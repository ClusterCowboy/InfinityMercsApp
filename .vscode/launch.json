{
  "version": "0.2.0",
  "configurations": [
    

    {
      "name": "Development Tablet",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "deploy-development-tablet",
      "program": "${workspaceFolder}/InfinityMercsApp/bin/Debug/net9.0-android/android-arm/InfinityMercsApp.dll",
      "cwd": "${workspaceFolder}/InfinityMercsApp",
      "stopAtEntry": false,
      "justMyCode": true
    },
    {
      "name": "MAUI Windows (Tablet Aspect)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-maui-windows-tablet",
