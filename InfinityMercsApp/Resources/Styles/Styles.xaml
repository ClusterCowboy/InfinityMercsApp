<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        DATAPAD GLOBAL STYLES — dark-only.
        Colour comes from semantic tokens in Colors.xaml (Void / Plate /
        Hairline / Signal / Text*). The app forces AppTheme.Dark at startup,
        so there is no light branch to maintain here.

        Typography:
            EthnocentricRegular  → page headlines (used sparingly)
            ConthraxSemiBold     → labels, controls, stat-block data (default)
            OpenSansRegular      → running prose / long descriptions (LabelProse)
    -->

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Signal}" />
    </Style>

    <Style TargetType="IndicatorView">
        <Setter Property="IndicatorColor" Value="{StaticResource Hairline}"/>
        <Setter Property="SelectedIndicatorColor" Value="{StaticResource Signal}"/>
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource Hairline}" />
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="4"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{StaticResource Hairline}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="BorderColor" Value="{StaticResource Signal}"/>
        <Setter Property="BorderWidth" Value="2"/>
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusDefault}"/>
        <Setter Property="Padding" Value="{DynamicResource PaddingControl}"/>
        <Setter Property="MinimumHeightRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="MinimumWidthRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                            <Setter Property="BackgroundColor" Value="Transparent" />
                            <Setter Property="BorderColor" Value="{StaticResource SignalDim}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource PlateRaised}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource Signal}" />
        <Setter Property="MinimumHeightRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="MinimumWidthRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Color" Value="{StaticResource Gray600}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="MinimumHeightRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="MinimumWidthRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="MinimumHeightRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="MinimumWidthRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="MinimumHeightRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="MinimumWidthRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Frame">
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="BorderColor" Value="{StaticResource Hairline}" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusDefault}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Plate}" />
    </Style>

    <Style TargetType="ImageButton">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="BorderColor" Value="Transparent"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="MinimumHeightRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="MinimumWidthRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.5" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver" />
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Span">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
    </Style>

    <Style TargetType="Label" x:Key="Headline">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="EthnocentricRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeHeadline}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="SubHeadline">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="EthnocentricRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSubHeadline}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!--
        Font-tier Label styles for code-behind use. Applied via
        `Style = (Style)Application.Current.Resources["LabelXxx"]` so the
        FontSize binding lives in XAML and resolves through DynamicResource.
    -->
    <Style TargetType="Label" x:Key="LabelMicro">
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeMicro}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
    </Style>

    <Style TargetType="Label" x:Key="LabelCaption">
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
    </Style>

    <Style TargetType="Label" x:Key="LabelBody">
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
    </Style>

    <!--
        Prose face for running text / long descriptions. Conthrax is a
        display/data face and gets hard to read in multi-line copy, so
        anything paragraph-length should carry this style.
    -->
    <Style TargetType="Label" x:Key="LabelProse">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="LineHeight" Value="1.35" />
    </Style>

    <Style TargetType="Label" x:Key="LabelSubHeadline">
        <Setter Property="FontFamily" Value="EthnocentricRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSubHeadline}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
    </Style>

    <Style TargetType="Label" x:Key="LabelTitleSmall">
        <Setter Property="FontFamily" Value="EthnocentricRegular" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeTitleSmall}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
    </Style>

    <Style TargetType="Entry" x:Key="EntryTitleSmall">
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeTitleSmall}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
    </Style>

    <Style TargetType="Button" x:Key="ButtonCaption">
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
    </Style>

    <Style TargetType="Button" x:Key="ButtonSubHeadline">
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSubHeadline}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
    </Style>

    <Style TargetType="ListView">
        <Setter Property="SeparatorColor" Value="{StaticResource Hairline}" />
        <Setter Property="RefreshControlColor" Value="{StaticResource Signal}" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="TitleColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="MinimumHeightRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="MinimumWidthRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                            <Setter Property="TitleColor" Value="{StaticResource TextDisabled}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource Signal}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="ProgressColor" Value="{StaticResource SignalDim}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="MinimumHeightRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="MinimumWidthRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{StaticResource Signal}" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="CancelButtonColor" Value="{StaticResource Signal}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="MinimumHeightRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="MinimumWidthRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                            <Setter Property="PlaceholderColor" Value="{StaticResource TextDisabled}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="SearchHandler">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                            <Setter Property="PlaceholderColor" Value="{StaticResource TextDisabled}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Ambient depth for raised surfaces. Neutral dark drop, not a glow. -->
    <Style TargetType="Shadow">
        <Setter Property="Radius" Value="8" />
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Brush" Value="{StaticResource Black}" />
        <Setter Property="Offset" Value="0,2" />
    </Style>

    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{StaticResource Signal}" />
        <Setter Property="MaximumTrackColor" Value="{StaticResource Hairline}" />
        <Setter Property="ThumbColor" Value="{StaticResource Signal}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="MinimumTrackColor" Value="{StaticResource SignalDim}"/>
                            <Setter Property="MaximumTrackColor" Value="{StaticResource Hairline}"/>
                            <Setter Property="ThumbColor" Value="{StaticResource Gray600}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="SwipeItem">
        <Setter Property="BackgroundColor" Value="{StaticResource Plate}" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource Signal}" />
        <Setter Property="ThumbColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="OnColor" Value="{StaticResource SignalDim}" />
                            <Setter Property="ThumbColor" Value="{StaticResource Gray600}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="On">
                        <VisualState.Setters>
                            <Setter Property="OnColor" Value="{StaticResource Signal}" />
                            <Setter Property="ThumbColor" Value="{StaticResource Void}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Off">
                        <VisualState.Setters>
                            <Setter Property="ThumbColor" Value="{StaticResource TextMuted}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="TimePicker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="ConthraxSemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
        <Setter Property="FontAutoScalingEnabled" Value="True"/>
        <Setter Property="MinimumHeightRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="MinimumWidthRequest" Value="{DynamicResource MinTouchTarget}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextDisabled}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource Void}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Void}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource TextDisabled}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource TextMuted}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource Plate}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Signal}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Signal}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextMuted}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource Void}" />
        <Setter Property="BarTextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="IconColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource Plate}" />
        <Setter Property="BarTextColor" Value="{StaticResource Signal}" />
        <Setter Property="UnselectedTabColor" Value="{StaticResource TextMuted}" />
        <Setter Property="SelectedTabColor" Value="{StaticResource Signal}" />
    </Style>

</ResourceDictionary>
