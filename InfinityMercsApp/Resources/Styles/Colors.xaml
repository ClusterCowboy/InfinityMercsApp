<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        ============================================================
        DATAPAD PALETTE  —  dark-only mercenary field terminal
        ============================================================
        One ground (cool slate), one signal (emerald). Spend colour
        on the accent and nowhere else. Status hues (caution / danger)
        exist only to mean something — never as decoration.

        SEMANTIC TOKENS are the going-forward vocabulary. The LEGACY
        KEYS below them are retuned aliases kept alive because
        Styles.xaml still references them; new XAML should use the
        semantic names.
        Note: For Android see also Platforms\Android\Resources\values\colors.xml
    -->

    <!-- ===== SEMANTIC TOKENS ===== -->

    <!-- Grounds: page → card → raised/selected surface -->
    <Color x:Key="Void">#0E1116</Color>
    <Color x:Key="Plate">#161B22</Color>
    <Color x:Key="PlateRaised">#1E2530</Color>

    <!-- Structure: hairline rules, dividers, tile frames -->
    <Color x:Key="Hairline">#2C3440</Color>
    <Color x:Key="HairlineBright">#3A4554</Color>

    <!-- Signal: the single accent. Dim = idle/disabled accent. Glow = ambient. -->
    <Color x:Key="Signal">#34D399</Color>
    <Color x:Key="SignalDim">#2A6B57</Color>
    <Color x:Key="SignalGlow">#3334D399</Color>

    <!-- Status: meaning-only. Caution = warnings, Danger = errors/injuries. -->
    <Color x:Key="Caution">#F59E0B</Color>
    <Color x:Key="Danger">#F87171</Color>

    <!-- Text ramp on dark grounds -->
    <Color x:Key="TextPrimary">#E6EBF2</Color>
    <Color x:Key="TextSecondary">#B5C0CE</Color>
    <Color x:Key="TextMuted">#8A97A8</Color>
    <Color x:Key="TextDisabled">#5A6677</Color>

    <SolidColorBrush x:Key="VoidBrush" Color="{StaticResource Void}" />
    <SolidColorBrush x:Key="PlateBrush" Color="{StaticResource Plate}" />
    <SolidColorBrush x:Key="PlateRaisedBrush" Color="{StaticResource PlateRaised}" />
    <SolidColorBrush x:Key="HairlineBrush" Color="{StaticResource Hairline}" />
    <SolidColorBrush x:Key="HairlineBrightBrush" Color="{StaticResource HairlineBright}" />
    <SolidColorBrush x:Key="SignalBrush" Color="{StaticResource Signal}" />
    <SolidColorBrush x:Key="SignalDimBrush" Color="{StaticResource SignalDim}" />
    <SolidColorBrush x:Key="CautionBrush" Color="{StaticResource Caution}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

    <!-- ===== LEGACY KEYS (retuned aliases — prefer the semantic tokens above) ===== -->

    <!-- Accents collapse onto the single Signal -->
    <Color x:Key="Primary">#34D399</Color>
    <Color x:Key="PrimaryDark">#2A6B57</Color>
    <Color x:Key="PrimaryDarkText">#E6EBF2</Color>
    <Color x:Key="Secondary">#2A6B57</Color>
    <Color x:Key="SecondaryDarkText">#B5C0CE</Color>
    <Color x:Key="Tertiary">#2C3440</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#34D399</Color>
    <Color x:Key="MidnightBlue">#E6EBF2</Color>
    <Color x:Key="OffBlack">#0E1116</Color>

    <!-- Neutral ramp, retuned cool/slate to sit under the datapad grounds -->
    <Color x:Key="Gray100">#E2E6EC</Color>
    <Color x:Key="Gray200">#C4CBD6</Color>
    <Color x:Key="Gray300">#9AA4B2</Color>
    <Color x:Key="Gray400">#7E8896</Color>
    <Color x:Key="Gray500">#5E6776</Color>
    <Color x:Key="Gray600">#3A4250</Color>
    <Color x:Key="Gray900">#161B22</Color>
    <Color x:Key="Gray950">#0E1116</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
