<?xml version="1.0" encoding="utf-8" ?>
<views:ContentPageBase
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
    xmlns:views="clr-namespace:InfinityMercsApp.Views"
    x:Class="InfinityMercsApp.Views.CreateNewCompanyPage"
    Title="Create New Company">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              RowSpacing="12"
              ColumnSpacing="12"
              HorizontalOptions="Fill"
              VerticalOptions="FillAndExpand"
              MaximumWidthRequest="1500">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="0">
                <Button x:Name="StandardCompanyButton"
                        Text=""
                        Command="{Binding OpenStandardCompanyPopupCommand}"
                        BackgroundColor="Transparent"
                        BorderColor="#22C55E"
                        BorderWidth="2"
                        CornerRadius="8"
                        VerticalOptions="FillAndExpand" />
                <Grid InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenStandardCompanyPopupCommand}" />
                    </Grid.GestureRecognizers>

                    <Image
                        Grid.Row="0"
                        x:Name="StandardCompanyIcon"
                        HeightRequest="120"
                        WidthRequest="120"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        InputTransparent="True"
                        Source="standard_company.png" />

                    <Label
                        Grid.Row="1"
                        Text="Standard Company"
                        FontSize="32"
                        VerticalOptions="Start"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        InputTransparent="True" />
                </Grid>
            </Grid>
            <Grid Grid.Row="0" Grid.Column="1">
                <Button x:Name="CohesiveCompanyButton"
                        Text=""
                        Command="{Binding OpenCohesiveCompanyPageCommand}"
                        BackgroundColor="Transparent"
                        BorderColor="#22C55E"
                        BorderWidth="2"
                        CornerRadius="8"
                        VerticalOptions="FillAndExpand" />
                <Grid InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenCohesiveCompanyPageCommand}" />
                    </Grid.GestureRecognizers>

                    <Image
                        Grid.Row="0"
                        x:Name="CohesiveCompanyIcon"
                        HeightRequest="120"
                        WidthRequest="120"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        InputTransparent="True"
                        Source="cohesive_company.png" />

                    <Label
                        Grid.Row="1"
                        Text="Cohesive Company"
                        FontSize="32"
                        VerticalOptions="Start"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        InputTransparent="True" />
                </Grid>
            </Grid>
            <Grid Grid.Row="1" Grid.Column="0">
                <Button x:Name="InspiringLeaderButton"
                        Text=""
                        Command="{Binding OpenInspiringLeadershipPageCommand}"
                        BackgroundColor="Transparent"
                        BorderColor="#22C55E"
                        BorderWidth="2"
                        CornerRadius="8"
                        VerticalOptions="FillAndExpand" />
                <Grid InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenInspiringLeadershipPageCommand}" />
                    </Grid.GestureRecognizers>

                    <Image
                        Grid.Row="0"
                        x:Name="InspiringLeaderIcon"
                        HeightRequest="120"
                        WidthRequest="120"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        InputTransparent="True"
                        Source="inspiring_leadership.png" />

                    <Label
                        Grid.Row="1"
                        Text="Inspiring Leader"
                        FontSize="32"
                        VerticalOptions="Start"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        InputTransparent="True" />
                </Grid>
            </Grid>
            <Grid Grid.Row="1" Grid.Column="1">
                <Button x:Name="AirborneCompanyButton"
                        Text=""
                        Command="{Binding OpenAirborneCompanyPageCommand}"
                        BackgroundColor="Transparent"
                        BorderColor="#22C55E"
                        BorderWidth="2"
                        CornerRadius="8"
                        VerticalOptions="FillAndExpand" />
                <Grid InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenAirborneCompanyPageCommand}" />
                    </Grid.GestureRecognizers>

                    <Image
                        Grid.Row="0"
                        x:Name="AirborneCompanyIcon"
                        HeightRequest="120"
                        WidthRequest="120"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        InputTransparent="True"
                        Source="airborne_company.png" />

                    <Label
                        Grid.Row="1"
                        Text="Airborne Company"
                        FontSize="32"
                        VerticalOptions="Start"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        InputTransparent="True" />
                </Grid>
            </Grid>
            <Grid Grid.Row="2" Grid.Column="0">
                <Button x:Name="TagCompanyButton"
                        Text=""
                        Command="{Binding OpenTAGCompanyPageCommand}"
                        BackgroundColor="Transparent"
                        BorderColor="#22C55E"
                        BorderWidth="2"
                        CornerRadius="8"
                        VerticalOptions="FillAndExpand" />
                <Grid InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenTAGCompanyPageCommand}" />
                    </Grid.GestureRecognizers>

                    <Image
                        Grid.Row="0"
                        x:Name="TagCompanyIcon"
                        HeightRequest="120"
                        WidthRequest="120"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        InputTransparent="True"
                        Source="tag_company.png" />

                    <Label
                        Grid.Row="1"
                        Text="TAG Company"
                        FontSize="32"
                        VerticalOptions="Start"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        InputTransparent="True" />
                </Grid>
            </Grid>
            <Grid Grid.Row="2" Grid.Column="1">
                <Button x:Name="LoneWolfCompanyButton"
                        Text=""
                        Command="{Binding OpenLoneWolfCompanyPopupCommand}"
                        BackgroundColor="Transparent"
                        BorderColor="#22C55E"
                        BorderWidth="2"
                        CornerRadius="8"
                        VerticalOptions="FillAndExpand" />
                <Grid InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenLoneWolfCompanyPopupCommand}" />
                    </Grid.GestureRecognizers>

                    <Image
                        Grid.Row="0"
                        x:Name="LoneWolfCompanyIcon"
                        HeightRequest="120"
                        WidthRequest="120"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        InputTransparent="True"
                        Source="proxy_pack.png" />

                    <Label
                        Grid.Row="1"
                        Text="Lone Wolf Company"
                        FontSize="32"
                        VerticalOptions="Start"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        InputTransparent="True" />
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" VerticalOptions="End">
            <Button
                Text="← BACK"
                HorizontalOptions="Start"
                Clicked="OnBackClicked" />
        </Grid>
    </Grid>

</views:ContentPageBase>

