<?xml version="1.0" encoding="utf-8" ?>
<layout:AdaptiveContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
    xmlns:layout="clr-namespace:InfinityMercsApp.Views.Adaptive"
    x:Class="InfinityMercsApp.Views.CreateNewCompanyPage"
    x:Name="CreateNewCompanyRoot"
    Title="Create New Company">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Scrollable card list/grid. Column count adapts to width in code-behind. -->
        <ScrollView Grid.Row="0" HorizontalOptions="Fill">
            <Grid x:Name="CardGrid"
                  RowSpacing="12"
                  ColumnSpacing="12"
                  HorizontalOptions="Fill"
                  MaximumWidthRequest="1500">

                <Grid x:Name="CardStandard" MinimumHeightRequest="160" VerticalOptions="Fill">
                    <Button x:Name="StandardCompanyButton"
                            Text=""
                            Command="{Binding OpenStandardCompanyPopupCommand}"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource Signal}"
                            BorderWidth="2"
                            CornerRadius="4"
                            VerticalOptions="FillAndExpand" />
                    <Grid x:Name="StandardCardContent" InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenStandardCompanyPopupCommand}" />
                        </Grid.GestureRecognizers>

                        <skia:SKCanvasView
                            Grid.Row="0"
                            x:Name="StandardCompanyIcon"
                            HeightRequest="120"
                            WidthRequest="120"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            InputTransparent="True"
                            PaintSurface="OnStandardCompanyIconPaintSurface" />

                        <Label
                            x:Name="StandardCompanyLabel"
                            Grid.Row="1"
                            Text="Standard Company"
                            FontSize="{DynamicResource FontSizeHeadline}"
                            VerticalOptions="Start"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            InputTransparent="True" />
                    </Grid>
                </Grid>

                <Grid x:Name="CardCohesive" MinimumHeightRequest="160" VerticalOptions="Fill">
                    <Button x:Name="CohesiveCompanyButton"
                            Text=""
                            Command="{Binding OpenCohesiveCompanyPageCommand}"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource Signal}"
                            BorderWidth="2"
                            CornerRadius="4"
                            VerticalOptions="FillAndExpand" />
                    <Grid x:Name="CohesiveCardContent" InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenCohesiveCompanyPageCommand}" />
                        </Grid.GestureRecognizers>

                        <skia:SKCanvasView
                            Grid.Row="0"
                            x:Name="CohesiveCompanyIcon"
                            HeightRequest="120"
                            WidthRequest="120"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            InputTransparent="True"
                            PaintSurface="OnCohesiveCompanyIconPaintSurface" />

                        <Label
                            x:Name="CohesiveCompanyLabel"
                            Grid.Row="1"
                            Text="Cohesive Company"
                            FontSize="{DynamicResource FontSizeHeadline}"
                            VerticalOptions="Start"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            InputTransparent="True" />
                    </Grid>
                </Grid>

                <Grid x:Name="CardInspiring" MinimumHeightRequest="160" VerticalOptions="Fill">
                    <Button x:Name="InspiringLeaderButton"
                            Text=""
                            Command="{Binding OpenInspiringLeadershipPageCommand}"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource Signal}"
                            BorderWidth="2"
                            CornerRadius="4"
                            VerticalOptions="FillAndExpand" />
                    <Grid x:Name="InspiringCardContent" InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenInspiringLeadershipPageCommand}" />
                        </Grid.GestureRecognizers>

                        <skia:SKCanvasView
                            Grid.Row="0"
                            x:Name="InspiringLeaderIcon"
                            HeightRequest="120"
                            WidthRequest="120"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            InputTransparent="True"
                            PaintSurface="OnInspiringLeaderIconPaintSurface" />

                        <Label
                            x:Name="InspiringLeaderLabel"
                            Grid.Row="1"
                            Text="Inspiring Leader"
                            FontSize="{DynamicResource FontSizeHeadline}"
                            VerticalOptions="Start"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            InputTransparent="True" />
                    </Grid>
                </Grid>

                <Grid x:Name="CardAirborne" MinimumHeightRequest="160" VerticalOptions="Fill">
                    <Button x:Name="AirborneCompanyButton"
                            Text=""
                            Command="{Binding OpenAirborneCompanyPageCommand}"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource Signal}"
                            BorderWidth="2"
                            CornerRadius="4"
                            VerticalOptions="FillAndExpand" />
                    <Grid x:Name="AirborneCardContent" InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenAirborneCompanyPageCommand}" />
                        </Grid.GestureRecognizers>

                        <skia:SKCanvasView
                            Grid.Row="0"
                            x:Name="AirborneCompanyIcon"
                            HeightRequest="120"
                            WidthRequest="120"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            InputTransparent="True"
                            PaintSurface="OnAirborneCompanyIconPaintSurface" />

                        <Label
                            x:Name="AirborneCompanyLabel"
                            Grid.Row="1"
                            Text="Airborne Company"
                            FontSize="{DynamicResource FontSizeHeadline}"
                            VerticalOptions="Start"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            InputTransparent="True" />
                    </Grid>
                </Grid>

                <Grid x:Name="CardTag" MinimumHeightRequest="160" VerticalOptions="Fill">
                    <Button x:Name="TagCompanyButton"
                            Text=""
                            Command="{Binding OpenTAGCompanyPageCommand}"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource Signal}"
                            BorderWidth="2"
                            CornerRadius="4"
                            VerticalOptions="FillAndExpand" />
                    <Grid x:Name="TagCardContent" InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenTAGCompanyPageCommand}" />
                        </Grid.GestureRecognizers>

                        <skia:SKCanvasView
                            Grid.Row="0"
                            x:Name="TagCompanyIcon"
                            HeightRequest="120"
                            WidthRequest="120"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            InputTransparent="True"
                            PaintSurface="OnTagCompanyIconPaintSurface" />

                        <Label
                            x:Name="TagCompanyLabel"
                            Grid.Row="1"
                            Text="TAG Company"
                            FontSize="{DynamicResource FontSizeHeadline}"
                            VerticalOptions="Start"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            InputTransparent="True" />
                    </Grid>
                </Grid>

                <Grid x:Name="CardLoneWolf" MinimumHeightRequest="160" VerticalOptions="Fill" IsVisible="False">
                    <Button x:Name="LoneWolfCompanyButton"
                            Text=""
                            Command="{Binding OpenLoneWolfCompanyPopupCommand}"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource Signal}"
                            BorderWidth="2"
                            CornerRadius="4"
                            VerticalOptions="FillAndExpand" />
                    <Grid InputTransparent="False" RowDefinitions="*,Auto" RowSpacing="6" Padding="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLoneWolfCompanyPopupCommand}" />
                        </Grid.GestureRecognizers>

                        <skia:SKCanvasView
                            Grid.Row="0"
                            x:Name="LoneWolfCompanyIcon"
                            HeightRequest="120"
                            WidthRequest="120"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            InputTransparent="True"
                            PaintSurface="OnLoneWolfCompanyIconPaintSurface" />

                        <Label
                            Grid.Row="1"
                            Text="Lone Wolf Company"
                            FontSize="{DynamicResource FontSizeHeadline}"
                            VerticalOptions="Start"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            InputTransparent="True" />
                    </Grid>
                </Grid>
            </Grid>
        </ScrollView>

        <Grid Grid.Row="1" VerticalOptions="End">
            <Button
                Text="← BACK"
                HorizontalOptions="Start"
                Clicked="OnBackClicked" />
        </Grid>
    </Grid>

</layout:AdaptiveContentPage>
