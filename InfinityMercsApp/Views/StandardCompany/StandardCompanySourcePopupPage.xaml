<?xml version="1.0" encoding="utf-8" ?>
<layout:AdaptiveContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
    xmlns:layout="clr-namespace:InfinityMercsApp.Views.Adaptive"
    x:Class="InfinityMercsApp.Views.StandardCompanySourcePopupPage"
    x:Name="SourcePopupRoot"
    BackgroundColor="#800E1116"
    Shell.NavBarIsVisible="False">

    <Grid Padding="32">
        <Border
            x:Name="ModalCard"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#161B22}"
            StrokeThickness="0"
            Padding="24"
            StrokeShape="RoundRectangle 4"
            HorizontalOptions="Fill"
            VerticalOptions="Center">
            <Grid RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Label
                    Text="Choose your source of units:"
                    FontSize="{DynamicResource FontSizeTitleLarge}"
                    FontAttributes="Bold"
                    HorizontalTextAlignment="Center" />

                <ScrollView Grid.Row="1">
                <Grid x:Name="CardsGrid" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="SourceCardOne" Grid.Column="0" MinimumHeightRequest="240">
                        <Button x:Name="OneVanillaFactionButton" Text="" Command="{Binding VanillaFactionSelectedCommand}" />
                        <VerticalStackLayout InputTransparent="True" Spacing="12" Padding="12">
                            <Image
                                x:Name="OneVanillaFactionIcon"
                                HeightRequest="140"
                                HorizontalOptions="Fill"
                                Source="single_sectorial.png" />
                            <Label
                                Text="One Vanilla Faction"
                                FontSize="{DynamicResource FontSizeTitleLarge}"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid x:Name="SourceCardTwo" Grid.Column="1" MinimumHeightRequest="240">
                        <Button x:Name="TwoSectorialsButton" Text="" Command="{Binding TwoSectorialsSelectedCommand}" />
                        <VerticalStackLayout InputTransparent="True" Spacing="12" Padding="12">
                            <Image
                                x:Name="TwoSectorialsIcon"
                                HeightRequest="140"
                                HorizontalOptions="Fill"
                                Source="multiple_sectorials.png" />
                            <Label
                                Text="Two Sectorials"
                                FontSize="{DynamicResource FontSizeTitleLarge}"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Grid>
                </ScrollView>

                <Button
                    Grid.Row="2"
                    Text="← BACK"
                    HorizontalOptions="Start"
                    Clicked="OnBackClicked" />
            </Grid>
        </Border>
    </Grid>
</layout:AdaptiveContentPage>
