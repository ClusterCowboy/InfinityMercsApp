<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             x:Class="InfinityMercsApp.Views.Season.SeasonPage"
             x:Name="SeasonRoot"
             Title="Season"
             BackgroundColor="#111827">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                BackgroundColor="#1F2937"
                Stroke="#374151"
                StrokeThickness="1"
                Padding="16,12"
                StrokeShape="Rectangle">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                    <Label x:Name="CompanyNameLabel"
                           Text="Season"
                           FontSize="{DynamicResource FontSizeSubHeadline}"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label x:Name="CompanyTypeLabel"
                           Text=""
                           FontSize="{DynamicResource FontSizeCaption}"
                           TextColor="#9CA3AF" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="PLAY ROUND"
                        BackgroundColor="#22C55E"
                        TextColor="Black"
                        BorderColor="#22C55E"
                        FontAttributes="Bold"
                        Clicked="OnPlayRoundClicked"
                        VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- Tab Content -->
        <Grid Grid.Row="1">

            <!-- Team Tab — mirrors CompanyViewerPage layout -->
            <Grid x:Name="TeamTabContent"
                  IsVisible="True"
                  Padding="16,8,16,0"
                  RowDefinitions="Auto,*"
                  RowSpacing="6">

                <!-- Horizontal unit strip -->
                <ScrollView x:Name="UnitStripScrollView"
                            Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <ScrollView.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnUnitStripPanUpdated" />
                    </ScrollView.GestureRecognizers>
                    <HorizontalStackLayout
                        BindableLayout.ItemsSource="{Binding Source={x:Reference SeasonRoot}, Path=CompanyUnits}"
                        Spacing="8"
                        Padding="0,0,2,0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <controls:CompanyViewerUnitTileView
                                    ItemTappedCommand="{Binding Source={x:Reference SeasonRoot}, Path=SelectCompanyUnitCommand}"
                                    ItemTappedCommandParameter="{Binding .}" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Selected unit details -->
                <Border Grid.Row="1" StrokeThickness="0" Padding="0,4,0,0">
                    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">

                        <!-- Name / type heading -->
                        <VerticalStackLayout Grid.Row="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Source={x:Reference SeasonRoot}, Path=SelectedCaptainNameHeading}"
                                   FontSize="{DynamicResource FontSizeTitleSmall}"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0"
                                       Text="{Binding Source={x:Reference SeasonRoot}, Path=SelectedProfileBaseNameHeading}"
                                       FontSize="{DynamicResource FontSizeBody}"
                                       TextColor="#9CA3AF"
                                       HorizontalOptions="Start"
                                       IsVisible="{Binding Source={x:Reference SeasonRoot}, Path=HasSelectedProfileBaseNameHeading}" />
                                <Label Grid.Column="1"
                                       Text="{Binding Source={x:Reference SeasonRoot}, Path=SelectedUnitTypeHeading}"
                                       FontSize="{DynamicResource FontSizeBody}"
                                       TextColor="#9CA3AF"
                                       HorizontalOptions="End"
                                       IsVisible="{Binding Source={x:Reference SeasonRoot}, Path=HasSelectedUnitTypeHeading}" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Stats block -->
                        <controls:UnitDisplayConfigurationsView
                            Grid.Row="1"
                            x:Name="TeamUnitDisplayView"
                            UnitNameHeading="{Binding UnitNameHeading}"
                            ShowRegularOrderIcon="{Binding ShowRegularOrderIcon}"
                            ShowIrregularOrderIcon="{Binding ShowIrregularOrderIcon}"
                            ShowImpetuousIcon="{Binding ShowImpetuousIcon}"
                            ShowTacticalAwarenessIcon="{Binding ShowTacticalAwarenessIcon}"
                            ShowCubeIcon="{Binding ShowCubeIcon}"
                            ShowCube2Icon="{Binding ShowCube2Icon}"
                            ShowHackableIcon="{Binding ShowHackableIcon}"
                            UnitMov="{Binding UnitMov}"
                            UnitCc="{Binding UnitCc}"
                            UnitBs="{Binding UnitBs}"
                            UnitPh="{Binding UnitPh}"
                            UnitWip="{Binding UnitWip}"
                            UnitArm="{Binding UnitArm}"
                            UnitBts="{Binding UnitBts}"
                            UnitVitalityHeader="{Binding UnitVitalityHeader}"
                            UnitVitality="{Binding UnitVitality}"
                            UnitS="{Binding UnitS}"
                            UnitAva="{Binding UnitAva}"
                            ShowConfigurationsSection="False"
                            EquipmentSummaryFormatted="{Binding EquipmentSummaryFormatted}"
                            SpecialSkillsSummaryFormatted="{Binding SpecialSkillsSummaryFormatted}" />

                        <!-- Weapons -->
                        <ScrollView Grid.Row="2">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0" Spacing="6">
                                    <Label Text="Weapons" FontSize="{DynamicResource FontSizeSectionHeader}" FontAttributes="Bold" TextColor="White" />
                                    <Label FormattedText="{Binding Source={x:Reference SeasonRoot}, Path=CurrentRangedWeaponsFormatted}"
                                           FontSize="{DynamicResource FontSizeBody}" LineBreakMode="WordWrap" />
                                    <Label FormattedText="{Binding Source={x:Reference SeasonRoot}, Path=CurrentMeleeWeaponsFormatted}"
                                           FontSize="{DynamicResource FontSizeBody}" LineBreakMode="WordWrap" />
                                    <Label FormattedText="{Binding Source={x:Reference SeasonRoot}, Path=CurrentPeripheralsFormatted}"
                                           FontSize="{DynamicResource FontSizeBody}" LineBreakMode="WordWrap"
                                           IsVisible="{Binding Source={x:Reference SeasonRoot}, Path=HasCurrentPeripherals}" />
                                </VerticalStackLayout>
                                <Grid Grid.Column="1" />
                            </Grid>
                        </ScrollView>

                    </Grid>
                </Border>
            </Grid>

            <!-- Inventory Tab (stub) -->
            <Grid x:Name="InventoryTabContent" IsVisible="False" Padding="16,8">
                <Label Text="Inventory — coming soon."
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="#6B7280" />
            </Grid>

            <!-- Marketplace Tab -->
            <Grid x:Name="MarketplaceTabContent" IsVisible="False" RowDefinitions="Auto,*">
                <!-- Store tab strip -->
                <Border Grid.Row="0"
                        BackgroundColor="#1F2937"
                        StrokeThickness="0"
                        Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout x:Name="StoreTabStrip" Spacing="6" Padding="12,6" />
                        </ScrollView>
                        <BoxView HeightRequest="1" Color="#374151" />
                    </VerticalStackLayout>
                </Border>
                <!-- Store content -->
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout x:Name="StoreContentArea" Padding="16,12" Spacing="0" />
                </ScrollView>
            </Grid>

        </Grid>

        <!-- Marketplace item popup overlay — covers full page -->
        <Grid x:Name="MarketplacePopupOverlay"
              Grid.Row="0" Grid.RowSpan="3"
              IsVisible="False"
              BackgroundColor="#D0111827">
            <Border BackgroundColor="#1F2937"
                    Stroke="#374151"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Margin="16,60,16,24">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="Auto,*"
                          BackgroundColor="#374151"
                          Padding="4,4">
                        <Button x:Name="PopupBackButton"
                                Grid.Column="0"
                                Text="← Back"
                                BackgroundColor="Transparent"
                                BorderColor="Transparent"
                                TextColor="#22C55E"
                                FontAttributes="Bold"
                                Padding="8,0"
                                Clicked="OnPopupBackClicked" />
                        <Label x:Name="PopupTitleLabel"
                               Grid.Column="1"
                               FontSize="{DynamicResource FontSizeBody}"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalTextAlignment="Center"
                               Padding="4,0,8,0"
                               LineBreakMode="TailTruncation" />
                    </Grid>
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout x:Name="PopupContentArea"
                                             Padding="16,12"
                                             Spacing="6" />
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Tab Bar -->
        <Border Grid.Row="2"
                BackgroundColor="#1F2937"
                Stroke="#374151"
                StrokeThickness="1"
                Padding="0"
                StrokeShape="Rectangle">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="0">
                <Button x:Name="TeamTabButton"
                        Grid.Column="0"
                        Text="TEAM"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        BorderWidth="0"
                        FontAttributes="Bold"
                        TextColor="#22C55E"
                        Clicked="OnTeamTabClicked" />
                <Button x:Name="InventoryTabButton"
                        Grid.Column="1"
                        Text="INVENTORY"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        BorderWidth="0"
                        TextColor="#6B7280"
                        Clicked="OnInventoryTabClicked" />
                <Button x:Name="MarketplaceTabButton"
                        Grid.Column="2"
                        Text="MARKETPLACE"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        BorderWidth="0"
                        TextColor="#6B7280"
                        Clicked="OnMarketplaceTabClicked" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>
