<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Season.SeasonPage"
             x:Name="SeasonRoot"
             Title=""
             BackgroundColor="#111827">

    <Grid RowDefinitions="Auto,*,Auto">

        <Border Grid.Row="0"
                BackgroundColor="#111827"
                Stroke="#374151"
                StrokeThickness="1"
                StrokeShape="Rectangle"
                Padding="10,8"
                MinimumHeightRequest="92">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="2"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Fill">
                    <Label x:Name="CompanyNameLabel"
                           Text="Season"
                           FontSize="{DynamicResource FontSizeSubHeadline}"
                           FontAttributes="Bold"
                           TextColor="White"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                    <Label x:Name="CompanyTypeLabel"
                           Text=""
                           FontSize="{DynamicResource FontSizeCaption}"
                           TextColor="#9CA3AF"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>
                <Border Grid.Column="1"
                        x:Name="PlayRoundButton"
                        BackgroundColor="#22C55E"
                        Stroke="Transparent"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 6"
                        Padding="10,5"
                        WidthRequest="112"
                        MinimumWidthRequest="112"
                        HeightRequest="66"
                        VerticalOptions="Center"
                        SizeChanged="OnPlayRoundButtonSizeChanged">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPlayRoundClicked" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                        <skia:SKCanvasView x:Name="PlayRoundFlagsCanvas"
                                           WidthRequest="36" HeightRequest="36"
                                           HorizontalOptions="Center"
                                           PaintSurface="OnPlayRoundFlagsCanvasPaintSurface" />
                        <Label x:Name="PlayRoundLabel"
                               Text="PLAY ROUND"
                               TextColor="Black"
                               FontAttributes="Bold"
                               FontSize="{DynamicResource FontSizeCaption}"
                               HorizontalTextAlignment="Center"
                               MaxLines="1"
                               LineBreakMode="NoWrap" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Border>

        <!-- Tab Content -->
        <Grid Grid.Row="1">

            <!-- Team Tab — mirrors CompanyViewerPage layout -->
            <Grid x:Name="TeamTabContent"
                  IsVisible="True"
                  Padding="16,8,16,0"
                  RowDefinitions="Auto,*"
                  RowSpacing="6">

                <!-- Unit selector (combo box) -->
                <Border Grid.Row="0"
                        x:Name="UnitPickerHeader"
                        BackgroundColor="#1F2937"
                        Stroke="#374151"
                        StrokeThickness="1"
                        Padding="8,6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUnitPickerTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="40,*,20" ColumnSpacing="8" VerticalOptions="Center">
                        <Grid Grid.Column="0" WidthRequest="36" HeightRequest="36" HorizontalOptions="Center" VerticalOptions="Center">
                            <skia:SKCanvasView x:Name="PickerHeaderLogoCanvas"
                                               PaintSurface="OnPickerHeaderLogoCanvasPaintSurface" />
                            <skia:SKCanvasView x:Name="PickerHeaderLtCanvas"
                                               WidthRequest="14" HeightRequest="14"
                                               HorizontalOptions="Start" VerticalOptions="Start"
                                               IsVisible="False"
                                               PaintSurface="OnPickerHeaderLtCanvasPaintSurface" />
                        </Grid>
                        <Label x:Name="PickerHeaderNameLabel"
                               Grid.Column="1"
                               Text="Select unit..."
                               TextColor="White"
                               FontSize="{DynamicResource FontSizeBody}"
                               VerticalTextAlignment="Center"
                               LineBreakMode="TailTruncation" />
                        <Label Grid.Column="2"
                               Text="▼"
                               TextColor="#9CA3AF"
                               FontSize="{DynamicResource FontSizeCaption}"
                               VerticalTextAlignment="Center"
                               HorizontalTextAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Selected unit details -->
                <Border Grid.Row="1" StrokeThickness="0" Padding="0,4,0,0">
                    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">

                        <!-- Name / type heading -->
                        <VerticalStackLayout Grid.Row="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Source={x:Reference SeasonRoot}, Path=SelectedCaptainNameHeading}"
                                   FontSize="{DynamicResource FontSizeTitleSmall}"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0"
                                       Text="{Binding Source={x:Reference SeasonRoot}, Path=SelectedProfileBaseNameHeading}"
                                       FontSize="{DynamicResource FontSizeBody}"
                                       TextColor="#9CA3AF"
                                       HorizontalOptions="Start"
                                       IsVisible="{Binding Source={x:Reference SeasonRoot}, Path=HasSelectedProfileBaseNameHeading}" />
                                <Label Grid.Column="1"
                                       Text="{Binding Source={x:Reference SeasonRoot}, Path=SelectedUnitTypeHeading}"
                                       FontSize="{DynamicResource FontSizeBody}"
                                       TextColor="#9CA3AF"
                                       HorizontalOptions="End"
                                       IsVisible="{Binding Source={x:Reference SeasonRoot}, Path=HasSelectedUnitTypeHeading}" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Stats block -->
                        <controls:UnitDisplayConfigurationsView
                            Grid.Row="1"
                            x:Name="TeamUnitDisplayView"
                            UnitNameHeading="{Binding UnitNameHeading}"
                            ShowRegularOrderIcon="{Binding ShowRegularOrderIcon}"
                            ShowIrregularOrderIcon="{Binding ShowIrregularOrderIcon}"
                            ShowImpetuousIcon="{Binding ShowImpetuousIcon}"
                            ShowTacticalAwarenessIcon="{Binding ShowTacticalAwarenessIcon}"
                            ShowCubeIcon="{Binding ShowCubeIcon}"
                            ShowCube2Icon="{Binding ShowCube2Icon}"
                            ShowHackableIcon="{Binding ShowHackableIcon}"
                            UnitMov="{Binding UnitMov}"
                            UnitCc="{Binding UnitCc}"
                            UnitBs="{Binding UnitBs}"
                            UnitPh="{Binding UnitPh}"
                            UnitWip="{Binding UnitWip}"
                            UnitArm="{Binding UnitArm}"
                            UnitBts="{Binding UnitBts}"
                            UnitVitalityHeader="{Binding UnitVitalityHeader}"
                            UnitVitality="{Binding UnitVitality}"
                            UnitS="{Binding UnitS}"
                            UnitAva="{Binding UnitAva}"
                            ShowConfigurationsSection="False"
                            ShowUnitName="False"
                            ShowAva="False"
                            EquipmentSummaryFormatted="{Binding EquipmentSummaryFormatted}"
                            SpecialSkillsSummaryFormatted="{Binding SpecialSkillsSummaryFormatted}" />

                        <!-- Weapons -->
                        <ScrollView Grid.Row="2">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0" Spacing="6">
                                    <Label Text="Weapons" FontSize="{DynamicResource FontSizeSectionHeader}" FontAttributes="Bold" TextColor="White" />
                                    <Label FormattedText="{Binding Source={x:Reference SeasonRoot}, Path=CurrentRangedWeaponsFormatted}"
                                           FontSize="{DynamicResource FontSizeBody}" LineBreakMode="WordWrap" />
                                    <Label FormattedText="{Binding Source={x:Reference SeasonRoot}, Path=CurrentMeleeWeaponsFormatted}"
                                           FontSize="{DynamicResource FontSizeBody}" LineBreakMode="WordWrap" />
                                    <Label FormattedText="{Binding Source={x:Reference SeasonRoot}, Path=CurrentPeripheralsFormatted}"
                                           FontSize="{DynamicResource FontSizeBody}" LineBreakMode="WordWrap"
                                           IsVisible="{Binding Source={x:Reference SeasonRoot}, Path=HasCurrentPeripherals}" />
                                </VerticalStackLayout>
                                <Grid Grid.Column="1" />
                            </Grid>
                        </ScrollView>

                    </Grid>
                </Border>

                <!-- Unit picker dropdown list -->
                <Border Grid.Row="1"
                        x:Name="UnitPickerDropdown"
                        IsVisible="False"
                        ZIndex="50"
                        VerticalOptions="Start"
                        BackgroundColor="#1F2937"
                        Stroke="#374151"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>
                    <ScrollView MaximumHeightRequest="320">
                        <VerticalStackLayout x:Name="UnitPickerDropdownStack" Spacing="0" />
                    </ScrollView>
                </Border>

                <!-- Tap-outside-to-dismiss backdrop -->
                <Grid Grid.Row="1"
                      x:Name="UnitPickerDismissOverlay"
                      IsVisible="False"
                      ZIndex="49"
                      BackgroundColor="Transparent"
                      InputTransparent="False">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUnitPickerDismissTapped" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Grid>

            <!-- Inventory Tab (stub) -->
            <Grid x:Name="InventoryTabContent" IsVisible="False" Padding="16,8">
                <Label Text="Inventory — coming soon."
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="#6B7280" />
            </Grid>

            <!-- Marketplace Tab -->
            <Grid x:Name="MarketplaceTabContent" IsVisible="False" RowDefinitions="Auto,*">
                <!-- Store tab strip -->
                <Border Grid.Row="0"
                        BackgroundColor="#1F2937"
                        StrokeThickness="0"
                        Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout x:Name="StoreTabStrip" Spacing="6" Padding="12,6" />
                        </ScrollView>
                        <BoxView HeightRequest="1" Color="#374151" />
                    </VerticalStackLayout>
                </Border>
                <!-- Store content -->
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout x:Name="StoreContentArea" Padding="16,12" Spacing="0" />
                </ScrollView>
            </Grid>

        </Grid>

        <!-- Marketplace item popup overlay — covers full page -->
        <Grid x:Name="MarketplacePopupOverlay"
              Grid.Row="0" Grid.RowSpan="3"
              IsVisible="False"
              BackgroundColor="#D0111827">
            <Border BackgroundColor="#1F2937"
                    Stroke="#374151"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Margin="16,60,16,24">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="Auto,*"
                          BackgroundColor="#374151"
                          Padding="4,4">
                        <Button x:Name="PopupBackButton"
                                Grid.Column="0"
                                Text="← Back"
                                BackgroundColor="Transparent"
                                BorderColor="Transparent"
                                TextColor="#22C55E"
                                FontAttributes="Bold"
                                Padding="8,0"
                                Clicked="OnPopupBackClicked" />
                        <Label x:Name="PopupTitleLabel"
                               Grid.Column="1"
                               FontSize="{DynamicResource FontSizeBody}"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalTextAlignment="Center"
                               Padding="4,0,8,0"
                               LineBreakMode="TailTruncation" />
                    </Grid>
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout x:Name="PopupContentArea"
                                             Padding="16,12"
                                             Spacing="6" />
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Tab Bar -->
        <Border Grid.Row="2"
                BackgroundColor="#1F2937"
                Stroke="#374151"
                StrokeThickness="1"
                Padding="0"
                StrokeShape="Rectangle">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="0">
                <Button x:Name="TeamTabButton"
                        Grid.Column="0"
                        Text="TEAM"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        BorderWidth="0"
                        FontAttributes="Bold"
                        TextColor="#22C55E"
                        Clicked="OnTeamTabClicked" />
                <Button x:Name="InventoryTabButton"
                        Grid.Column="1"
                        Text="INVENTORY"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        BorderWidth="0"
                        TextColor="#6B7280"
                        Clicked="OnInventoryTabClicked" />
                <Button x:Name="MarketplaceTabButton"
                        Grid.Column="2"
                        Text="MARKETPLACE"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        BorderWidth="0"
                        TextColor="#6B7280"
                        Clicked="OnMarketplaceTabClicked" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>
