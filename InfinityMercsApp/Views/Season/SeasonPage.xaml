<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Season.SeasonPage"
             x:Name="SeasonRoot"
             Title=""
             BackgroundColor="#111827">

    <Shell.TitleView>
        <Grid HorizontalOptions="Fill"
              VerticalOptions="Fill"
              Padding="4,0,12,0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <Label x:Name="SeasonTitleBarLabel"
                   Grid.Column="0"
                   Text="{Binding Source={x:Reference SeasonRoot}, Path=SeasonTitleBarText}"
                   FontSize="{DynamicResource FontSizeBody}"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalTextAlignment="Center"
                   HorizontalTextAlignment="Start"
                   MaxLines="1"
                   LineBreakMode="TailTruncation" />
            <Label x:Name="SeasonResourcesTitleBarLabel"
                   Grid.Column="1"
                   Text="{Binding Source={x:Reference SeasonRoot}, Path=SeasonResourcesTitleBarText}"
                   FontSize="{DynamicResource FontSizeBody}"
                   FontAttributes="Bold"
                   TextColor="#22C55E"
                   VerticalTextAlignment="Center"
                   HorizontalTextAlignment="End"
                   HorizontalOptions="End"
                   MaxLines="1"
                   LineBreakMode="NoWrap" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*,Auto">

        <Border Grid.Row="0"
                BackgroundColor="#111827"
                Stroke="#374151"
                StrokeThickness="1"
                StrokeShape="Rectangle"
                Padding="10,8"
                MinimumHeightRequest="92">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="2"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Fill">
                    <Label x:Name="CompanyNameLabel"
                           Text="Season"
                           FontSize="{DynamicResource FontSizeSubHeadline}"
                           FontAttributes="Bold"
                           TextColor="White"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                    <Label x:Name="CompanyTypeLabel"
                           Text=""
                           FontSize="{DynamicResource FontSizeCaption}"
                           TextColor="#9CA3AF"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>
                <Border Grid.Column="1"
                        x:Name="PlayRoundButton"
                        BackgroundColor="#22C55E"
                        Stroke="Transparent"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 6"
                        Padding="10,5"
                        WidthRequest="112"
                        MinimumWidthRequest="112"
                        HeightRequest="82"
                        VerticalOptions="Center"
                        SizeChanged="OnPlayRoundButtonSizeChanged">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPlayRoundClicked" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                        <skia:SKCanvasView x:Name="PlayRoundFlagsCanvas"
                                           WidthRequest="36" HeightRequest="36"
                                           HorizontalOptions="Center"
                                           PaintSurface="OnPlayRoundFlagsCanvasPaintSurface" />
                        <Label x:Name="PlayRoundLabel"
                               Text="PLAY ROUND"
                               TextColor="Black"
                               FontAttributes="Bold"
                               FontSize="{DynamicResource FontSizeCaption}"
                               HorizontalTextAlignment="Center"
                               MaxLines="2"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Border>

        <!-- Tab Content -->
        <Grid Grid.Row="1">

            <!-- Team Tab — mirrors CompanyViewerPage layout -->
            <Grid x:Name="TeamTabContent"
                  IsVisible="True"
                  Padding="5,8,5,0"
                  RowDefinitions="Auto,*"
                  RowSpacing="6">

                <!-- Unit selector (combo box) -->
                <Border Grid.Row="0"
                        x:Name="UnitPickerHeader"
                        BackgroundColor="#1F2937"
                        Stroke="#374151"
                        StrokeThickness="3"
                        Padding="8,6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUnitPickerTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="40,*,20" ColumnSpacing="8" VerticalOptions="Center">
                        <Grid Grid.Column="0" WidthRequest="36" HeightRequest="36" HorizontalOptions="Center" VerticalOptions="Center">
                            <skia:SKCanvasView x:Name="PickerHeaderLogoCanvas"
                                               PaintSurface="OnPickerHeaderLogoCanvasPaintSurface" />
                            <skia:SKCanvasView x:Name="PickerHeaderLtCanvas"
                                               WidthRequest="14" HeightRequest="14"
                                               HorizontalOptions="Start" VerticalOptions="Start"
                                               IsVisible="False"
                                               PaintSurface="OnPickerHeaderLtCanvasPaintSurface" />
                        </Grid>
                        <Label x:Name="PickerHeaderNameLabel"
                               Grid.Column="1"
                               Text="Select unit..."
                               TextColor="White"
                               FontSize="{DynamicResource FontSizeBody}"
                               VerticalTextAlignment="Center"
                               LineBreakMode="TailTruncation" />
                        <Label Grid.Column="2"
                               Text="▼"
                               TextColor="#9CA3AF"
                               FontSize="{DynamicResource FontSizeCaption}"
                               VerticalTextAlignment="Center"
                               HorizontalTextAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Selected unit details -->
                <Border Grid.Row="1" StrokeThickness="0" Padding="0,4,0,0">
                    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">

                        <!-- Name / type heading -->
                        <VerticalStackLayout Grid.Row="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Source={x:Reference SeasonRoot}, Path=SelectedCaptainNameHeading}"
                                   FontSize="{DynamicResource FontSizeTitleSmall}"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0"
                                       Text="{Binding Source={x:Reference SeasonRoot}, Path=SelectedProfileBaseNameHeading}"
                                       FontSize="{DynamicResource FontSizeBody}"
                                       TextColor="#9CA3AF"
                                       HorizontalOptions="Start"
                                       IsVisible="{Binding Source={x:Reference SeasonRoot}, Path=HasSelectedProfileBaseNameHeading}" />
                                <Label Grid.Column="1"
                                       Text="{Binding Source={x:Reference SeasonRoot}, Path=SelectedUnitTypeHeading}"
                                       FontSize="{DynamicResource FontSizeBody}"
                                       TextColor="#9CA3AF"
                                       HorizontalOptions="End"
                                       IsVisible="{Binding Source={x:Reference SeasonRoot}, Path=HasSelectedUnitTypeHeading}" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Stats block -->
                        <controls:UnitDisplayConfigurationsView
                            Grid.Row="1"
                            x:Name="TeamUnitDisplayView"
                            UnitNameHeading="{Binding UnitNameHeading}"
                            ShowRegularOrderIcon="{Binding ShowRegularOrderIcon}"
                            ShowIrregularOrderIcon="{Binding ShowIrregularOrderIcon}"
                            ShowImpetuousIcon="{Binding ShowImpetuousIcon}"
                            ShowTacticalAwarenessIcon="{Binding ShowTacticalAwarenessIcon}"
                            ShowCubeIcon="{Binding ShowCubeIcon}"
                            ShowCube2Icon="{Binding ShowCube2Icon}"
                            ShowHackableIcon="{Binding ShowHackableIcon}"
                            UnitMov="{Binding UnitMov}"
                            UnitCc="{Binding UnitCc}"
                            UnitBs="{Binding UnitBs}"
                            UnitPh="{Binding UnitPh}"
                            UnitWip="{Binding UnitWip}"
                            UnitArm="{Binding UnitArm}"
                            UnitBts="{Binding UnitBts}"
                            UnitVitalityHeader="{Binding UnitVitalityHeader}"
                            UnitVitality="{Binding UnitVitality}"
                            UnitS="{Binding UnitS}"
                            UnitAva="{Binding UnitAva}"
                            ShowConfigurationsSection="False"
                            ShowUnitName="False"
                            ShowAva="False"
                            ShowSummaryRows="False"
                            EquipmentSummaryFormatted="{Binding EquipmentSummaryFormatted}"
                            SpecialSkillsSummaryFormatted="{Binding SpecialSkillsSummaryFormatted}" />

                        <!-- Sections: Equipment, Skills, Perks, Weapons, CC Weapons, Gear Slots -->
                        <ScrollView Grid.Row="2">
                            <VerticalStackLayout Spacing="14" Padding="0,2,0,24">

                                <!-- Equipment -->
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="EQUIPMENT" FontSize="{DynamicResource FontSizeSectionHeader}" FontAttributes="Bold" TextColor="White" />
                                    <BoxView HeightRequest="1" Color="#374151" Margin="0,1,0,3" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" x:Name="EquipmentLeftColumn" Spacing="3" />
                                        <VerticalStackLayout Grid.Column="1" x:Name="EquipmentRightColumn" Spacing="3" />
                                    </Grid>
                                </VerticalStackLayout>

                                <!-- Special Skills -->
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="SPECIAL SKILLS" FontSize="{DynamicResource FontSizeSectionHeader}" FontAttributes="Bold" TextColor="White" />
                                    <BoxView HeightRequest="1" Color="#374151" Margin="0,1,0,3" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" x:Name="SkillsLeftColumn" Spacing="3" />
                                        <VerticalStackLayout Grid.Column="1" x:Name="SkillsRightColumn" Spacing="3" />
                                    </Grid>
                                </VerticalStackLayout>

                                <!-- Perks -->
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="PERKS" FontSize="{DynamicResource FontSizeSectionHeader}" FontAttributes="Bold" TextColor="White" />
                                    <BoxView HeightRequest="1" Color="#374151" Margin="0,1,0,3" />
                                    <Label Text="(coming soon)" TextColor="#fe34de" FontSize="{DynamicResource FontSizeBody}" />
                                </VerticalStackLayout>

                                <!-- Weapons -->
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="WEAPONS" FontSize="{DynamicResource FontSizeSectionHeader}" FontAttributes="Bold" TextColor="White" />
                                    <BoxView HeightRequest="1" Color="#374151" Margin="0,1,0,3" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" x:Name="WeaponsLeftColumn" Spacing="3" />
                                        <VerticalStackLayout Grid.Column="1" x:Name="WeaponsRightColumn" Spacing="3" />
                                    </Grid>
                                </VerticalStackLayout>

                                <!-- CC Weapons -->
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="CC WEAPONS" FontSize="{DynamicResource FontSizeSectionHeader}" FontAttributes="Bold" TextColor="White" />
                                    <BoxView HeightRequest="1" Color="#374151" Margin="0,1,0,3" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" x:Name="CcWeaponsLeftColumn" Spacing="3" />
                                        <VerticalStackLayout Grid.Column="1" x:Name="CcWeaponsRightColumn" Spacing="3" />
                                    </Grid>
                                </VerticalStackLayout>

                                <!-- Gear Slots -->
                                <VerticalStackLayout Spacing="6">

                                    <Label Text="PRIMARY" TextColor="#9CA3AF" FontSize="{DynamicResource FontSizeBody}" FontAttributes="Bold" />
                                    <Picker x:Name="PrimaryGearPicker"
                                            TextColor="White"
                                            BackgroundColor="#1F2937"
                                            TitleColor="#9CA3AF"
                                            SelectedIndexChanged="OnPrimaryGearPickerChanged" />

                                    <Label Text="SECONDARY" TextColor="#9CA3AF" FontSize="{DynamicResource FontSizeBody}" FontAttributes="Bold" />
                                    <Picker x:Name="SecondaryGearPicker"
                                            TextColor="White"
                                            BackgroundColor="#1F2937"
                                            TitleColor="#9CA3AF"
                                            SelectedIndexChanged="OnSecondaryGearPickerChanged" />

                                    <Label Text="SIDEARM" TextColor="#9CA3AF" FontSize="{DynamicResource FontSizeBody}" FontAttributes="Bold" />
                                    <Picker x:Name="SidearmGearPicker"
                                            TextColor="White"
                                            BackgroundColor="#1F2937"
                                            TitleColor="#9CA3AF"
                                            SelectedIndexChanged="OnSidearmGearPickerChanged" />

                                    <Label Text="ACCESSORIES" TextColor="#9CA3AF" FontSize="{DynamicResource FontSizeBody}" FontAttributes="Bold" />
                                    <Picker x:Name="AccessoriesGearPicker"
                                            TextColor="White"
                                            BackgroundColor="#1F2937"
                                            TitleColor="#9CA3AF"
                                            SelectedIndexChanged="OnAccessoriesGearPickerChanged" />

                                    <Label Text="ROLES" TextColor="#9CA3AF" FontSize="{DynamicResource FontSizeBody}" FontAttributes="Bold" />
                                    <Picker x:Name="RolesGearPicker"
                                            TextColor="White"
                                            BackgroundColor="#1F2937"
                                            TitleColor="#9CA3AF"
                                            SelectedIndexChanged="OnRolesGearPickerChanged" />

                                    <Label Text="ARMOR" TextColor="#9CA3AF" FontSize="{DynamicResource FontSizeBody}" FontAttributes="Bold" />
                                    <Picker x:Name="ArmorGearPicker"
                                            TextColor="White"
                                            BackgroundColor="#1F2937"
                                            TitleColor="#9CA3AF"
                                            SelectedIndexChanged="OnArmorGearPickerChanged" />

                                    <Label Text="AUGMENTS" TextColor="#9CA3AF" FontSize="{DynamicResource FontSizeBody}" FontAttributes="Bold" />
                                    <Picker x:Name="AugmentsGearPicker"
                                            TextColor="White"
                                            BackgroundColor="#1F2937"
                                            TitleColor="#9CA3AF"
                                            SelectedIndexChanged="OnAugmentsGearPickerChanged" />

                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </ScrollView>

                    </Grid>
                </Border>

                <!-- Unit picker dropdown list -->
                <Border Grid.Row="1"
                        x:Name="UnitPickerDropdown"
                        IsVisible="False"
                        ZIndex="50"
                        VerticalOptions="Start"
                        BackgroundColor="#1F2937"
                        Stroke="#374151"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>
                    <ScrollView MaximumHeightRequest="320">
                        <VerticalStackLayout x:Name="UnitPickerDropdownStack" Spacing="0" />
                    </ScrollView>
                </Border>

                <!-- Tap-outside-to-dismiss backdrop -->
                <Grid Grid.Row="1"
                      x:Name="UnitPickerDismissOverlay"
                      IsVisible="False"
                      ZIndex="49"
                      BackgroundColor="Transparent"
                      InputTransparent="False">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUnitPickerDismissTapped" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Grid>

            <!-- Inventory Tab -->
            <Grid x:Name="InventoryTabContent" IsVisible="False">
                <Label Text="Inventory — coming soon."
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="#6B7280"
                       IsVisible="False" />
                <ScrollView>
                    <VerticalStackLayout x:Name="InventoryContentArea" Padding="16,12" Spacing="0" />
                </ScrollView>
            </Grid>

            <!-- Marketplace Tab -->
            <Grid x:Name="MarketplaceTabContent" IsVisible="False" RowDefinitions="Auto,*">
                <!-- Store selector dropdown -->
                <Border Grid.Row="0"
                        BackgroundColor="#1F2937"
                        StrokeThickness="0"
                        Padding="12,6">
                    <VerticalStackLayout Spacing="0">
                        <Picker x:Name="StoreSelectorPicker"
                                Title="Select store..."
                                TextColor="White"
                                TitleColor="#9CA3AF"
                                BackgroundColor="#374151"
                                SelectedIndexChanged="OnStoreSelectorPickerChanged" />
                        <BoxView HeightRequest="1" Color="#374151" Margin="0,6,0,0" />
                    </VerticalStackLayout>
                </Border>
                <!-- Store content -->
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout x:Name="StoreContentArea" Padding="16,12" Spacing="0" />
                </ScrollView>
            </Grid>

        </Grid>

        <!-- Marketplace item popup overlay — covers full page -->
        <Grid x:Name="MarketplacePopupOverlay"
              Grid.Row="0" Grid.RowSpan="3"
              IsVisible="False"
              BackgroundColor="#D0111827">
            <Border BackgroundColor="#1F2937"
                    Stroke="#374151"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Margin="16,60,16,24">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="Auto,*"
                          BackgroundColor="#374151"
                          Padding="4,4">
                        <Button x:Name="PopupBackButton"
                                Grid.Column="0"
                                Text="← Back"
                                BackgroundColor="Transparent"
                                BorderColor="Transparent"
                                TextColor="#22C55E"
                                FontAttributes="Bold"
                                Padding="8,0"
                                Clicked="OnPopupBackClicked" />
                        <Label x:Name="PopupTitleLabel"
                               Grid.Column="1"
                               FontSize="{DynamicResource FontSizeBody}"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalTextAlignment="Center"
                               Padding="4,0,8,0"
                               LineBreakMode="TailTruncation" />
                    </Grid>
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout x:Name="PopupContentArea"
                                             Padding="16,12"
                                             Spacing="6" />
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>

        <!-- Store-finding popup overlay -->
        <Grid x:Name="StoreSearchOverlay"
              Grid.Row="0" Grid.RowSpan="3"
              IsVisible="False"
              BackgroundColor="#D0111827">
            <Border BackgroundColor="#1F2937"
                    Stroke="#374151"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Margin="16,60,16,24"
                    VerticalOptions="Start">
                <VerticalStackLayout Padding="16,14,16,14" Spacing="14">
                    <Label Text="Finding store near you..."
                           FontAttributes="Bold"
                           FontSize="18"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />

                    <Border BackgroundColor="#111827" Stroke="#374151" StrokeThickness="1"
                            StrokeShape="RoundRectangle 6" Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="ROLL FOR IT"
                                   TextColor="#9CA3AF"
                                   FontAttributes="Bold"
                                   FontSize="12" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label x:Name="StoreRollResultLabel"
                                       Grid.Column="0"
                                       Text="—"
                                       TextColor="White"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       VerticalTextAlignment="Center" />
                                <Button x:Name="StoreRollButton"
                                        Grid.Column="1"
                                        Text="ROLL"
                                        BackgroundColor="#374151"
                                        TextColor="#22C55E"
                                        FontAttributes="Bold"
                                        CornerRadius="6"
                                        Padding="14,0"
                                        HeightRequest="38"
                                        Clicked="OnStoreRollClicked" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#111827" Stroke="#374151" StrokeThickness="1"
                            StrokeShape="RoundRectangle 6" Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="OR PICK A ROLL"
                                   TextColor="#9CA3AF"
                                   FontAttributes="Bold"
                                   FontSize="12" />
                            <Picker x:Name="StoreRollPicker"
                                    Title="Select 1-20..."
                                    TextColor="White"
                                    TitleColor="#9CA3AF"
                                    BackgroundColor="#374151"
                                    SelectedIndexChanged="OnStoreRollPickerChanged" />
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout x:Name="StoreChooseArea" IsVisible="False" Spacing="8">
                        <Border BackgroundColor="#111827" Stroke="#F59E0B" StrokeThickness="1"
                                StrokeShape="RoundRectangle 6" Padding="12">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="CHOOSE ANY STORE (19-20)"
                                       TextColor="#F59E0B"
                                       FontAttributes="Bold"
                                       FontSize="12" />
                                <Picker x:Name="StoreChoicePicker"
                                        Title="Select a store..."
                                        TextColor="White"
                                        TitleColor="#9CA3AF"
                                        BackgroundColor="#374151"
                                        SelectedIndexChanged="OnStoreChoicePickerChanged" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <Button x:Name="StoreSearchConfirmButton"
                            Text="CONFIRM"
                            BackgroundColor="#22C55E"
                            TextColor="Black"
                            FontAttributes="Bold"
                            HeightRequest="44"
                            CornerRadius="6"
                            IsEnabled="False"
                            Opacity="0.45"
                            Clicked="OnStoreSearchConfirmClicked" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Bottom Tab Bar -->
        <Border Grid.Row="2"
                BackgroundColor="#1F2937"
                Stroke="#374151"
                StrokeThickness="1"
                Padding="0"
                StrokeShape="Rectangle">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="0">
                <Button x:Name="TeamTabButton"
                        Grid.Column="0"
                        Text="TEAM"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        BorderWidth="0"
                        FontAttributes="Bold"
                        TextColor="#22C55E"
                        Clicked="OnTeamTabClicked" />
                <Button x:Name="InventoryTabButton"
                        Grid.Column="1"
                        Text="INVENTORY"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        BorderWidth="0"
                        TextColor="#6B7280"
                        Clicked="OnInventoryTabClicked" />
                <Button x:Name="MarketplaceTabButton"
                        Grid.Column="2"
                        Text="MARKETS"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        BorderWidth="0"
                        TextColor="#6B7280"
                        Clicked="OnMarketplaceTabClicked" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>
