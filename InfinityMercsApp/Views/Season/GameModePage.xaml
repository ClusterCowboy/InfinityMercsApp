<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Season.GameModePage"
             Title="Contract"
             BackgroundColor="#111827">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- Header -->
        <Border Grid.Row="0"
                BackgroundColor="#1F2937"
                Stroke="#374151"
                StrokeThickness="1"
                Padding="16,12"
                StrokeShape="Rectangle">
            <Label Text="CONTRACT IN PROGRESS"
                   FontSize="{DynamicResource FontSizeSubHeadline}"
                   FontAttributes="Bold"
                   TextColor="#22C55E"
                   HorizontalTextAlignment="Center" />
        </Border>

        <!-- Body -->
        <VerticalStackLayout Grid.Row="1"
                             Spacing="{DynamicResource SpacingXL}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Padding="24,0">
            <Label Text="GAME ON"
                   FontSize="{DynamicResource FontSizeHeadline}"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <Label Text="Manage your contract. When finished, end the game to record results."
                   FontSize="{DynamicResource FontSizeBody}"
                   TextColor="#9CA3AF"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>

        <!-- End Game button -->
        <Button Grid.Row="2"
                Text="END GAME"
                BackgroundColor="#DC2626"
                TextColor="White"
                BorderColor="#DC2626"
                FontAttributes="Bold"
                HorizontalOptions="Fill"
                Margin="16,8,16,16"
                Clicked="OnEndGameClicked" />

    </Grid>

</ContentPage>
