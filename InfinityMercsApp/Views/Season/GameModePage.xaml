<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Season.GameModePage"
             Title="CONTRACT IN PROGRESS"
             BackgroundColor="#111827">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="0">

        <!-- Round header band -->
        <Border Grid.Row="0"
                BackgroundColor="#1F2937"
                Stroke="#374151"
                StrokeThickness="1"
                Padding="16,10"
                StrokeShape="Rectangle">
            <Label x:Name="RoundLabel"
                   Text="Round 1"
                   FontSize="{DynamicResource FontSizeSubHeadline}"
                   FontAttributes="Bold"
                   TextColor="#22C55E"
                   HorizontalTextAlignment="Center" />
        </Border>

        <!-- Color order icon row with counts (tap to mark as used) -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Padding="8,12,8,4">
            <HorizontalStackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLtColorTapped" />
                </HorizontalStackLayout.GestureRecognizers>
                <skia:SKCanvasView x:Name="LtColorCanvas"  WidthRequest="44" HeightRequest="44" VerticalOptions="Center" PaintSurface="OnLtColorPaint" />
                <Label x:Name="LtCountLabel"  Text="0" TextColor="#FBBF24" FontAttributes="Bold" FontSize="{DynamicResource FontSizeSubHeadline}" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnImpColorTapped" />
                </HorizontalStackLayout.GestureRecognizers>
                <skia:SKCanvasView x:Name="ImpColorCanvas" WidthRequest="44" HeightRequest="44" VerticalOptions="Center" PaintSurface="OnImpColorPaint" />
                <Label x:Name="ImpCountLabel" Text="0" TextColor="#F97316" FontAttributes="Bold" FontSize="{DynamicResource FontSizeSubHeadline}" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnIrrColorTapped" />
                </HorizontalStackLayout.GestureRecognizers>
                <skia:SKCanvasView x:Name="IrrColorCanvas" WidthRequest="44" HeightRequest="44" VerticalOptions="Center" PaintSurface="OnIrrColorPaint" />
                <Label x:Name="IrrCountLabel" Text="0" TextColor="#F59E0B" FontAttributes="Bold" FontSize="{DynamicResource FontSizeSubHeadline}" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRegColorTapped" />
                </HorizontalStackLayout.GestureRecognizers>
                <skia:SKCanvasView x:Name="RegColorCanvas" WidthRequest="44" HeightRequest="44" VerticalOptions="Center" PaintSurface="OnRegColorPaint" />
                <Label x:Name="RegCountLabel" Text="0" TextColor="#22C55E" FontAttributes="Bold" FontSize="{DynamicResource FontSizeSubHeadline}" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Greyscale order icon row with counts (tap to restore) -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*" Padding="8,4,8,8">
            <HorizontalStackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLtGreyTapped" />
                </HorizontalStackLayout.GestureRecognizers>
                <skia:SKCanvasView x:Name="LtGreyCanvas"  WidthRequest="44" HeightRequest="44" VerticalOptions="Center" PaintSurface="OnLtGreyPaint" />
                <Label x:Name="LtGreyCountLabel"  Text="0" TextColor="#9CA3AF" FontAttributes="Bold" FontSize="{DynamicResource FontSizeSubHeadline}" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnImpGreyTapped" />
                </HorizontalStackLayout.GestureRecognizers>
                <skia:SKCanvasView x:Name="ImpGreyCanvas" WidthRequest="44" HeightRequest="44" VerticalOptions="Center" PaintSurface="OnImpGreyPaint" />
                <Label x:Name="ImpGreyCountLabel" Text="0" TextColor="#9CA3AF" FontAttributes="Bold" FontSize="{DynamicResource FontSizeSubHeadline}" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnIrrGreyTapped" />
                </HorizontalStackLayout.GestureRecognizers>
                <skia:SKCanvasView x:Name="IrrGreyCanvas" WidthRequest="44" HeightRequest="44" VerticalOptions="Center" PaintSurface="OnIrrGreyPaint" />
                <Label x:Name="IrrGreyCountLabel" Text="0" TextColor="#9CA3AF" FontAttributes="Bold" FontSize="{DynamicResource FontSizeSubHeadline}" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRegGreyTapped" />
                </HorizontalStackLayout.GestureRecognizers>
                <skia:SKCanvasView x:Name="RegGreyCanvas" WidthRequest="44" HeightRequest="44" VerticalOptions="Center" PaintSurface="OnRegGreyPaint" />
                <Label x:Name="RegGreyCountLabel" Text="0" TextColor="#9CA3AF" FontAttributes="Bold" FontSize="{DynamicResource FontSizeSubHeadline}" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Unit accordion -->
        <ScrollView Grid.Row="3">
            <VerticalStackLayout x:Name="AccordionStack" Spacing="0" Padding="0,8,0,0" />
        </ScrollView>

        <!-- End Game button -->
        <Button Grid.Row="4"
                Text="END GAME"
                BackgroundColor="#DC2626"
                TextColor="White"
                BorderColor="#DC2626"
                FontAttributes="Bold"
                HorizontalOptions="Fill"
                Margin="16,8,16,16"
                Clicked="OnEndGameClicked" />

    </Grid>

</ContentPage>
