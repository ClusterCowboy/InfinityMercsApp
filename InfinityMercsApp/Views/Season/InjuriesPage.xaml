<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Season.InjuriesPage"
             Title="INJURIES"
             BackgroundColor="{StaticResource Void}">

    <Grid RowDefinitions="*,Auto" Padding="0">

        <ScrollView Grid.Row="0"
                    Orientation="Vertical"
                    VerticalScrollBarVisibility="Always">
            <VerticalStackLayout x:Name="InjuryStack" Spacing="0" Padding="0,8,0,16" />
        </ScrollView>

        <Button x:Name="ContinueButton"
                Grid.Row="1"
                Text="CONTINUE"
                BackgroundColor="{StaticResource Signal}"
                TextColor="{StaticResource TextPrimary}"
                FontAttributes="Bold"
                FontSize="{DynamicResource FontSizeSectionHeader}"
                HeightRequest="52"
                CornerRadius="0"
                Margin="0"
                IsEnabled="False"
                Opacity="0.45"
                Clicked="OnContinueClicked" />

    </Grid>

</ContentPage>
