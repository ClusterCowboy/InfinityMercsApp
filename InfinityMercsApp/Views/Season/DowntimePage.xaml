<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Season.DowntimePage"
             Title="Downtime"
             BackgroundColor="#111827">

    <Grid RowDefinitions="*,Auto" Padding="16">

        <!-- Stub content -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="{DynamicResource SpacingXL}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">
            <Label Text="DOWNTIME"
                   FontSize="{DynamicResource FontSizeHeadline}"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <Label Text="Spend resources, make repairs, and prepare for the next round."
                   FontSize="{DynamicResource FontSizeBody}"
                   TextColor="#6B7280"
                   HorizontalTextAlignment="Center" />
            <Border BackgroundColor="#1F2937"
                    Stroke="#374151"
                    StrokeThickness="1"
                    Padding="{DynamicResource PaddingSection}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{DynamicResource CornerRadiusDefault}" />
                </Border.StrokeShape>
                <Label Text="Downtime events — coming soon."
                       FontSize="{DynamicResource FontSizeBody}"
                       TextColor="#6B7280"
                       HorizontalTextAlignment="Center" />
            </Border>
        </VerticalStackLayout>

        <!-- Back To Base button -->
        <Button Grid.Row="1"
                Text="BACK TO BASE"
                BackgroundColor="Transparent"
                TextColor="White"
                BorderColor="#22C55E"
                FontAttributes="Bold"
                Clicked="OnBackToBaseClicked"
                HorizontalOptions="Fill" />

    </Grid>
</ContentPage>
