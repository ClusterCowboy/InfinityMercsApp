<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Season.DowntimePage"
             Title="Downtime"
             BackgroundColor="#111827">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16,12,16,16">

        <Label Grid.Row="0"
               Text="DOWNTIME EVENT"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="White"
               Margin="0,0,0,12"/>

        <ScrollView Grid.Row="1" x:Name="EventScrollView">
            <VerticalStackLayout x:Name="EventStack" Spacing="12">
                <Label x:Name="EmptyLabel"
                       Text="Press Roll for a random event, or pick a number and press Real."
                       TextColor="#6B7280"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       Margin="0,40,0,0"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom controls: contextual prompt + Roll | Picker | Real, then Back to Base when resolved -->
        <VerticalStackLayout Grid.Row="2" Spacing="6" Margin="0,12,0,0">
            <Label x:Name="RollContextLabel"
                   Text="Press ROLL for a random event, or pick a value and press REAL."
                   TextColor="#9CA3AF"
                   FontSize="12"
                   HorizontalTextAlignment="Center"/>
            <Grid x:Name="RollBar" ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                <Button Grid.Column="0"
                        x:Name="RollButton"
                        Text="ROLL"
                        BackgroundColor="#22C55E"
                        TextColor="Black"
                        FontAttributes="Bold"
                        Clicked="OnRollClicked"/>
                <Picker Grid.Column="1"
                        x:Name="RealPicker"
                        Title="1-20"
                        WidthRequest="90"
                        TextColor="White"
                        BackgroundColor="#374151"/>
                <Button Grid.Column="2"
                        x:Name="RealButton"
                        Text="REAL"
                        BackgroundColor="Transparent"
                        BorderColor="#22C55E"
                        BorderWidth="1"
                        TextColor="White"
                        FontAttributes="Bold"
                        Clicked="OnRealClicked"/>
            </Grid>

            <Button x:Name="ContinueButton"
                    Text="BACK TO BASE"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    BorderColor="#22C55E"
                    BorderWidth="1"
                    FontAttributes="Bold"
                    IsVisible="False"
                    Clicked="OnBackToBaseClicked"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
