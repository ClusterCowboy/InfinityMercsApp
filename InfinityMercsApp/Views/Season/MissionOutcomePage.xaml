<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Season.MissionOutcomePage"
             Title="Mission Outcome"
             BackgroundColor="{StaticResource Void}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16,12,16,16">

        <Label Grid.Row="0"
               Text="MISSION OUTCOME"
               FontSize="{DynamicResource FontSizeTitleSmall}"
               FontAttributes="Bold"
               TextColor="{StaticResource TextPrimary}"
               Margin="0,0,0,12"/>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">

                <!-- Victory / Defeat selection -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Mission Result"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="{DynamicResource FontSizeBody}"
                           FontAttributes="Bold" />
                    <Grid ColumnSpacing="8" ColumnDefinitions="*,*">
                        <Button x:Name="VictoryButton"
                                Grid.Column="0"
                                Text="VICTORY"
                                BackgroundColor="{StaticResource HairlineBright}"
                                TextColor="{StaticResource Signal}"
                                FontAttributes="Bold"
                                FontSize="{DynamicResource FontSizeBody}"
                                HeightRequest="44"
                                CornerRadius="4"
                                Padding="0"
                                Clicked="OnVictoryClicked" />
                        <Button x:Name="DefeatButton"
                                Grid.Column="1"
                                Text="DEFEAT"
                                BackgroundColor="{StaticResource HairlineBright}"
                                TextColor="{StaticResource Danger}"
                                FontAttributes="Bold"
                                FontSize="{DynamicResource FontSizeBody}"
                                HeightRequest="44"
                                CornerRadius="4"
                                Padding="0"
                                Clicked="OnDefeatClicked" />
                    </Grid>
                </VerticalStackLayout>

                <!-- Points scored -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Points Scored"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="{DynamicResource FontSizeBody}"
                           FontAttributes="Bold" />
                    <Picker x:Name="PointsPicker"
                            Title="Select points (0-10)..."
                            TextColor="{StaticResource TextPrimary}"
                            TitleColor="{StaticResource TextMuted}"
                            BackgroundColor="{StaticResource HairlineBright}"
                            SelectedIndexChanged="OnPointsChanged" />
                </VerticalStackLayout>

                <!-- Outcome breakdown card -->
                <Border Stroke="Transparent"
                        BackgroundColor="{StaticResource Plate}"
                        StrokeShape="RoundRectangle 4"
                        Padding="14">
                    <VerticalStackLayout x:Name="BreakdownStack" Spacing="6" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="2"
                x:Name="ContinueButton"
                Text="GO TO EXPERIENCE"
                BackgroundColor="{StaticResource Signal}"
                TextColor="{StaticResource Void}"
                FontAttributes="Bold"
                Margin="0,12,0,0"
                IsEnabled="False"
                Opacity="0.45"
                Clicked="OnGoToExperienceClicked"
                HorizontalOptions="Fill" />
    </Grid>
</ContentPage>
