<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Season.LoadSeasonPage"
             Title="Load Season"
             BackgroundColor="{StaticResource Void}">

    <Grid Padding="16" RowDefinitions="Auto,*" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Text="Load Season"
                   FontSize="{DynamicResource FontSizeDisplay}"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalTextAlignment="Start" />
            <Label Text="All saved seasons are listed below."
                   FontSize="{DynamicResource FontSizeBody}"
                   TextColor="{StaticResource TextMuted}"
                   HorizontalTextAlignment="Start" />
        </VerticalStackLayout>

        <Grid Grid.Row="1">

            <CollectionView ItemsSource="{Binding SeasonRecords}"
                            SelectionMode="None"
                            IsVisible="{Binding HasSeasonRecords}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="1"
                                Stroke="{StaticResource Hairline}"
                                BackgroundColor="{StaticResource Plate}"
                                Padding="14,12"
                                Margin="0,0,0,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="{DynamicResource CornerRadiusDefault}" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLoadSeasonTapped" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding DisplayName}"
                                       FontSize="{DynamicResource FontSizeSubHeadline}"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Subtitle}"
                                       FontSize="{DynamicResource FontSizeCaption}"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border IsVisible="{Binding ShowEmptyState}"
                    BackgroundColor="{StaticResource Plate}"
                    Stroke="{StaticResource Hairline}"
                    StrokeThickness="1"
                    Padding="{DynamicResource PaddingSection}"
                    VerticalOptions="Center"
                    HorizontalOptions="Fill">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{DynamicResource CornerRadiusDefault}" />
                </Border.StrokeShape>
                <Label Text="No saved seasons yet. Start a new season to begin your campaign."
                       FontSize="{DynamicResource FontSizeBody}"
                       TextColor="{StaticResource TextMuted}"
                       HorizontalTextAlignment="Center" />
            </Border>

        </Grid>

    </Grid>

</ContentPage>
