<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Season.LoadSeasonPage"
             Title="Load Season"
             BackgroundColor="#111827">

    <Grid Padding="16">
        <VerticalStackLayout Spacing="{DynamicResource SpacingXL}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">
            <Label Text="LOAD SEASON"
                   FontSize="{DynamicResource FontSizeHeadline}"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <Border BackgroundColor="#1F2937"
                    Stroke="#374151"
                    StrokeThickness="1"
                    Padding="{DynamicResource PaddingSection}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{DynamicResource CornerRadiusDefault}" />
                </Border.StrokeShape>
                <Label Text="No saved seasons yet. Start a new season to begin your campaign."
                       FontSize="{DynamicResource FontSizeBody}"
                       TextColor="#6B7280"
                       HorizontalTextAlignment="Center" />
            </Border>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
