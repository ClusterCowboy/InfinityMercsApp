<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Season.ExperiencePage"
             Title="Experience"
             BackgroundColor="#111827">

    <Grid RowDefinitions="*,Auto" Padding="16">

        <!-- Stub content -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="{DynamicResource SpacingXL}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">
            <Label Text="EXPERIENCE"
                   FontSize="{DynamicResource FontSizeHeadline}"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <Label Text="Count experience gains for units that participated in the round."
                   FontSize="{DynamicResource FontSizeBody}"
                   TextColor="#6B7280"
                   HorizontalTextAlignment="Center" />
            <Border BackgroundColor="#1F2937"
                    Stroke="#374151"
                    StrokeThickness="1"
                    Padding="{DynamicResource PaddingSection}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{DynamicResource CornerRadiusDefault}" />
                </Border.StrokeShape>
                <Label Text="Per-unit experience entry — coming soon."
                       FontSize="{DynamicResource FontSizeBody}"
                       TextColor="#6B7280"
                       HorizontalTextAlignment="Center" />
            </Border>
        </VerticalStackLayout>

        <!-- Confirm button -->
        <Button Grid.Row="1"
                Text="CONFIRM EXPERIENCE GAINS"
                BackgroundColor="#22C55E"
                TextColor="Black"
                BorderColor="#22C55E"
                FontAttributes="Bold"
                Clicked="OnConfirmExperienceClicked"
                HorizontalOptions="Fill" />

    </Grid>
</ContentPage>
