<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Season.ExperiencePage"
             Title="Experience"
             BackgroundColor="#111827">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16,12,16,16">

        <Label Grid.Row="0"
               Text="EXPERIENCE"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="White"
               Margin="0,0,0,12"/>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="UnitStack" Spacing="10"/>
        </ScrollView>

        <Button Grid.Row="2"
                x:Name="ConfirmButton"
                Text="CONFIRM EXPERIENCE GAINS"
                BackgroundColor="#22C55E"
                TextColor="Black"
                FontAttributes="Bold"
                Margin="0,12,0,0"
                Clicked="OnConfirmExperienceClicked"
                HorizontalOptions="Fill" />
    </Grid>
</ContentPage>
