<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Season.PlayModePage"
             Title="Play Round"
             BackgroundColor="#111827">

    <Grid RowDefinitions="*,Auto" Padding="16">

        <!-- Stub content -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="{DynamicResource SpacingXL}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">
            <Label Text="PLAY MODE"
                   FontSize="{DynamicResource FontSizeHeadline}"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <Label Text="Select your deployment and manage the round."
                   FontSize="{DynamicResource FontSizeBody}"
                   TextColor="#6B7280"
                   HorizontalTextAlignment="Center" />
            <Border BackgroundColor="#1F2937"
                    Stroke="#374151"
                    StrokeThickness="1"
                    Padding="{DynamicResource PaddingSection}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{DynamicResource CornerRadiusDefault}" />
                </Border.StrokeShape>
                <Label Text="Deployment selection — coming soon."
                       FontSize="{DynamicResource FontSizeBody}"
                       TextColor="#6B7280"
                       HorizontalTextAlignment="Center" />
            </Border>
        </VerticalStackLayout>

        <!-- End Game button -->
        <Button Grid.Row="1"
                Text="END GAME"
                BackgroundColor="#DC2626"
                TextColor="White"
                BorderColor="#DC2626"
                FontAttributes="Bold"
                Clicked="OnEndGameClicked"
                HorizontalOptions="Fill" />

    </Grid>
</ContentPage>
