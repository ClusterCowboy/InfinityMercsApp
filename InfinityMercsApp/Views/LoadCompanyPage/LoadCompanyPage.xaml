<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.LoadCompanyPage"
             x:Name="LoadCompanyRoot"
             Title="Load Company">

    <Grid Padding="16" RowDefinitions="Auto,*" RowSpacing="12">
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label
                Text="Load Records"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalTextAlignment="Start" />
            <Label
                Text="All saved armies are listed below."
                HorizontalTextAlignment="Start" />
        </VerticalStackLayout>

        <Grid Grid.Row="1">
            <CollectionView
                ItemsSource="{Binding SavedRecords}"
                SelectionMode="None"
                IsVisible="{Binding HasSavedRecords}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="1" Padding="10" Margin="0,0,0,8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLoadRecordTapped" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                    <skia:SKCanvasView
                                        WidthRequest="50"
                                        HeightRequest="50"
                                        VerticalOptions="Center"
                                        HorizontalOptions="Center"
                                        BindingContextChanged="OnRecordIconBindingContextChanged"
                                        PaintSurface="OnCompanyIconPaintSurface" />
                                    <skia:SKCanvasView
                                        WidthRequest="50"
                                        HeightRequest="50"
                                        VerticalOptions="Center"
                                        HorizontalOptions="Center"
                                        BindingContextChanged="OnRecordIconBindingContextChanged"
                                        PaintSurface="OnFactionIconsPaintSurface" />
                                </HorizontalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label
                                        Text="{Binding DisplayName}"
                                        FontSize="18"
                                        FontAttributes="Bold" />
                                    <Label
                                        Text="{Binding Subtitle}"
                                        FontSize="12"
                                        TextColor="#9CA3AF" />
                                </VerticalStackLayout>

                                <Border
                                    Grid.Column="2"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"
                                    StrokeThickness="0"
                                    Padding="4">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDeleteRecordTapped" />
                                    </Border.GestureRecognizers>
                                    <skia:SKCanvasView
                                        WidthRequest="50"
                                        HeightRequest="50"
                                        VerticalOptions="Center"
                                        HorizontalOptions="Center"
                                        BindingContextChanged="OnRecordIconBindingContextChanged"
                                        PaintSurface="OnTrashIconPaintSurface" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label
                Text="No saved armies found."
                HorizontalTextAlignment="Center"
                VerticalTextAlignment="Center"
                IsVisible="{Binding ShowEmptyState}" />
        </Grid>
    </Grid>

</ContentPage>
