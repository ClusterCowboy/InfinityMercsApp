<?xml version="1.0" encoding="utf-8" ?>
<layout:AdaptiveContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:layout="clr-namespace:InfinityMercsApp.Views.Adaptive"
    x:Class="InfinityMercsApp.Views.ModeSelectionPage"
    x:Name="ModeSelectionRoot"
    Title="Home">

    <Grid x:Name="RootGrid" Padding="24" RowDefinitions="Auto,Auto,Auto,*" HorizontalOptions="Fill">
        <Image
            x:Name="HeaderImage"
            Grid.Row="0"
            HeightRequest="220"
            HorizontalOptions="Center"
            WidthRequest="420"
            Source="m2_no_bg_short.webp" />

        <Label
            Grid.Row="1"
            Text="MERCENARIES"
            FontSize="{DynamicResource FontSizeDisplay}"
            HorizontalTextAlignment="Center" />

        <Label
            Grid.Row="2"
            Text="Dirty fights in the world of Infinity: The Game"
            FontSize="{DynamicResource FontSizeTitleSmall}"
            HorizontalTextAlignment="Center" />

        <Grid x:Name="ButtonBar"
              Grid.Row="3"
              VerticalOptions="Center"
              HorizontalOptions="Center"
              ColumnSpacing="12"
              RowSpacing="12">
            <Button
                x:Name="NewCompanyButton"
                Text="New Company"
                WidthRequest="170"
                Command="{Binding NavigateToCreateNewCompanyCommand}" />

            <Button
                x:Name="LoadCompanyButton"
                Text="Load Company"
                WidthRequest="170"
                Command="{Binding NavigateToLoadArmyCommand}" />
        </Grid>
    </Grid>

</layout:AdaptiveContentPage>
