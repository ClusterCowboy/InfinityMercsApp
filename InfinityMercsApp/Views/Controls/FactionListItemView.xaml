<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Controls.FactionListItemView">

    <Border x:Name="ItemBorder" Padding="0" StrokeThickness="0">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnItemTapped" />
        </Border.GestureRecognizers>
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="6" />
        </Border.StrokeShape>
        <Border.Triggers>
            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                <Setter Property="BackgroundColor" Value="#334155" />
            </DataTrigger>
            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                <Setter Property="BackgroundColor" Value="Transparent" />
            </DataTrigger>
        </Border.Triggers>

        <Grid
            Padding="8,6"
            MinimumHeightRequest="50"
            ColumnDefinitions="Auto,*,Auto,Auto,Auto"
            ColumnSpacing="10"
            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=IsHorizontalLayout}">
            <skia:SKCanvasView
                x:Name="LogoCanvas"
                WidthRequest="32"
                HeightRequest="32"
                VerticalOptions="Center"
                PaintSurface="OnLogoCanvasPaintSurface" />
            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                <Label Text="{Binding Name}" FormattedText="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=TitleFormatted}" />
                <Label
                    Text="{Binding Subtitle}"
                    FontSize="12"
                    TextColor="#6B7280"
                    IsVisible="{Binding HasSubtitle}" />
            </VerticalStackLayout>
            <skia:SKCanvasView
                Grid.Column="2"
                x:Name="RightIconPrimaryCanvas"
                WidthRequest="24"
                HeightRequest="24"
                VerticalOptions="Center"
                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=ShowRightPrimaryIconSlot}"
                PaintSurface="OnRightIconPrimaryCanvasPaintSurface" />
            <skia:SKCanvasView
                Grid.Column="3"
                x:Name="RightIconSecondaryCanvas"
                WidthRequest="24"
                HeightRequest="24"
                VerticalOptions="Center"
                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=ShowRightSecondaryIconSlot}"
                PaintSurface="OnRightIconSecondaryCanvasPaintSurface" />
            <Label
                Grid.Column="4"
                Text="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=TrailingText}"
                FontAttributes="Bold"
                VerticalOptions="Start"
                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=HasTrailingText}" />
        </Grid>

        <Grid
            Padding="8,6"
            MinimumHeightRequest="88"
            RowDefinitions="Auto,Auto"
            RowSpacing="6"
            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=UseVerticalTileLayout}">
            <skia:SKCanvasView
                x:Name="LogoCanvasVertical"
                Grid.Row="0"
                WidthRequest="48"
                HeightRequest="48"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                PaintSurface="OnLogoCanvasVerticalPaintSurface" />
            <Label
                Grid.Row="1"
                Text="{Binding Name}"
                FormattedText="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=TitleFormatted}"
                FontSize="14"
                LineBreakMode="WordWrap"
                MaxLines="3"
                HorizontalTextAlignment="Center"
                HorizontalOptions="Fill" />
        </Grid>
    </Border>

</ContentView>
