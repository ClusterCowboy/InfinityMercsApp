<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Controls.FactionListItemView"
             x:Name="FactionListItemRoot">

    <Border x:Name="ItemBorder" Padding="0" StrokeThickness="0">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnItemTapped" />
        </Border.GestureRecognizers>
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="6" />
        </Border.StrokeShape>
        <Border.Triggers>
            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                <Setter Property="BackgroundColor" Value="#334155" />
            </DataTrigger>
            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                <Setter Property="BackgroundColor" Value="Transparent" />
            </DataTrigger>
        </Border.Triggers>

        <Grid
            x:Name="HorizontalLayoutRoot"
            Padding="8,6"
            MinimumHeightRequest="50"
            ColumnDefinitions="Auto,*,Auto,Auto,Auto"
            ColumnSpacing="10">
            <skia:SKCanvasView
                x:Name="LogoCanvas"
                WidthRequest="32"
                HeightRequest="32"
                VerticalOptions="Center"
                PaintSurface="OnLogoCanvasPaintSurface" />
            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                <Grid>
                    <Label
                        x:Name="HorizontalNameLabel"
                        Text="{Binding Name}"
                        TextColor="White" />
                    <Label
                        x:Name="HorizontalFormattedNameLabel"
                        FormattedText="{Binding Source={x:Reference FactionListItemRoot}, Path=TitleFormatted}"
                        TextColor="White"
                        IsVisible="False" />
                </Grid>
                <Label
                    Text="{Binding Subtitle}"
                    FontSize="12"
                    TextColor="#6B7280"
                    IsVisible="{Binding HasSubtitle}" />
            </VerticalStackLayout>
            <skia:SKCanvasView
                Grid.Column="2"
                x:Name="RightIconPrimaryCanvas"
                WidthRequest="24"
                HeightRequest="24"
                VerticalOptions="Center"
                IsVisible="{Binding Source={x:Reference FactionListItemRoot}, Path=ShowRightPrimaryIconSlot}"
                PaintSurface="OnRightIconPrimaryCanvasPaintSurface" />
            <skia:SKCanvasView
                Grid.Column="3"
                x:Name="RightIconSecondaryCanvas"
                WidthRequest="24"
                HeightRequest="24"
                VerticalOptions="Center"
                IsVisible="{Binding Source={x:Reference FactionListItemRoot}, Path=ShowRightSecondaryIconSlot}"
                PaintSurface="OnRightIconSecondaryCanvasPaintSurface" />
            <Label
                Grid.Column="4"
                Text="{Binding Source={x:Reference FactionListItemRoot}, Path=TrailingText}"
                FontAttributes="Bold"
                TextColor="White"
                VerticalOptions="Start"
                IsVisible="{Binding Source={x:Reference FactionListItemRoot}, Path=HasTrailingText}" />
        </Grid>

        <Grid
            x:Name="VerticalLayoutRoot"
            Padding="8,6"
            MinimumHeightRequest="88"
            RowDefinitions="Auto,Auto"
            RowSpacing="6"
            IsVisible="False">
            <skia:SKCanvasView
                x:Name="LogoCanvasVertical"
                Grid.Row="0"
                WidthRequest="48"
                HeightRequest="48"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                PaintSurface="OnLogoCanvasVerticalPaintSurface" />
            <Grid Grid.Row="1">
                <Label
                    x:Name="VerticalNameLabel"
                    Text="{Binding Name}"
                    FontSize="14"
                    TextColor="White"
                    LineBreakMode="WordWrap"
                    MaxLines="3"
                    HorizontalTextAlignment="Center"
                    HorizontalOptions="Fill" />
                <Label
                    x:Name="VerticalFormattedNameLabel"
                    FormattedText="{Binding Source={x:Reference FactionListItemRoot}, Path=TitleFormatted}"
                    FontSize="14"
                    TextColor="White"
                    LineBreakMode="WordWrap"
                    MaxLines="3"
                    HorizontalTextAlignment="Center"
                    HorizontalOptions="Fill"
                    IsVisible="False" />
            </Grid>
        </Grid>
    </Border>

</ContentView>
