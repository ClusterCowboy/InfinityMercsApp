<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             x:Class="InfinityMercsApp.Views.Controls.MercsCompanyEntriesListView"
             x:Name="MercsEntriesListRoot">

    <CollectionView
        x:Name="EntriesCollection"
        ItemsSource="{Binding Source={x:Reference MercsEntriesListRoot}, Path=ItemsSource}"
        SelectionMode="None"
        VerticalOptions="FillAndExpand">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <controls:MercsCompanyEntryCardView
                    SelectEntryCommand="{Binding Source={x:Reference MercsEntriesListRoot}, Path=SelectEntryCommand}"
                    RemoveEntryCommand="{Binding Source={x:Reference MercsEntriesListRoot}, Path=RemoveEntryCommand}"
                    ShowOrderModifierBadges="{Binding Source={x:Reference MercsEntriesListRoot}, Path=ShowOrderModifierBadges}"
                    PeripheralIconCanvasPaintSurface="OnPeripheralIconCanvasPaintSurface"
                    IrregularIconCanvasPaintSurface="OnIrregularIconCanvasPaintSurface"
                    RegularModifierIconCanvasPaintSurface="OnRegularModifierIconCanvasPaintSurface" />
            </DataTemplate>
        </CollectionView.ItemTemplate>
        <CollectionView.EmptyView>
            <Label
                Text="{Binding Source={x:Reference MercsEntriesListRoot}, Path=EmptyText}"
                TextColor="#6B7280" />
        </CollectionView.EmptyView>
    </CollectionView>

</ContentView>
