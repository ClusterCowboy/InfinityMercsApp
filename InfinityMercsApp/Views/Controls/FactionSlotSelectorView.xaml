<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Controls.FactionSlotSelectorView"
             x:Name="FactionSlotSelectorRoot"
             Margin="30,0,0,0"
             HorizontalOptions="FillAndExpand">
    <Grid ColumnDefinitions="*,*" ColumnSpacing="0" VerticalOptions="Center" HorizontalOptions="FillAndExpand">
        <Border StrokeThickness="2"
                Stroke="{Binding Source={x:Reference FactionSlotSelectorRoot}, Path=LeftSlotBorderColor}"
                Padding="8,4"
                Margin="15,0"
                Grid.Column="0"
                HorizontalOptions="FillAndExpand">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnLeftSlotTapped" />
            </Border.GestureRecognizers>
            <Grid HorizontalOptions="Center">
                <skia:SKCanvasView
                    x:Name="LeftSlotCanvas"
                    WidthRequest="28"
                    HeightRequest="28"
                    VerticalOptions="Center"
                    PaintSurface="OnLeftSlotCanvasPaintSurface" />
            </Grid>
        </Border>
        <Border StrokeThickness="2"
                Stroke="{Binding Source={x:Reference FactionSlotSelectorRoot}, Path=RightSlotBorderColor}"
                Padding="8,4"
                Margin="15,0"
                Grid.Column="1"
                HorizontalOptions="FillAndExpand"
                IsVisible="{Binding Source={x:Reference FactionSlotSelectorRoot}, Path=ShowRightSelectionBox}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnRightSlotTapped" />
            </Border.GestureRecognizers>
            <Grid HorizontalOptions="Center">
                <skia:SKCanvasView
                    x:Name="RightSlotCanvas"
                    WidthRequest="28"
                    HeightRequest="28"
                    VerticalOptions="Center"
                    PaintSurface="OnRightSlotCanvasPaintSurface" />
            </Grid>
        </Border>
    </Grid>
</ContentView>
