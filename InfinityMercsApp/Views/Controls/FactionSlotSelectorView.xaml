<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Controls.FactionSlotSelectorView"
             x:Name="FactionSlotSelectorRoot">
    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
        <Border StrokeThickness="2" Stroke="{Binding Source={x:Reference FactionSlotSelectorRoot}, Path=LeftSlotBorderColor}" Padding="8,4">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnLeftSlotTapped" />
            </Border.GestureRecognizers>
            <Grid ColumnDefinitions="34,*" ColumnSpacing="8">
                <skia:SKCanvasView
                    x:Name="LeftSlotCanvas"
                    Grid.Column="0"
                    WidthRequest="28"
                    HeightRequest="28"
                    VerticalOptions="Center"
                    PaintSurface="OnLeftSlotCanvasPaintSurface" />
                <Label
                    Grid.Column="1"
                    Text="{Binding Source={x:Reference FactionSlotSelectorRoot}, Path=LeftSlotText}"
                    VerticalOptions="Center" />
            </Grid>
        </Border>
        <Border StrokeThickness="2"
                Stroke="{Binding Source={x:Reference FactionSlotSelectorRoot}, Path=RightSlotBorderColor}"
                Padding="8,4"
                IsVisible="{Binding Source={x:Reference FactionSlotSelectorRoot}, Path=ShowRightSelectionBox}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnRightSlotTapped" />
            </Border.GestureRecognizers>
            <Grid ColumnDefinitions="34,*" ColumnSpacing="8">
                <skia:SKCanvasView
                    x:Name="RightSlotCanvas"
                    Grid.Column="0"
                    WidthRequest="28"
                    HeightRequest="28"
                    VerticalOptions="Center"
                    PaintSurface="OnRightSlotCanvasPaintSurface" />
                <Label
                    Grid.Column="1"
                    Text="{Binding Source={x:Reference FactionSlotSelectorRoot}, Path=RightSlotText}"
                    VerticalOptions="Center" />
            </Grid>
        </Border>
    </HorizontalStackLayout>
</ContentView>
