<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             x:Class="InfinityMercsApp.Views.Controls.FactionSelectionStripView"
             x:Name="FactionSelectionStripRoot">

    <!-- Virtualized horizontal list: only the on-screen faction tiles are realised, so opening the
         picker no longer builds a Skia canvas for every faction up-front. The per-item tap command is
         bound via RelativeSource (not x:Reference) so it resolves inside the CollectionView template. -->
    <CollectionView x:Name="FactionCollectionView"
                    HeightRequest="100"
                    SelectionMode="None"
                    HorizontalScrollBarVisibility="Always"
                    VerticalScrollBarVisibility="Never"
                    ItemsSource="{Binding Source={x:Reference FactionSelectionStripRoot}, Path=EffectiveItemsSource}">
        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="2" />
        </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <controls:FactionListItemView
                    WidthRequest="138"
                    UseVerticalTileLayout="True"
                    ItemTappedCommand="{Binding Source={RelativeSource AncestorType={x:Type controls:FactionSelectionStripView}}, Path=SelectFactionCommand}"
                    ItemTappedCommandParameter="{Binding .}" />
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentView>
