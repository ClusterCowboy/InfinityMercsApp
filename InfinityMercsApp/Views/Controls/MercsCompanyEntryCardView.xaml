<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Controls.MercsCompanyEntryCardView"
             x:Name="MercsEntryCardRoot">

    <Border StrokeThickness="0" Padding="8" Margin="0,0,0,6">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnCardTapped" />
        </Border.GestureRecognizers>
        <Border.Triggers>
            <DataTrigger TargetType="Border" Binding="{Binding IsLieutenant}" Value="True">
                <Setter Property="BackgroundColor" Value="#004219" />
            </DataTrigger>
            <DataTrigger TargetType="Border" Binding="{Binding IsLieutenant}" Value="False">
                <Setter Property="BackgroundColor" Value="Transparent" />
            </DataTrigger>
        </Border.Triggers>

        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto" RowSpacing="6" ColumnSpacing="8">
            <Button
                x:Name="DetailsToggleButton"
                Grid.Row="0"
                Grid.Column="0"
                Text="›"
                WidthRequest="26"
                HeightRequest="26"
                Padding="0"
                FontAttributes="Bold"
                FontSize="18"
                CornerRadius="13"
                BackgroundColor="#111827"
                BorderColor="#6B7280"
                BorderWidth="1"
                TextColor="#E5E7EB"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Clicked="OnToggleDetailsButtonClicked" />

            <controls:UnitSelectionListItemView Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" />

            <HorizontalStackLayout Grid.Row="0" Grid.Column="2" Spacing="8" VerticalOptions="Start" HorizontalOptions="End">
                <Label Text="{Binding CostDisplay}" VerticalOptions="Center" />
                <Button
                    Text="X"
                    WidthRequest="28"
                    HeightRequest="28"
                    Padding="0"
                    FontAttributes="Bold"
                    VerticalOptions="Start"
                    HorizontalOptions="End"
                    Clicked="OnRemoveButtonClicked" />
            </HorizontalStackLayout>

            <VerticalStackLayout
                Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Spacing="6"
                IsVisible="{Binding IsDetailsExpanded}">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                    <Border Grid.Row="0" Grid.Column="0" BackgroundColor="Transparent" StrokeThickness="0" Padding="6,4">
                        <Label Text="{Binding SavedEquipmentDisplay}" TextColor="#06B6D4" FontSize="12" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" />
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" BackgroundColor="Transparent" StrokeThickness="0" Padding="6,4">
                        <Label Text="{Binding SavedSkillsDisplay}" TextColor="#F59E0B" FontSize="12" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" />
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0" BackgroundColor="Transparent" StrokeThickness="0" Padding="6,4">
                        <Label Text="{Binding SavedRangedWeaponsDisplay}" TextColor="#EF4444" FontSize="12" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" />
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="Transparent" StrokeThickness="0" Padding="6,4">
                        <Label Text="{Binding SavedCcWeaponsDisplay}" TextColor="#22C55E" FontSize="12" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" />
                    </Border>
                </Grid>

                <Border BackgroundColor="#111827" Stroke="#4B5563" StrokeThickness="1" Padding="6,4" IsVisible="{Binding HasPeripheralStatBlock}">
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                            <skia:SKCanvasView
                                Grid.Column="0"
                                WidthRequest="18"
                                HeightRequest="18"
                                VerticalOptions="Center"
                                PaintSurface="OnPeripheralIconCanvasPaintSurface" />
                            <Label Grid.Column="1" Text="{Binding PeripheralNameHeading}" FontSize="12" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                        </Grid>
                        <Label Text="{Binding PeripheralSubtitle}" FontSize="12" TextColor="#9CA3AF" LineBreakMode="WordWrap" />
                        <Label
                            FormattedText="{Binding PeripheralEquipmentLineFormatted}"
                            TextColor="White"
                            FontSize="12"
                            LineBreakMode="WordWrap"
                            HorizontalOptions="FillAndExpand"
                            IsVisible="{Binding HasPeripheralEquipmentLine}" />
                        <Label
                            FormattedText="{Binding PeripheralSkillsLineFormatted}"
                            TextColor="White"
                            FontSize="12"
                            LineBreakMode="WordWrap"
                            HorizontalOptions="FillAndExpand"
                            IsVisible="{Binding HasPeripheralSkillsLine}" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout
                    Spacing="2"
                    IsVisible="{Binding Source={x:Reference MercsEntryCardRoot}, Path=ShowOrderModifierBadges}">
                    <HorizontalStackLayout
                        Spacing="4"
                        IsVisible="{Binding IsIrregular}">
                        <skia:SKCanvasView
                            WidthRequest="16"
                            HeightRequest="16"
                            VerticalOptions="Center"
                            PaintSurface="OnIrregularIconCanvasPaintSurface" />
                        <Label
                            Text="Irregular"
                            FontSize="12"
                            TextColor="#F87171"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout
                        Spacing="4"
                        IsVisible="{Binding ShowRegularModifier}">
                        <skia:SKCanvasView
                            WidthRequest="16"
                            HeightRequest="16"
                            VerticalOptions="Center"
                            PaintSurface="OnRegularModifierIconCanvasPaintSurface" />
                        <Label
                            Text="Regular"
                            FontSize="12"
                            TextColor="#4ADE80"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>
    </Border>

</ContentView>
