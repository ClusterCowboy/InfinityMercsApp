<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Controls.SeasonStartPointsView"
             x:Name="SeasonStartPointsRoot">
    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
        <Label
            WidthRequest="70"
            Text="{Binding Source={x:Reference SeasonStartPointsRoot}, Path=SeasonPointsCapText}"
            VerticalOptions="Center" />
        <Label Text="/" VerticalOptions="Center" />
        <Picker
            WidthRequest="80"
            SelectedItem="{Binding Source={x:Reference SeasonStartPointsRoot}, Path=SelectedStartSeasonPoints, Mode=TwoWay}">
            <Picker.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>60</x:String>
                    <x:String>75</x:String>
                    <x:String>90</x:String>
                </x:Array>
            </Picker.ItemsSource>
        </Picker>
        <Label Text="Points to start season" VerticalOptions="Center" />
        <skia:SKCanvasView
            x:Name="SeasonValidationCanvas"
            WidthRequest="24"
            HeightRequest="24"
            VerticalOptions="Center"
            PaintSurface="OnSeasonValidationCanvasPaintSurface" />
    </HorizontalStackLayout>
</ContentView>
