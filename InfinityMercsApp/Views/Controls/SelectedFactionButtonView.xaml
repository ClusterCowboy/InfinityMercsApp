<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Controls.SelectedFactionButtonView"
             x:Name="SelectedFactionButtonRoot">

    <Border Stroke="{StaticResource Signal}"
            StrokeThickness="2"
            BackgroundColor="{StaticResource Plate}"
            Padding="10,8">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="4" />
        </Border.StrokeShape>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTapped" />
        </Border.GestureRecognizers>
        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10" VerticalOptions="Center">
            <skia:SKCanvasView
                x:Name="LeftSlotCanvas"
                Grid.Column="0"
                WidthRequest="34"
                HeightRequest="34"
                VerticalOptions="Center"
                PaintSurface="OnLeftSlotCanvasPaintSurface" />
            <skia:SKCanvasView
                x:Name="RightSlotCanvas"
                Grid.Column="1"
                WidthRequest="34"
                HeightRequest="34"
                VerticalOptions="Center"
                IsVisible="{Binding Source={x:Reference SelectedFactionButtonRoot}, Path=ShowRightSlot}"
                PaintSurface="OnRightSlotCanvasPaintSurface" />
            <Label
                x:Name="PromptLabel"
                Grid.Column="2"
                Text="Tap to choose faction"
                FontSize="{DynamicResource FontSizeBody}"
                TextColor="{StaticResource TextMuted}"
                LineBreakMode="TailTruncation"
                VerticalOptions="Center" />
            <Label
                Grid.Column="3"
                Text="CHANGE"
                FontSize="{DynamicResource FontSizeCaption}"
                FontAttributes="Bold"
                TextColor="{StaticResource Signal}"
                VerticalOptions="Center" />
        </Grid>
    </Border>

</ContentView>
