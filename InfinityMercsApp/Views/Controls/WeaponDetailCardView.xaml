<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Controls.WeaponDetailCardView">

    <Border BackgroundColor="#111827"
            Stroke="#4B5563"
            StrokeThickness="1"
            Padding="10,8">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="6" />
        </Border.StrokeShape>
        <VerticalStackLayout x:Name="ContentStack" Spacing="4" />
    </Border>

</ContentView>
