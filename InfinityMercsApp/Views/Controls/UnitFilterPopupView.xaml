<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Controls.UnitFilterPopupView"
             SizeChanged="OnPopupSizeChanged">

    <Grid Padding="20">
        <Border
            x:Name="PopupContainer"
            BackgroundColor="#1F1F23"
            Stroke="#4B5563"
            StrokeThickness="1"
            Padding="16"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            MaximumWidthRequest="900">

            <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="12">
                <Label
                    Grid.Row="0"
                    Text="Choose criteria to filter units by"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="White" />

                <Grid Grid.Row="1"
                      ColumnDefinitions="1.1*,1.4*"
                      ColumnSpacing="14"
                      VerticalOptions="FillAndExpand"
                      MinimumHeightRequest="320">
                    <Border Grid.Column="0" Stroke="#374151" StrokeThickness="1" Padding="10">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Criteria" TextColor="White" FontAttributes="Bold" />
                            <CollectionView ItemsSource="{Binding CriteriaItems}"
                                            SelectionMode="Single"
                                            SelectedItem="{Binding SelectedCriterion}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Stroke="#4B5563" StrokeThickness="1" Padding="8" Margin="0,0,0,6">
                                            <VerticalStackLayout Spacing="3">
                                                <Label Text="{Binding Title}" TextColor="White" FontAttributes="Bold" />
                                                <Label Text="{Binding Summary}" TextColor="#9CA3AF" FontSize="12" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Stroke="#374151" StrokeThickness="1" Padding="10">
                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="{Binding SelectedCriterionTitle}" TextColor="White" FontAttributes="Bold" FontSize="18" />
                                <Picker Grid.Column="1" WidthRequest="110" TextColor="White" ItemsSource="{Binding MatchModeOptions}" SelectedItem="{Binding SelectedActiveMatchMode}" />
                            </Grid>

                            <CollectionView Grid.Row="1"
                                            ItemsSource="{Binding ActiveCriterionOptions}"
                                            SelectionMode="None"
                                            VerticalOptions="FillAndExpand">
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Vertical" Span="2" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="0,2">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   TextColor="White"
                                                   VerticalTextAlignment="Center"
                                                   LineBreakMode="WordWrap" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                                <Border Grid.Column="0"
                                        WidthRequest="56"
                                        HeightRequest="56"
                                        BackgroundColor="Transparent"
                                        StrokeThickness="0"
                                        Padding="0"
                                        HorizontalOptions="Start">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnApplyCriterionTapped" />
                                    </Border.GestureRecognizers>
                                    <skia:SKCanvasView x:Name="ApplyCriterionIconCanvas"
                                                       PaintSurface="OnApplyCriterionIconCanvasPaintSurface" />
                                </Border>
                                <Button Grid.Column="1"
                                        Text="Clear"
                                        HorizontalOptions="Center"
                                        Clicked="OnClearSelectionsClicked" />
                                <Border Grid.Column="2"
                                        WidthRequest="56"
                                        HeightRequest="56"
                                        BackgroundColor="Transparent"
                                        StrokeThickness="0"
                                        Padding="0"
                                        HorizontalOptions="End">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnClearCriterionTapped" />
                                    </Border.GestureRecognizers>
                                    <skia:SKCanvasView x:Name="ClearCriterionIconCanvas"
                                                       PaintSurface="OnClearCriterionIconCanvasPaintSurface" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="12"
                      RowSpacing="10">
                    <Label Grid.Row="0" Grid.Column="0" Text="Points" VerticalTextAlignment="Center" TextColor="White" />
                    <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="8">
                        <Picker WidthRequest="120" TextColor="White" ItemsSource="{Binding PointsOptions}" SelectedItem="{Binding SelectedMinPoints}" />
                        <Label Text="to" VerticalTextAlignment="Center" TextColor="White" />
                        <Picker WidthRequest="120" TextColor="White" ItemsSource="{Binding PointsOptions}" SelectedItem="{Binding SelectedMaxPoints}" />
                    </HorizontalStackLayout>

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="Lieutenant Only Units"
                           VerticalTextAlignment="Center"
                           TextColor="White"
                           IsVisible="{Binding LieutenantOnlyUnitsEnabled}" />
                    <CheckBox Grid.Row="1"
                              Grid.Column="1"
                              IsChecked="{Binding SelectedLieutenantOnlyUnits}"
                              IsEnabled="{Binding LieutenantOnlyUnitsEnabled}"
                              IsVisible="{Binding LieutenantOnlyUnitsEnabled}"
                              HorizontalOptions="Start" />

                    <Label Grid.Row="2"
                           Grid.Column="0"
                           Text="Fireteam View"
                           VerticalTextAlignment="Center"
                           TextColor="White"
                           IsVisible="{Binding TeamsViewEnabled}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding TeamsViewEnabled}" Value="False">
                                <Setter Property="TextColor" Value="#6B7280" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                    <CheckBox Grid.Row="2"
                              Grid.Column="1"
                              IsChecked="{Binding SelectedTeamsView}"
                              IsEnabled="{Binding TeamsViewEnabled}"
                              IsVisible="{Binding TeamsViewEnabled}"
                              HorizontalOptions="Start" />
                </Grid>

                <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10" Margin="0,8,0,0">
                    <Button Grid.Column="0" Text="Back" Clicked="OnBackClicked" />
                    <Button Grid.Column="1" Text="Reset" Clicked="OnResetClicked" />
                    <Button Grid.Column="2" Text="Update Filter" HorizontalOptions="End" Clicked="OnFilterArmyClicked" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentView>
