<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Controls.UnitFilterPopupView">

    <Grid Padding="20">
        <Border
            BackgroundColor="#1F1F23"
            Stroke="#4B5563"
            StrokeThickness="1"
            Padding="16"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            MaximumWidthRequest="700">

            <VerticalStackLayout Spacing="12">
                <Label
                    Text="Choose criteria to filter units by"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="White" />

                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                    <Label Grid.Row="0" Grid.Column="0" Text="Classification" VerticalTextAlignment="Center" TextColor="White" />
                    <Picker Grid.Row="0" Grid.Column="1" TextColor="White" ItemsSource="{Binding ClassificationOptions}" SelectedItem="{Binding SelectedClassification}" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Characteristics" VerticalTextAlignment="Center" TextColor="White" />
                    <Picker Grid.Row="1" Grid.Column="1" TextColor="White" ItemsSource="{Binding CharacteristicsOptions}" SelectedItem="{Binding SelectedCharacteristics}" />

                    <Label Grid.Row="2" Grid.Column="0" Text="Skills" VerticalTextAlignment="Center" TextColor="White" />
                    <Picker Grid.Row="2" Grid.Column="1" TextColor="White" ItemsSource="{Binding SkillsOptions}" SelectedItem="{Binding SelectedSkills}" />

                    <Label Grid.Row="3" Grid.Column="0" Text="Equipment" VerticalTextAlignment="Center" TextColor="White" />
                    <Picker Grid.Row="3" Grid.Column="1" TextColor="White" ItemsSource="{Binding EquipmentOptions}" SelectedItem="{Binding SelectedEquipment}" />

                    <Label Grid.Row="4" Grid.Column="0" Text="Weapons" VerticalTextAlignment="Center" TextColor="White" />
                    <Picker Grid.Row="4" Grid.Column="1" TextColor="White" ItemsSource="{Binding WeaponsOptions}" SelectedItem="{Binding SelectedWeapons}" />

                    <Label Grid.Row="5" Grid.Column="0" Text="Ammo" VerticalTextAlignment="Center" TextColor="White" />
                    <Picker Grid.Row="5" Grid.Column="1" TextColor="White" ItemsSource="{Binding AmmoOptions}" SelectedItem="{Binding SelectedAmmo}" />

                    <Label Grid.Row="6" Grid.Column="0" Text="Points" VerticalTextAlignment="Center" TextColor="White" />
                    <HorizontalStackLayout Grid.Row="6" Grid.Column="1" Spacing="8">
                        <Picker WidthRequest="120" TextColor="White" ItemsSource="{Binding PointsOptions}" SelectedItem="{Binding SelectedMinPoints}" />
                        <Label Text="to" VerticalTextAlignment="Center" TextColor="White" />
                        <Picker WidthRequest="120" TextColor="White" ItemsSource="{Binding PointsOptions}" SelectedItem="{Binding SelectedMaxPoints}" />
                    </HorizontalStackLayout>

                    <Label Grid.Row="7" Grid.Column="0" Text="Lieutenant Only Units" VerticalTextAlignment="Center" TextColor="White" />
                    <CheckBox Grid.Row="7" Grid.Column="1" IsChecked="{Binding SelectedLieutenantOnlyUnits}" HorizontalOptions="Start" />

                    <Label Grid.Row="8" Grid.Column="0" Text="Fireteams View" VerticalTextAlignment="Center" TextColor="White" />
                    <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding SelectedTeamsView}" HorizontalOptions="Start" />
                </Grid>

                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10" Margin="0,8,0,0">
                    <Button Grid.Column="0" Text="Back" Clicked="OnBackClicked" />
                    <Button Grid.Column="1" Text="Reset" Clicked="OnResetClicked" />
                    <Button Grid.Column="2" Text="Filter Army" HorizontalOptions="End" Clicked="OnFilterArmyClicked" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
