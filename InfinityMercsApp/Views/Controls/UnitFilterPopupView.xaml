<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.Controls.UnitFilterPopupView"
             SizeChanged="OnPopupSizeChanged">

    <Grid Padding="16">
        <Border
            x:Name="PopupContainer"
            BackgroundColor="{StaticResource Plate}"
            Stroke="{StaticResource HairlineBright}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 4"
            Padding="0"
            VerticalOptions="Center"
            HorizontalOptions="Center">

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- ===== Header ===== -->
                <Border Grid.Row="0"
                        BackgroundColor="{StaticResource PlateRaised}"
                        StrokeThickness="0"
                        Padding="16,14">
                    <Label Text="Filter Units"
                           FontFamily="EthnocentricRegular"
                           FontSize="{DynamicResource FontSizeSubHeadline}"
                           TextColor="{StaticResource TextPrimary}"
                           VerticalOptions="Center" />
                </Border>

                <!-- ===== Body (scrolls so it never overflows the screen) ===== -->
                <ScrollView Grid.Row="1" Padding="16,14">
                    <VerticalStackLayout Spacing="18">

                        <!-- Criterion selector chips -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Criteria"
                                   Style="{StaticResource LabelCaption}"
                                   TextColor="{StaticResource TextMuted}" />
                            <FlexLayout BindableLayout.ItemsSource="{Binding CriteriaItems}"
                                        Direction="Row"
                                        Wrap="Wrap"
                                        AlignItems="Center">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border StrokeThickness="1"
                                                Stroke="{StaticResource Hairline}"
                                                BackgroundColor="{StaticResource Plate}"
                                                StrokeShape="RoundRectangle 4"
                                                Padding="12,8"
                                                Margin="0,0,8,8">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnCriterionChipTapped" />
                                            </Border.GestureRecognizers>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding HasSelections}" Value="True">
                                                    <Setter Property="Stroke" Value="{StaticResource SignalDim}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter Property="Stroke" Value="{StaticResource Signal}" />
                                                    <Setter Property="BackgroundColor" Value="{StaticResource PlateRaised}" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding Title}"
                                                       Style="{StaticResource LabelBody}"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       VerticalOptions="Center">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                                <BoxView WidthRequest="6"
                                                         HeightRequest="6"
                                                         CornerRadius="3"
                                                         Color="{StaticResource Signal}"
                                                         VerticalOptions="Center"
                                                         IsVisible="{Binding HasSelections}" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource Hairline}" />

                        <!-- Selected criterion editor: tap chips to toggle values -->
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding SelectedCriterionTitle}"
                                       FontFamily="ConthraxSemiBold"
                                       FontAttributes="Bold"
                                       FontSize="{DynamicResource FontSizeSectionHeader}"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="Clear"
                                        Style="{StaticResource ButtonCaption}"
                                        Padding="10,4"
                                        MinimumHeightRequest="0"
                                        Clicked="OnClearCriterionClicked" />
                            </Grid>

                            <HorizontalStackLayout Spacing="8">
                                <Label Text="Match"
                                       Style="{StaticResource LabelCaption}"
                                       TextColor="{StaticResource TextMuted}"
                                       VerticalOptions="Center" />
                                <Picker WidthRequest="100"
                                        TextColor="{StaticResource TextPrimary}"
                                        ItemsSource="{Binding MatchModeOptions}"
                                        SelectedItem="{Binding SelectedActiveMatchMode}" />
                            </HorizontalStackLayout>

                            <FlexLayout BindableLayout.ItemsSource="{Binding ActiveCriterionOptions}"
                                        Direction="Row"
                                        Wrap="Wrap"
                                        AlignItems="Center">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border StrokeThickness="1"
                                                Stroke="{StaticResource Hairline}"
                                                BackgroundColor="{StaticResource Plate}"
                                                StrokeShape="RoundRectangle 4"
                                                Padding="12,8"
                                                Margin="0,0,8,8">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnOptionChipTapped" />
                                            </Border.GestureRecognizers>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Stroke" Value="{StaticResource Signal}" />
                                                    <Setter Property="BackgroundColor" Value="{StaticResource SignalDim}" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding Value}"
                                                   Style="{StaticResource LabelBody}"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   VerticalOptions="Center">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource Hairline}" />

                        <!-- Points range -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Points"
                                   Style="{StaticResource LabelCaption}"
                                   TextColor="{StaticResource TextMuted}" />
                            <HorizontalStackLayout Spacing="8">
                                <Picker WidthRequest="110" TextColor="{StaticResource TextPrimary}" ItemsSource="{Binding PointsOptions}" SelectedItem="{Binding SelectedMinPoints}" />
                                <Label Text="to" VerticalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                                <Picker WidthRequest="110" TextColor="{StaticResource TextPrimary}" ItemsSource="{Binding PointsOptions}" SelectedItem="{Binding SelectedMaxPoints}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- Toggles -->
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding LieutenantOnlyUnitsEnabled}">
                                <Label Grid.Column="0"
                                       Text="Lieutenant Only Units"
                                       VerticalTextAlignment="Center"
                                       TextColor="{StaticResource TextPrimary}" />
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding SelectedLieutenantOnlyUnits}"
                                          IsEnabled="{Binding LieutenantOnlyUnitsEnabled}"
                                          HorizontalOptions="End" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding TeamsViewEnabled}">
                                <Label Grid.Column="0"
                                       Text="Fireteam View"
                                       VerticalTextAlignment="Center"
                                       TextColor="{StaticResource TextPrimary}" />
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding SelectedTeamsView}"
                                          IsEnabled="{Binding TeamsViewEnabled}"
                                          HorizontalOptions="End" />
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- ===== Footer action bar ===== -->
                <Border Grid.Row="2"
                        BackgroundColor="{StaticResource PlateRaised}"
                        StrokeThickness="0"
                        Padding="16,12">
                    <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Text="Back" Clicked="OnBackClicked" />
                        <Button Grid.Column="1" Text="Reset" Clicked="OnResetClicked" />
                        <Button Grid.Column="2"
                                Text="Update"
                                HorizontalOptions="End"
                                BackgroundColor="{StaticResource Signal}"
                                TextColor="{StaticResource Void}"
                                Clicked="OnFilterArmyClicked" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ContentView>
