<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.Controls.ViewerListRowView"
             x:Name="Root">
    <Border Padding="8,6" StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="6" />
        </Border.StrokeShape>
        <Border.Triggers>
            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                <Setter Property="BackgroundColor" Value="#334155" />
            </DataTrigger>
            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                <Setter Property="BackgroundColor" Value="Transparent" />
            </DataTrigger>
        </Border.Triggers>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTapped" />
        </Border.GestureRecognizers>
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" MinimumHeightRequest="44">
            <skia:SKCanvasView
                x:Name="LogoCanvas"
                WidthRequest="28"
                HeightRequest="28"
                VerticalOptions="Center"
                PaintSurface="OnLogoCanvasPaintSurface" />
            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                <Label Text="{Binding Name}" TextColor="White" LineBreakMode="TailTruncation" />
                <Label Text="{Binding Subtitle}" TextColor="#6B7280" FontSize="12" IsVisible="{Binding HasSubtitle}" LineBreakMode="TailTruncation" />
            </VerticalStackLayout>
        </Grid>
    </Border>
</ContentView>
