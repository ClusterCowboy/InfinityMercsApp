<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:shell="clr-namespace:Microsoft.Maui.Controls;assembly=Microsoft.Maui.Controls"
             x:Class="InfinityMercsApp.Views.ArmyFactionSelectionPage"
             x:Name="ArmyFactionSelectionRoot"
             Title="">

    <shell:Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
            <Label
                Grid.Column="0"
                Text="{Binding PageHeading}"
                TextColor="#A78BFA"
                FontSize="36"
                FontAttributes="Bold"
                VerticalOptions="Center" />
            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                <Label
                    WidthRequest="70"
                    Text="{Binding SeasonPointsCapText}"
                    VerticalOptions="Center" />
                <Label Text="/" VerticalOptions="Center" />
                <Picker
                    WidthRequest="80"
                    SelectedItem="{Binding SelectedStartSeasonPoints}">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>60</x:String>
                            <x:String>75</x:String>
                            <x:String>90</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
                <Label Text="Points to start season" VerticalOptions="Center" />
                <skia:SKCanvasView
                    x:Name="SeasonValidationCanvas"
                    WidthRequest="24"
                    HeightRequest="24"
                    VerticalOptions="Center"
                    PaintSurface="OnSeasonValidationCanvasPaintSurface" />
            </HorizontalStackLayout>
        </Grid>
    </shell:Shell.TitleView>

    <Grid Padding="16" ColumnDefinitions="*,*" ColumnSpacing="12" RowSpacing="10">

        <Grid Grid.Column="0" RowDefinitions="Auto,*" RowSpacing="10">
            <Grid Grid.Row="0" ColumnDefinitions="*,*" ColumnSpacing="10" HeightRequest="50">
                <Border StrokeThickness="2" Stroke="{Binding LeftSlotBorderColor}" Padding="8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLeftSlotTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="34,*" ColumnSpacing="8">
                        <skia:SKCanvasView
                            x:Name="LeftSlotCanvas"
                            Grid.Column="0"
                            WidthRequest="34"
                            HeightRequest="34"
                            VerticalOptions="Center"
                            PaintSurface="OnLeftSlotCanvasPaintSurface" />
                        <Label
                            Grid.Column="1"
                            Text="{Binding LeftSlotText}"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>
                <Border Grid.Column="1" StrokeThickness="2" Stroke="{Binding RightSlotBorderColor}" Padding="8" IsVisible="{Binding ShowRightSelectionBox}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRightSlotTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="34,*" ColumnSpacing="8">
                        <skia:SKCanvasView
                            x:Name="RightSlotCanvas"
                            Grid.Column="0"
                            WidthRequest="34"
                            HeightRequest="34"
                            VerticalOptions="Center"
                            PaintSurface="OnRightSlotCanvasPaintSurface" />
                        <Label
                            Grid.Column="1"
                            Text="{Binding RightSlotText}"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <Grid IsVisible="{Binding IsFactionSelectionActive}" RowDefinitions="*,Auto" RowSpacing="10">
                    <Border Grid.Row="0" StrokeThickness="1" Padding="10">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <Border Grid.Row="0" Padding="12,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFactionSelectionHeaderTapped" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsFactionSelectionActive}" Value="True">
                                        <Setter Property="BackgroundColor" Value="Black" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsFactionSelectionActive}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label
                                    Text="FACTION SELECTION"
                                    FontSize="24"
                                    FontAttributes="Bold"
                                    HorizontalTextAlignment="Start">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsFactionSelectionActive}" Value="True">
                                            <Setter Property="TextColor" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsFactionSelectionActive}" Value="False">
                                            <Setter Property="TextColor" Value="#A78BFA" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>

                            <ScrollView Grid.Row="1">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Factions}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <controls:FactionListItemView
                                                ItemTappedCommand="{Binding Source={x:Reference ArmyFactionSelectionRoot}, Path=BindingContext.SelectFactionCommand}"
                                                ItemTappedCommandParameter="{Binding .}" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </ScrollView>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" StrokeThickness="1" Padding="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                            <Border Grid.Column="0" Padding="12,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnUnitSelectionHeaderTapped" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsUnitSelectionActive}" Value="True">
                                        <Setter Property="BackgroundColor" Value="Black" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsUnitSelectionActive}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label
                                    Text="UNIT SELECTION"
                                    FontSize="24"
                                    FontAttributes="Bold"
                                    HorizontalTextAlignment="Start"
                                    VerticalTextAlignment="Center"
                                    VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsUnitSelectionActive}" Value="True">
                                            <Setter Property="TextColor" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsUnitSelectionActive}" Value="False">
                                            <Setter Property="TextColor" Value="#A78BFA" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding LieutenantOnlyUnits}" VerticalOptions="Center" />
                                    <Label Text="Lieutenant Only Units" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding TeamsView}" VerticalOptions="Center" />
                                    <Label Text="Duo Teams View" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </Grid>

                <Grid IsVisible="{Binding IsUnitSelectionActive}" RowDefinitions="Auto,*" RowSpacing="10">
                    <Border Grid.Row="0" StrokeThickness="1" Padding="10">
                        <Border Padding="12,8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFactionSelectionHeaderTapped" />
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsFactionSelectionActive}" Value="True">
                                    <Setter Property="BackgroundColor" Value="Black" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsFactionSelectionActive}" Value="False">
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label
                                Text="FACTION SELECTION"
                                FontSize="24"
                                FontAttributes="Bold"
                                HorizontalTextAlignment="Start">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsFactionSelectionActive}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsFactionSelectionActive}" Value="False">
                                        <Setter Property="TextColor" Value="#A78BFA" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </Border>

                    <Border Grid.Row="1" StrokeThickness="1" Padding="10">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                                <Border Grid.Column="0" Padding="12,8">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnUnitSelectionHeaderTapped" />
                                    </Border.GestureRecognizers>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsUnitSelectionActive}" Value="True">
                                            <Setter Property="BackgroundColor" Value="Black" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsUnitSelectionActive}" Value="False">
                                            <Setter Property="BackgroundColor" Value="Transparent" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label
                                        Text="UNIT SELECTION"
                                        FontSize="24"
                                        FontAttributes="Bold"
                                        HorizontalTextAlignment="Start"
                                        VerticalTextAlignment="Center"
                                        VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsUnitSelectionActive}" Value="True">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsUnitSelectionActive}" Value="False">
                                                <Setter Property="TextColor" Value="#A78BFA" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                        <CheckBox IsChecked="{Binding LieutenantOnlyUnits}" VerticalOptions="Center" />
                                        <Label Text="Lieutenant Only Units" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                        <CheckBox IsChecked="{Binding TeamsView}" VerticalOptions="Center" />
                                        <Label Text="Duo Teams View" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>

                            <ScrollView Grid.Row="1" IsVisible="{Binding ShowUnitsList}">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Units}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <controls:FactionListItemView
                                                ItemTapped="OnUnitItemTappedFromView"
                                                IsVisible="{Binding IsVisible}" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </ScrollView>

                            <ScrollView Grid.Row="1" IsVisible="{Binding ShowTeamsList}">
                                <VerticalStackLayout Spacing="0">
                                    <Label
                                        Text="One Duo fireteam per company"
                                        FontAttributes="Bold"
                                        Margin="8,6,8,8" />
                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding TeamEntries}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border StrokeThickness="1" Padding="8,6" MinimumHeightRequest="50" IsVisible="{Binding IsVisible}">
                                                <VerticalStackLayout Spacing="4">
                                                    <Label Text="{Binding Name}" />
                                                    <VerticalStackLayout Spacing="3">
                                                        <Grid ColumnDefinitions="44,44,*" ColumnSpacing="8">
                                                            <Label Grid.Column="0" Text="MIN" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                                            <Label Grid.Column="1" Text="MAX" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                                            <Label Grid.Column="2" Text="UNIT" FontAttributes="Bold" />
                                                        </Grid>
                                                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding AllowedProfiles}" Spacing="2">
                                                            <BindableLayout.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid ColumnDefinitions="44,44,*" ColumnSpacing="8" IsVisible="{Binding IsVisible}" MinimumHeightRequest="50">
                                                                        <Label Grid.Column="0" Text="{Binding Min}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" VerticalOptions="Center" />
                                                                        <Label Grid.Column="1" Text="{Binding Max}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" VerticalOptions="Center" />
                                                                        <controls:FactionListItemView
                                                                            Grid.Column="2"
                                                                            ItemTapped="OnTeamAllowedProfileTappedFromView" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </BindableLayout.ItemTemplate>
                                                        </VerticalStackLayout>
                                                    </VerticalStackLayout>
                                                </VerticalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </ScrollView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Column="1" RowDefinitions="*,*" RowSpacing="10">
        <Border Grid.Row="0" StrokeThickness="1" Padding="10">
            <Grid RowDefinitions="*" RowSpacing="8">
                <Border Grid.Row="0" StrokeThickness="1" Padding="8" VerticalOptions="Fill">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="6">
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="56,*,140" ColumnSpacing="10" RowSpacing="4">
                            <skia:SKCanvasView
                                x:Name="SelectedUnitCanvas"
                                Grid.Column="0"
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                WidthRequest="50"
                                HeightRequest="50"
                                VerticalOptions="Center"
                                PaintSurface="OnSelectedUnitCanvasPaintSurface" />
                            <Label Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Text="{Binding UnitNameHeading}" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />
                            <skia:SKCanvasView
                                x:Name="TopIconRowCanvas"
                                Grid.Row="0"
                                Grid.Column="2"
                                HeightRequest="24"
                                HorizontalOptions="Fill"
                                VerticalOptions="Center"
                                IsVisible="{Binding HasAnyTopHeaderIcons}"
                                PaintSurface="OnTopIconRowCanvasPaintSurface" />
                            <skia:SKCanvasView
                                x:Name="BottomIconRowCanvas"
                                Grid.Row="1"
                                Grid.Column="2"
                                HeightRequest="24"
                                HorizontalOptions="Fill"
                                VerticalOptions="Center"
                                IsVisible="{Binding HasAnyBottomHeaderIcons}"
                                PaintSurface="OnBottomIconRowCanvasPaintSurface" />
                        </Grid>
                        <Grid Grid.Row="1" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="MOV" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="CC" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="BS" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="PH" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="WIP" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="ARM" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="6" Text="BTS" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="7" Text="{Binding UnitVitalityHeader}" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="8" Text="S" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="9" Text="AVA" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Grid>
                        <Grid Grid.Row="2" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="{Binding UnitMov}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding UnitCc}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding UnitBs}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="{Binding UnitPh}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="{Binding UnitWip}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="{Binding UnitArm}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="6" Text="{Binding UnitBts}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="7" Text="{Binding UnitVitality}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="8" Text="{Binding UnitS}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="9" Text="{Binding UnitAva}" HorizontalTextAlignment="Center" />
                        </Grid>
                        <Label Grid.Row="3" FormattedText="{Binding EquipmentSummaryFormatted}" LineBreakMode="WordWrap" />
                        <Label Grid.Row="4" FormattedText="{Binding SpecialSkillsSummaryFormatted}" LineBreakMode="WordWrap" />
                        <Label Grid.Row="5" Text="Configurations" FontSize="20" FontAttributes="Bold" />
                        <ScrollView Grid.Row="6" VerticalOptions="FillAndExpand">
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Profiles}" Spacing="6">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border StrokeThickness="1" Padding="10" MinimumHeightRequest="50" IsVisible="{Binding IsVisible}">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsLieutenantBlocked}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#7F1D1D" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsLieutenantBlocked}" Value="False">
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference ArmyFactionSelectionRoot}, Path=BindingContext.AddProfileToMercsCompanyCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="2">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="56" />
                                                    </Grid.ColumnDefinitions>
                                                    <Label Grid.Column="0" FormattedText="{Binding NameFormatted}" FontAttributes="Bold" />
                                                    <Label Grid.Column="1" Text="{Binding Cost, StringFormat='C {0}'}" FontSize="12" HorizontalTextAlignment="End" />
                                                </Grid>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Label Grid.Column="0" FormattedText="{Binding RangedWeaponsFormatted}" FontSize="12" TextColor="#EF4444" LineBreakMode="WordWrap" />
                                                    <Label Grid.Column="1" FormattedText="{Binding MeleeWeaponsFormatted}" FontSize="12" TextColor="#22C55E" LineBreakMode="WordWrap" />
                                                    <Label Grid.Column="2" FormattedText="{Binding UniqueEquipmentFormatted}" FontSize="12" TextColor="#06B6D4" LineBreakMode="WordWrap" />
                                                    <Label Grid.Column="3" FormattedText="{Binding UniqueSkillsFormatted}" FontSize="12" TextColor="#F59E0B" LineBreakMode="WordWrap" />
                                                </Grid>
                                                <Label FormattedText="{Binding PeripheralsFormatted}" FontSize="12" TextColor="#FACC15" LineBreakMode="WordWrap" IsVisible="{Binding HasPeripherals}" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </ScrollView>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" StrokeThickness="1" Padding="10">
            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <Label
                    Grid.Row="0"
                    Text="Mercs Company"
                    FontSize="20"
                    FontAttributes="Bold" />
                <CollectionView
                    Grid.Row="1"
                    ItemsSource="{Binding MercsCompanyEntries}"
                    SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="1" Padding="8" Margin="0,0,0,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference ArmyFactionSelectionRoot}, Path=BindingContext.SelectMercsCompanyEntryCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsLieutenant}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#004219" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsLieutenant}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                                    <controls:FactionListItemView Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" TitleFormatted="{Binding NameFormatted}" />
                                    <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="8" VerticalOptions="Start" HorizontalOptions="End">
                                        <Label Text="{Binding CostDisplay}" VerticalOptions="Center" />
                                        <Button
                                            Text="X"
                                            WidthRequest="28"
                                            HeightRequest="28"
                                            Padding="0"
                                            FontAttributes="Bold"
                                            VerticalOptions="Start"
                                            HorizontalOptions="End"
                                            Command="{Binding Source={x:Reference ArmyFactionSelectionRoot}, Path=BindingContext.RemoveMercsCompanyEntryCommand}"
                                            CommandParameter="{Binding .}" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" FormattedText="{Binding EquipmentLineFormatted}" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" IsVisible="{Binding HasEquipmentLine}" />
                                    <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" FormattedText="{Binding SkillsLineFormatted}" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" IsVisible="{Binding HasSkillsLine}" />
                                    <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" FormattedText="{Binding RangedLineFormatted}" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" />
                                    <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" FormattedText="{Binding CcLineFormatted}" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="No units added yet." TextColor="#6B7280" />
                    </CollectionView.EmptyView>
                </CollectionView>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</ContentPage>
