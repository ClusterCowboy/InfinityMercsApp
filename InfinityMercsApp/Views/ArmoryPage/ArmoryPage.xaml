<?xml version="1.0" encoding="utf-8" ?>
<layout:AdaptiveContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             xmlns:layout="clr-namespace:InfinityMercsApp.Views.Adaptive"
             xmlns:domain="clr-namespace:InfinityMercsApp.Domain.Models.Metadata;assembly=InfinityMercsApp.Domain"
             x:Class="InfinityMercsApp.Views.ArmoryPage"
             x:Name="ArmoryRoot"
             Title="Armory">

    <Grid x:Name="RootGrid" Padding="16" ColumnDefinitions="*" ColumnSpacing="16">

        <!-- Left: weapon list -->
        <Border x:Name="ListPane" Grid.Column="0" StrokeThickness="1" Padding="12">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                <Label Grid.Row="0"
                       Text="Weapons"
                       HorizontalTextAlignment="Center"
                       FontSize="{DynamicResource FontSizeTitleSmall}"
                       FontAttributes="Bold" />
                <Entry Grid.Row="1"
                       Placeholder="Search weapons..."
                       TextChanged="OnWeaponSearchTextChanged" />
                <CollectionView Grid.Row="2"
                                VerticalOptions="FillAndExpand"
                                ItemsSource="{Binding Source={x:Reference ArmoryRoot}, Path=WeaponGroups}"
                                SelectionMode="Single"
                                SelectedItem="{Binding Source={x:Reference ArmoryRoot}, Path=SelectedWeaponGroup, Mode=TwoWay}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="6,4">
                                <Label Text="{Binding Name}"
                                       FontSize="{DynamicResource FontSizeBody}"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <!-- Right: weapon detail -->
        <Border x:Name="DetailPane" Grid.Column="1" StrokeThickness="1" Padding="14">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                <!-- Compact-only return to the weapon list -->
                <Button x:Name="DetailBackButton"
                        Grid.Row="0"
                        Text="← Weapons"
                        IsVisible="False"
                        HorizontalOptions="Start"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        TextColor="{StaticResource Signal}"
                        FontAttributes="Bold"
                        Padding="0"
                        Clicked="OnDetailBackClicked" />
                <Label Grid.Row="1"
                       Text="{Binding Source={x:Reference ArmoryRoot}, Path=SelectedWeaponName}"
                       FontSize="{DynamicResource FontSizeSubHeadline}"
                       FontAttributes="Bold" />
                <Grid Grid.Row="2">
                    <Label Text="Select a weapon from the list."
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           TextColor="{StaticResource TextMuted}"
                           IsVisible="{Binding Source={x:Reference ArmoryRoot}, Path=NoWeaponSelected}" />
                    <ScrollView VerticalOptions="Fill"
                                IsVisible="{Binding Source={x:Reference ArmoryRoot}, Path=HasSelectedWeapon}">
                        <VerticalStackLayout x:Name="DetailWeaponList"
                                             Spacing="8"
                                             BindableLayout.ItemsSource="{Binding Source={x:Reference ArmoryRoot}, Path=SelectedWeaponGroup.Modes}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="domain:Weapon">
                                    <controls:WeaponDetailCardView Weapon="{Binding}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Grid>
        </Border>

    </Grid>

</layout:AdaptiveContentPage>
