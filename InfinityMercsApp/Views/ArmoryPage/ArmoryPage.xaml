<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             xmlns:domain="clr-namespace:InfinityMercsApp.Domain.Models.Metadata;assembly=InfinityMercsApp.Domain"
             x:Class="InfinityMercsApp.Views.ArmoryPage"
             x:Name="ArmoryRoot"
             Title="Armory">

    <Grid Padding="16" ColumnDefinitions="3*,7*" ColumnSpacing="16">

        <!-- Left: weapon list -->
        <Border Grid.Column="0" StrokeThickness="1" Padding="12">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                <Label Grid.Row="0"
                       Text="Weapons"
                       HorizontalTextAlignment="Center"
                       FontSize="20"
                       FontAttributes="Bold" />
                <Entry Grid.Row="1"
                       Placeholder="Search weapons..."
                       TextChanged="OnWeaponSearchTextChanged" />
                <CollectionView Grid.Row="2"
                                VerticalOptions="FillAndExpand"
                                ItemsSource="{Binding Source={x:Reference ArmoryRoot}, Path=WeaponGroups}"
                                SelectionMode="Single"
                                SelectedItem="{Binding Source={x:Reference ArmoryRoot}, Path=SelectedWeaponGroup, Mode=TwoWay}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="6,4">
                                <Label Text="{Binding Name}"
                                       FontSize="14"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <!-- Right: weapon detail -->
        <Border Grid.Column="1" StrokeThickness="1" Padding="14">
            <Grid RowDefinitions="Auto,*" RowSpacing="10">
                <Label Grid.Row="0"
                       Text="{Binding Source={x:Reference ArmoryRoot}, Path=SelectedWeaponName}"
                       FontSize="18"
                       FontAttributes="Bold" />
                <Grid Grid.Row="1">
                    <Label Text="Select a weapon from the list."
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           TextColor="#6B7280"
                           IsVisible="{Binding Source={x:Reference ArmoryRoot}, Path=NoWeaponSelected}" />
                    <ScrollView VerticalOptions="Fill"
                                IsVisible="{Binding Source={x:Reference ArmoryRoot}, Path=HasSelectedWeapon}">
                        <VerticalStackLayout Spacing="8"
                                             BindableLayout.ItemsSource="{Binding Source={x:Reference ArmoryRoot}, Path=SelectedWeaponGroup.Modes}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="domain:Weapon">
                                    <controls:WeaponDetailCardView Weapon="{Binding}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Grid>
        </Border>

    </Grid>

</ContentPage>
