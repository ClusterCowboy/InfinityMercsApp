<?xml version="1.0" encoding="utf-8" ?>
<views:ContentPageBase xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:InfinityMercsApp.Views"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.SplashPage"
             BackgroundColor="#0E1116">

    <Grid>
        <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="16">

            <skia:SKCanvasView
                x:Name="SplashLogoCanvas"
                HeightRequest="120"
                WidthRequest="320"
                HorizontalOptions="Center"
                PaintSurface="OnSplashLogoPaintSurface" />

            <Label
                Text="Infinity Mercs"
                FontSize="{DynamicResource FontSizeTitleLarge}"
                FontAttributes="Bold"
                TextColor="#E6EBF2"
                HorizontalTextAlignment="Center" />

            <ActivityIndicator
                IsRunning="True"
                Color="#34D399"
                HorizontalOptions="Center" />

            <Label
                x:Name="StatusLabel"
                Text="{Binding UpdateProgressMessage}"
                FontSize="{DynamicResource FontSizeSectionHeader}"
                TextColor="#8A97A8"
                HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </Grid>

</views:ContentPageBase>

