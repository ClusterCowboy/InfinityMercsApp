<?xml version="1.0" encoding="utf-8" ?>
<layout:AdaptiveContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:layout="clr-namespace:InfinityMercsApp.Views.Adaptive"
             x:Class="InfinityMercsApp.Views.MarketplacesPage"
             x:Name="MarketplacesRoot"
             Title="Marketplaces">

    <Grid Padding="16" RowDefinitions="Auto,*" RowSpacing="12">

        <!-- Marketplace selector dropdown -->
        <Border Grid.Row="0" StrokeThickness="1" Padding="8,4">
            <Picker x:Name="MarketplacePicker"
                    Title="Select a Marketplace"
                    ItemsSource="{Binding Source={x:Reference MarketplacesRoot}, Path=StoreNames}"
                    SelectedIndexChanged="OnStorePickerSelectedIndexChanged"
                    FontSize="{DynamicResource FontSizeSectionHeader}" />
        </Border>

        <!-- Content area: rail / sections / cart placement is reflowed per width mode -->
        <Grid x:Name="ContentGrid" Grid.Row="1">

            <!-- Placeholder shown before any selection -->
            <Label x:Name="PlaceholderLabel"
                   Text="Select a marketplace from the dropdown above."
                   HorizontalTextAlignment="Center"
                   VerticalOptions="Start"
                   Margin="0,24,0,0"
                   FontSize="{DynamicResource FontSizeSectionHeader}"
                   TextColor="{StaticResource TextMuted}" />

            <!-- Store info header / metadata rail -->
            <Border x:Name="StoreInfoBorder"
                    IsVisible="False"
                    VerticalOptions="Start"
                    StrokeThickness="1"
                    Padding="12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding Source={x:Reference MarketplacesRoot}, Path=StoreName}"
                           FontSize="{DynamicResource FontSizeTitleSmall}"
                           FontAttributes="Bold" />
                    <Label Text="{Binding Source={x:Reference MarketplacesRoot}, Path=StoreFactionsDisplay}"
                           FontSize="{DynamicResource FontSizeBody}"
                           TextColor="{StaticResource TextMuted}" />
                    <Label Text="{Binding Source={x:Reference MarketplacesRoot}, Path=StoreMetaDisplay}"
                           FontSize="{DynamicResource FontSizeBody}"
                           TextColor="{StaticResource TextMuted}" />
                </VerticalStackLayout>
            </Border>

            <!-- Marketplace sections -->
            <ScrollView x:Name="SectionsScroll" IsVisible="False">
                <Grid x:Name="SectionsHost" RowSpacing="12" ColumnSpacing="12">

                    <!-- Items section -->
                    <Border x:Name="ItemsBorder"
                            StrokeThickness="1"
                            Padding="12"
                            VerticalOptions="Start"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Items" FontSize="{DynamicResource FontSizeSubHeadline}" FontAttributes="Bold" />

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Source={x:Reference MarketplacesRoot}, Path=ItemGroups}"
                                                 Spacing="12">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <VerticalStackLayout Spacing="4">
                                            <!-- Category label -->
                                            <Label Text="{Binding Category}"
                                                   FontSize="{DynamicResource FontSizeBody}"
                                                   FontAttributes="Bold,Italic"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   Padding="2,4,2,0" />

                                            <!-- Item button cards -->
                                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Items}"
                                                                 Spacing="4">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Stroke="{StaticResource Hairline}"
                                                                StrokeThickness="1"
                                                                StrokeShape="RoundRectangle 4"
                                                                BackgroundColor="{StaticResource Plate}"
                                                                Padding="12,10"
                                                                Margin="0,0,0,0"
                                                                MinimumHeightRequest="52">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Command="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowItemCommand}"
                                                                    CommandParameter="{Binding}" />
                                                            </Border.GestureRecognizers>
                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                <VerticalStackLayout Grid.Column="0"
                                                                                     Spacing="2"
                                                                                     VerticalOptions="Center">
                                                                    <Label Text="{Binding Name}"
                                                                           FontSize="{DynamicResource FontSizeBody}"
                                                                           FontAttributes="Bold"
                                                                           TextColor="{StaticResource TextPrimary}" />
                                                                    <Label Text="{Binding CostDisplay}"
                                                                           FontSize="{DynamicResource FontSizeBody}"
                                                                           TextColor="{StaticResource Signal}" />
                                                                </VerticalStackLayout>
                                                                <HorizontalStackLayout Grid.Column="1"
                                                                                       IsVisible="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowQuantityControls}"
                                                                                       Spacing="6"
                                                                                       VerticalOptions="Center">
                                                                    <Button Text="−"
                                                                            BackgroundColor="{StaticResource HairlineBright}"
                                                                            TextColor="{StaticResource Danger}"
                                                                            BorderColor="{StaticResource HairlineBright}"
                                                                            BorderWidth="1"
                                                                            CornerRadius="4"
                                                                            FontSize="{DynamicResource FontSizeSubHeadline}"
                                                                            WidthRequest="44"
                                                                            HeightRequest="44"
                                                                            Padding="0"
                                                                            CommandParameter="{Binding}"
                                                                            Clicked="OnItemDecrement" />
                                                                    <Label Text="{Binding Quantity}"
                                                                           FontSize="{DynamicResource FontSizeBody}"
                                                                           TextColor="{StaticResource TextPrimary}"
                                                                           VerticalTextAlignment="Center"
                                                                           HorizontalTextAlignment="Center"
                                                                           MinimumWidthRequest="28" />
                                                                    <Button Text="+"
                                                                            BackgroundColor="{StaticResource HairlineBright}"
                                                                            TextColor="{StaticResource Signal}"
                                                                            BorderColor="{StaticResource HairlineBright}"
                                                                            BorderWidth="1"
                                                                            CornerRadius="4"
                                                                            FontSize="{DynamicResource FontSizeSubHeadline}"
                                                                            WidthRequest="44"
                                                                            HeightRequest="44"
                                                                            Padding="0"
                                                                            CommandParameter="{Binding}"
                                                                            Clicked="OnItemIncrement" />
                                                                </HorizontalStackLayout>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Troop Types section -->
                    <Border x:Name="TroopTypesBorder"
                            StrokeThickness="1"
                            Padding="12"
                            VerticalOptions="Start"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Troop Types" FontSize="{DynamicResource FontSizeSubHeadline}" FontAttributes="Bold" />

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Source={x:Reference MarketplacesRoot}, Path=TroopTypeRows}"
                                                 Spacing="4">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border Stroke="{StaticResource Hairline}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 4"
                                                BackgroundColor="{StaticResource Plate}"
                                                Padding="12,10"
                                                MinimumHeightRequest="52">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowTroopTypeCommand}"
                                                    CommandParameter="{Binding}" />
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <VerticalStackLayout Grid.Column="0"
                                                                     Spacing="2"
                                                                     VerticalOptions="Center">
                                                    <Label Text="{Binding DisplayName}"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource TextPrimary}" />
                                                    <Label Text="{Binding StatDisplay}"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           TextColor="{StaticResource TextMuted}" />
                                                    <Label Text="{Binding CostDisplay}"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           TextColor="{StaticResource Signal}" />
                                                    <Label Text="{Binding Abilities}"
                                                           FontSize="{DynamicResource FontSizeCaption}"
                                                           TextColor="{StaticResource TextMuted}"
                                                           LineBreakMode="WordWrap"
                                                           IsVisible="{Binding HasAbilities}" />
                                                </VerticalStackLayout>
                                                <HorizontalStackLayout Grid.Column="1"
                                                                       IsVisible="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowQuantityControls}"
                                                                       Spacing="6"
                                                                       VerticalOptions="Center">
                                                    <Button Text="−"
                                                            BackgroundColor="{StaticResource HairlineBright}"
                                                            TextColor="{StaticResource Danger}"
                                                            BorderColor="{StaticResource HairlineBright}"
                                                            BorderWidth="1"
                                                            CornerRadius="4"
                                                            FontSize="{DynamicResource FontSizeSubHeadline}"
                                                            WidthRequest="44"
                                                            HeightRequest="44"
                                                            Padding="0"
                                                            CommandParameter="{Binding}"
                                                            Clicked="OnTroopDecrement" />
                                                    <Label Text="{Binding Quantity}"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           VerticalTextAlignment="Center"
                                                           HorizontalTextAlignment="Center"
                                                           MinimumWidthRequest="28" />
                                                    <Button Text="+"
                                                            BackgroundColor="{StaticResource HairlineBright}"
                                                            TextColor="{StaticResource Signal}"
                                                            BorderColor="{StaticResource HairlineBright}"
                                                            BorderWidth="1"
                                                            CornerRadius="4"
                                                            FontSize="{DynamicResource FontSizeSubHeadline}"
                                                            WidthRequest="44"
                                                            HeightRequest="44"
                                                            Padding="0"
                                                            CommandParameter="{Binding}"
                                                            Clicked="OnTroopIncrement" />
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Augments section -->
                    <Border x:Name="AugmentsBorder"
                            StrokeThickness="1"
                            Padding="12"
                            VerticalOptions="Start"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Augments" FontSize="{DynamicResource FontSizeSubHeadline}" FontAttributes="Bold" />

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Source={x:Reference MarketplacesRoot}, Path=AugmentRows}"
                                                 Spacing="4">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border Stroke="{StaticResource Hairline}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 4"
                                                BackgroundColor="{StaticResource Plate}"
                                                Padding="12,10"
                                                MinimumHeightRequest="52">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowAugmentCommand}"
                                                    CommandParameter="{Binding}" />
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <VerticalStackLayout Grid.Column="0"
                                                                     Spacing="2"
                                                                     VerticalOptions="Center">
                                                    <Label Text="{Binding Name}"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource TextPrimary}" />
                                                    <Label Text="{Binding RequirementDisplay}"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           TextColor="{StaticResource TextMuted}"
                                                           IsVisible="{Binding HasRequirement}" />
                                                    <Label Text="{Binding CostDisplay}"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           TextColor="{StaticResource Signal}" />
                                                </VerticalStackLayout>
                                                <HorizontalStackLayout Grid.Column="1"
                                                                       IsVisible="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowQuantityControls}"
                                                                       Spacing="6"
                                                                       VerticalOptions="Center">
                                                    <Button Text="−"
                                                            BackgroundColor="{StaticResource HairlineBright}"
                                                            TextColor="{StaticResource Danger}"
                                                            BorderColor="{StaticResource HairlineBright}"
                                                            BorderWidth="1"
                                                            CornerRadius="4"
                                                            FontSize="{DynamicResource FontSizeSubHeadline}"
                                                            WidthRequest="44"
                                                            HeightRequest="44"
                                                            Padding="0"
                                                            CommandParameter="{Binding}"
                                                            Clicked="OnAugmentDecrement" />
                                                    <Label Text="{Binding Quantity}"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           VerticalTextAlignment="Center"
                                                           HorizontalTextAlignment="Center"
                                                           MinimumWidthRequest="28" />
                                                    <Button Text="+"
                                                            BackgroundColor="{StaticResource HairlineBright}"
                                                            TextColor="{StaticResource Signal}"
                                                            BorderColor="{StaticResource HairlineBright}"
                                                            BorderWidth="1"
                                                            CornerRadius="4"
                                                            FontSize="{DynamicResource FontSizeSubHeadline}"
                                                            WidthRequest="44"
                                                            HeightRequest="44"
                                                            Padding="0"
                                                            CommandParameter="{Binding}"
                                                            Clicked="OnAugmentIncrement" />
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </ScrollView>

            <!-- Wide-only cart / quantity summary rail -->
            <Border x:Name="CartBorder"
                    IsVisible="False"
                    StrokeThickness="1"
                    Padding="12">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                    <Label Grid.Row="0"
                           Text="Cart"
                           FontSize="{DynamicResource FontSizeSubHeadline}"
                           FontAttributes="Bold" />
                    <Label Grid.Row="1"
                           Text="Tap + on any item to add it here."
                           VerticalOptions="Start"
                           FontSize="{DynamicResource FontSizeBody}"
                           TextColor="{StaticResource TextMuted}"
                           IsVisible="{Binding Source={x:Reference MarketplacesRoot}, Path=IsCartEmpty}" />
                    <ScrollView Grid.Row="1"
                                IsVisible="{Binding Source={x:Reference MarketplacesRoot}, Path=HasCartLines}">
                        <VerticalStackLayout Spacing="6"
                                             BindableLayout.ItemsSource="{Binding Source={x:Reference MarketplacesRoot}, Path=CartLines}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <Label Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="{DynamicResource FontSizeBody}"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="1"
                                               Text="{Binding QuantityDisplay}"
                                               FontSize="{DynamicResource FontSizeBody}"
                                               TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Column="2"
                                               Text="{Binding CostDisplay}"
                                               FontSize="{DynamicResource FontSizeBody}"
                                               TextColor="{StaticResource Signal}" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>
                    <Label Grid.Row="2"
                           Text="{Binding Source={x:Reference MarketplacesRoot}, Path=CartTotalDisplay}"
                           FontSize="{DynamicResource FontSizeBody}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>

        </Grid>

        <!-- Item detail popup overlay — covers the full page -->
        <Grid x:Name="MarketplacePopupOverlay"
              Grid.Row="0" Grid.RowSpan="2"
              IsVisible="False"
              BackgroundColor="#D00E1116">
            <Border BackgroundColor="{StaticResource Plate}"
                    Stroke="{StaticResource Hairline}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 4"
                    Margin="16,60,16,24">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="Auto,*"
                          BackgroundColor="{StaticResource HairlineBright}"
                          Padding="4,4">
                        <Button x:Name="PopupBackButton"
                                Grid.Column="0"
                                Text="← Back"
                                BackgroundColor="Transparent"
                                BorderColor="Transparent"
                                TextColor="{StaticResource Signal}"
                                FontAttributes="Bold"
                                Padding="8,0"
                                Clicked="OnPopupBackClicked" />
                        <Label x:Name="PopupTitleLabel"
                               Grid.Column="1"
                               FontSize="{DynamicResource FontSizeBody}"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalTextAlignment="Center"
                               Padding="4,0,8,0"
                               LineBreakMode="TailTruncation" />
                    </Grid>
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout x:Name="PopupContentArea"
                                             Padding="16,12"
                                             Spacing="6" />
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>

    </Grid>

</layout:AdaptiveContentPage>
