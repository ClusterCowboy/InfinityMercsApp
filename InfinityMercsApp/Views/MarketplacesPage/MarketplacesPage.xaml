<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InfinityMercsApp.Views.MarketplacesPage"
             x:Name="MarketplacesRoot"
             Title="Marketplaces">

    <Grid Padding="16" RowDefinitions="Auto,*" RowSpacing="12">

        <!-- Marketplace selector dropdown -->
        <Border Grid.Row="0" StrokeThickness="1" Padding="8,4">
            <Picker x:Name="MarketplacePicker"
                    Title="Select a Marketplace"
                    ItemsSource="{Binding Source={x:Reference MarketplacesRoot}, Path=StoreNames}"
                    SelectedIndexChanged="OnStorePickerSelectedIndexChanged"
                    FontSize="16" />
        </Border>

        <!-- Content area -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12">

                <!-- Placeholder shown before any selection -->
                <Label x:Name="PlaceholderLabel"
                       Text="Select a marketplace from the dropdown above."
                       HorizontalTextAlignment="Center"
                       Margin="0,24,0,0"
                       FontSize="16"
                       TextColor="#6B7280" />

                <!-- Store detail, hidden until a store is selected -->
                <VerticalStackLayout x:Name="StoreContentLayout"
                                     IsVisible="False"
                                     Spacing="12">

                    <!-- Store info header -->
                    <Border StrokeThickness="1" Padding="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Source={x:Reference MarketplacesRoot}, Path=StoreName}"
                                   FontSize="22"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding Source={x:Reference MarketplacesRoot}, Path=StoreFactionsDisplay}"
                                   FontSize="14"
                                   TextColor="#9CA3AF" />
                            <Label Text="{Binding Source={x:Reference MarketplacesRoot}, Path=StoreMetaDisplay}"
                                   FontSize="14"
                                   TextColor="#9CA3AF" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Items section -->
                    <Border x:Name="ItemsBorder"
                            StrokeThickness="1"
                            Padding="12"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Items" FontSize="18" FontAttributes="Bold" />

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Source={x:Reference MarketplacesRoot}, Path=ItemGroups}"
                                                 Spacing="12">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <VerticalStackLayout Spacing="4">
                                            <!-- Category label -->
                                            <Label Text="{Binding Category}"
                                                   FontSize="13"
                                                   FontAttributes="Bold,Italic"
                                                   TextColor="#60A5FA"
                                                   Padding="2,4,2,0" />

                                            <!-- Item button cards -->
                                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Items}"
                                                                 Spacing="4">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Stroke="#374151"
                                                                StrokeThickness="1"
                                                                StrokeShape="RoundRectangle 4"
                                                                BackgroundColor="#1F2937"
                                                                Padding="12,10"
                                                                Margin="0,0,0,0"
                                                                MinimumHeightRequest="52">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Command="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowItemCommand}"
                                                                    CommandParameter="{Binding}" />
                                                            </Border.GestureRecognizers>
                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                <VerticalStackLayout Grid.Column="0"
                                                                                     Spacing="2"
                                                                                     VerticalOptions="Center">
                                                                    <Label Text="{Binding Name}"
                                                                           FontSize="15"
                                                                           FontAttributes="Bold"
                                                                           TextColor="White" />
                                                                    <Label Text="{Binding CostDisplay}"
                                                                           FontSize="13"
                                                                           TextColor="#22C55E" />
                                                                </VerticalStackLayout>
                                                                <HorizontalStackLayout Grid.Column="1"
                                                                                       IsVisible="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowQuantityControls}"
                                                                                       Spacing="6"
                                                                                       VerticalOptions="Center">
                                                                    <Button Text="−"
                                                                            BackgroundColor="#374151"
                                                                            TextColor="#EF4444"
                                                                            BorderColor="#4B5563"
                                                                            BorderWidth="1"
                                                                            CornerRadius="4"
                                                                            FontSize="18"
                                                                            WidthRequest="44"
                                                                            HeightRequest="44"
                                                                            Padding="0"
                                                                            CommandParameter="{Binding}"
                                                                            Clicked="OnItemDecrement" />
                                                                    <Label Text="{Binding Quantity}"
                                                                           FontSize="15"
                                                                           TextColor="White"
                                                                           VerticalTextAlignment="Center"
                                                                           HorizontalTextAlignment="Center"
                                                                           MinimumWidthRequest="28" />
                                                                    <Button Text="+"
                                                                            BackgroundColor="#374151"
                                                                            TextColor="#22C55E"
                                                                            BorderColor="#4B5563"
                                                                            BorderWidth="1"
                                                                            CornerRadius="4"
                                                                            FontSize="18"
                                                                            WidthRequest="44"
                                                                            HeightRequest="44"
                                                                            Padding="0"
                                                                            CommandParameter="{Binding}"
                                                                            Clicked="OnItemIncrement" />
                                                                </HorizontalStackLayout>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Troop Types section -->
                    <Border x:Name="TroopTypesBorder"
                            StrokeThickness="1"
                            Padding="12"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Troop Types" FontSize="18" FontAttributes="Bold" />

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Source={x:Reference MarketplacesRoot}, Path=TroopTypeRows}"
                                                 Spacing="4">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border Stroke="#374151"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 4"
                                                BackgroundColor="#1F2937"
                                                Padding="12,10"
                                                MinimumHeightRequest="52">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowTroopTypeCommand}"
                                                    CommandParameter="{Binding}" />
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <VerticalStackLayout Grid.Column="0"
                                                                     Spacing="2"
                                                                     VerticalOptions="Center">
                                                    <Label Text="{Binding DisplayName}"
                                                           FontSize="15"
                                                           FontAttributes="Bold"
                                                           TextColor="White" />
                                                    <Label Text="{Binding StatDisplay}"
                                                           FontSize="13"
                                                           TextColor="#9CA3AF" />
                                                    <Label Text="{Binding CostDisplay}"
                                                           FontSize="13"
                                                           TextColor="#22C55E" />
                                                    <Label Text="{Binding Abilities}"
                                                           FontSize="12"
                                                           TextColor="#6B7280"
                                                           LineBreakMode="WordWrap"
                                                           IsVisible="{Binding HasAbilities}" />
                                                </VerticalStackLayout>
                                                <HorizontalStackLayout Grid.Column="1"
                                                                       IsVisible="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowQuantityControls}"
                                                                       Spacing="6"
                                                                       VerticalOptions="Center">
                                                    <Button Text="−"
                                                            BackgroundColor="#374151"
                                                            TextColor="#EF4444"
                                                            BorderColor="#4B5563"
                                                            BorderWidth="1"
                                                            CornerRadius="4"
                                                            FontSize="18"
                                                            WidthRequest="44"
                                                            HeightRequest="44"
                                                            Padding="0"
                                                            CommandParameter="{Binding}"
                                                            Clicked="OnTroopDecrement" />
                                                    <Label Text="{Binding Quantity}"
                                                           FontSize="15"
                                                           TextColor="White"
                                                           VerticalTextAlignment="Center"
                                                           HorizontalTextAlignment="Center"
                                                           MinimumWidthRequest="28" />
                                                    <Button Text="+"
                                                            BackgroundColor="#374151"
                                                            TextColor="#22C55E"
                                                            BorderColor="#4B5563"
                                                            BorderWidth="1"
                                                            CornerRadius="4"
                                                            FontSize="18"
                                                            WidthRequest="44"
                                                            HeightRequest="44"
                                                            Padding="0"
                                                            CommandParameter="{Binding}"
                                                            Clicked="OnTroopIncrement" />
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Augments section -->
                    <Border x:Name="AugmentsBorder"
                            StrokeThickness="1"
                            Padding="12"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Augments" FontSize="18" FontAttributes="Bold" />

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Source={x:Reference MarketplacesRoot}, Path=AugmentRows}"
                                                 Spacing="4">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border Stroke="#374151"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 4"
                                                BackgroundColor="#1F2937"
                                                Padding="12,10"
                                                MinimumHeightRequest="52">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowAugmentCommand}"
                                                    CommandParameter="{Binding}" />
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <VerticalStackLayout Grid.Column="0"
                                                                     Spacing="2"
                                                                     VerticalOptions="Center">
                                                    <Label Text="{Binding Name}"
                                                           FontSize="15"
                                                           FontAttributes="Bold"
                                                           TextColor="White" />
                                                    <Label Text="{Binding RequirementDisplay}"
                                                           FontSize="13"
                                                           TextColor="#9CA3AF"
                                                           IsVisible="{Binding HasRequirement}" />
                                                    <Label Text="{Binding CostDisplay}"
                                                           FontSize="13"
                                                           TextColor="#22C55E" />
                                                </VerticalStackLayout>
                                                <HorizontalStackLayout Grid.Column="1"
                                                                       IsVisible="{Binding Source={x:Reference MarketplacesRoot}, Path=ShowQuantityControls}"
                                                                       Spacing="6"
                                                                       VerticalOptions="Center">
                                                    <Button Text="−"
                                                            BackgroundColor="#374151"
                                                            TextColor="#EF4444"
                                                            BorderColor="#4B5563"
                                                            BorderWidth="1"
                                                            CornerRadius="4"
                                                            FontSize="18"
                                                            WidthRequest="44"
                                                            HeightRequest="44"
                                                            Padding="0"
                                                            CommandParameter="{Binding}"
                                                            Clicked="OnAugmentDecrement" />
                                                    <Label Text="{Binding Quantity}"
                                                           FontSize="15"
                                                           TextColor="White"
                                                           VerticalTextAlignment="Center"
                                                           HorizontalTextAlignment="Center"
                                                           MinimumWidthRequest="28" />
                                                    <Button Text="+"
                                                            BackgroundColor="#374151"
                                                            TextColor="#22C55E"
                                                            BorderColor="#4B5563"
                                                            BorderWidth="1"
                                                            CornerRadius="4"
                                                            FontSize="18"
                                                            WidthRequest="44"
                                                            HeightRequest="44"
                                                            Padding="0"
                                                            CommandParameter="{Binding}"
                                                            Clicked="OnAugmentIncrement" />
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Item detail popup overlay — covers the full page -->
        <Grid x:Name="MarketplacePopupOverlay"
              Grid.Row="0" Grid.RowSpan="2"
              IsVisible="False"
              BackgroundColor="#D0111827">
            <Border BackgroundColor="#1F2937"
                    Stroke="#374151"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Margin="16,60,16,24">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="Auto,*"
                          BackgroundColor="#374151"
                          Padding="4,4">
                        <Button x:Name="PopupBackButton"
                                Grid.Column="0"
                                Text="← Back"
                                BackgroundColor="Transparent"
                                BorderColor="Transparent"
                                TextColor="#22C55E"
                                FontAttributes="Bold"
                                Padding="8,0"
                                Clicked="OnPopupBackClicked" />
                        <Label x:Name="PopupTitleLabel"
                               Grid.Column="1"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalTextAlignment="Center"
                               Padding="4,0,8,0"
                               LineBreakMode="TailTruncation" />
                    </Grid>
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout x:Name="PopupContentArea"
                                             Padding="16,12"
                                             Spacing="6" />
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>

    </Grid>

</ContentPage>
