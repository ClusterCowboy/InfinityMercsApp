<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.PerkTesterPage"
             x:Name="PerkTesterPageRoot"
             Title="Perk Tester">

    <Grid Padding="16" ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="0.8*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" RowDefinitions="*,*" RowSpacing="12">
            <Border Grid.Row="0" StrokeThickness="1" Padding="10">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                    <Label
                        Text="Factions"
                        FontSize="20"
                        FontAttributes="Bold" />

                    <HorizontalStackLayout Grid.Row="1" Spacing="8" VerticalOptions="Center">
                        <RadioButton Content="All" IsChecked="{Binding ShowAllFactionEntries}" />
                        <RadioButton Content="Factions" IsChecked="{Binding ShowFactionEntriesOnly}" />
                        <RadioButton Content="Sectorials" IsChecked="{Binding ShowSectorialEntriesOnly}" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout Grid.Row="2" Spacing="2">
                        <ActivityIndicator
                            IsRunning="{Binding IsLoading}"
                            IsVisible="{Binding IsLoading}"
                            HorizontalOptions="Start" />
                        <Label
                            Text="{Binding Status}"
                            FontSize="12"
                            TextColor="#6B7280" />
                    </VerticalStackLayout>

                    <ScrollView Grid.Row="3" x:Name="FactionScrollView">
                        <ScrollView.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnFactionListPanUpdated" />
                        </ScrollView.GestureRecognizers>
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Factions}" Spacing="0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <controls:ViewerListRowView
                                        ItemTappedCommand="{Binding Source={x:Reference PerkTesterPageRoot}, Path=BindingContext.SelectFactionCommand}"
                                        ItemTappedCommandParameter="{Binding .}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>

            <Border Grid.Row="1" StrokeThickness="1" Padding="12">
                <Grid RowDefinitions="Auto,*" RowSpacing="8">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Text="Units" Command="{Binding ShowUnitsTabCommand}" CornerRadius="8">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding ShowUnitsTab}" Value="True">
                                    <Setter Property="TextColor" Value="White" />
                                    <Setter Property="BorderColor" Value="#22C55E" />
                                    <Setter Property="BorderWidth" Value="3" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding ShowUnitsTab}" Value="False">
                                    <Setter Property="TextColor" Value="White" />
                                    <Setter Property="BorderColor" Value="#22C55E" />
                                    <Setter Property="BorderWidth" Value="2" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Grid.Column="1" Text="Fireteams" Command="{Binding ShowFireteamsTabCommand}" CornerRadius="8">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding ShowFireteamsTab}" Value="True">
                                    <Setter Property="TextColor" Value="White" />
                                    <Setter Property="BorderColor" Value="#22C55E" />
                                    <Setter Property="BorderWidth" Value="3" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding ShowFireteamsTab}" Value="False">
                                    <Setter Property="TextColor" Value="White" />
                                    <Setter Property="BorderColor" Value="#22C55E" />
                                    <Setter Property="BorderWidth" Value="2" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*" RowSpacing="8" IsVisible="{Binding ShowUnitsTab}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="Units" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
                            <Border
                                Grid.Column="1"
                                x:Name="UnitSelectionFilterButton"
                                StrokeThickness="0"
                                BackgroundColor="Transparent"
                                Padding="2"
                                VerticalOptions="Center"
                                HorizontalOptions="End">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnUnitSelectionFilterButtonTapped" />
                                </Border.GestureRecognizers>
                                <skia:SKCanvasView
                                    x:Name="UnitSelectionFilterCanvas"
                                    WidthRequest="20"
                                    HeightRequest="20"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    PaintSurface="OnUnitSelectionFilterCanvasPaintSurface" />
                            </Border>
                        </Grid>
                        <Label Grid.Row="1" Text="{Binding UnitsStatus}" TextColor="#6B7280" />
                        <ScrollView Grid.Row="2" x:Name="UnitScrollView">
                            <ScrollView.GestureRecognizers>
                                <PanGestureRecognizer PanUpdated="OnUnitListPanUpdated" />
                            </ScrollView.GestureRecognizers>
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Units}" Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <controls:ViewerListRowView
                                            ItemTappedCommand="{Binding Source={x:Reference PerkTesterPageRoot}, Path=BindingContext.SelectUnitCommand}"
                                            ItemTappedCommandParameter="{Binding .}" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </ScrollView>
                    </Grid>

                    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8" IsVisible="{Binding ShowFireteamsTab}">
                        <Label Text="Fireteams" FontSize="20" FontAttributes="Bold" />
                        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="DUO" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding FireteamDuoCount}" FontSize="18" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="HARIS" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding FireteamHarisCount}" FontSize="18" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="2">
                                <Label Text="CORE" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding FireteamCoreCount}" FontSize="18" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Grid>
                        <Label Grid.Row="2" Text="{Binding FireteamsStatus}" TextColor="#6B7280" />
                        <ScrollView Grid.Row="3">
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Fireteams}" Spacing="8">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border StrokeThickness="1" Padding="10">
                                            <VerticalStackLayout Spacing="6">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                                <Label Text="{Binding TeamTypes, StringFormat='Types: {0}'}" />
                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                                    <Label Grid.Column="0" Text="Unit" FontAttributes="Bold" />
                                                    <Label Grid.Column="1" Text="Min" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="2" Text="Max" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                                </Grid>
                                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding UnitLimits}" Spacing="2">
                                                    <BindableLayout.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                                                <Label Grid.Column="0" Text="{Binding Name}" />
                                                                <Label Grid.Column="1" Text="{Binding Min}" HorizontalTextAlignment="Center" />
                                                                <Label Grid.Column="2" Text="{Binding Max}" HorizontalTextAlignment="Center" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </BindableLayout.ItemTemplate>
                                                </VerticalStackLayout>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </ScrollView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1" StrokeThickness="1" Padding="12">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                <controls:UnitDisplayConfigurationsView
                    Grid.Row="0"
                    x:Name="UnitDisplayConfigurationsView"
                    ShowConfigurationsSection="False"
                    UnitNameHeading="{Binding UnitNameHeading}"
                    ShowRegularOrderIcon="{Binding ShowRegularOrderIcon}"
                    ShowIrregularOrderIcon="{Binding ShowIrregularOrderIcon}"
                    ShowImpetuousIcon="{Binding ShowImpetuousIcon}"
                    ShowTacticalAwarenessIcon="{Binding ShowTacticalAwarenessIcon}"
                    ShowCubeIcon="{Binding ShowCubeIcon}"
                    ShowCube2Icon="{Binding ShowCube2Icon}"
                    ShowHackableIcon="{Binding ShowHackableIcon}"
                    UnitMov="{Binding UnitMov}"
                    UnitCc="{Binding UnitCc}"
                    UnitBs="{Binding UnitBs}"
                    UnitPh="{Binding UnitPh}"
                    UnitWip="{Binding UnitWip}"
                    UnitArm="{Binding UnitArm}"
                    UnitBts="{Binding UnitBts}"
                    UnitVitalityHeader="{Binding UnitVitalityHeader}"
                    UnitVitality="{Binding UnitVitality}"
                    UnitS="{Binding UnitS}"
                    UnitAva="{Binding UnitAva}"
                    EquipmentSummaryFormatted="{Binding EquipmentSummaryFormatted}"
                    SpecialSkillsSummaryFormatted="{Binding SpecialSkillsSummaryFormatted}" />
                <Label
                    Grid.Row="1"
                    Text="{Binding ProfilesStatus}"
                    TextColor="#6B7280" />
                <ScrollView Grid.Row="2">
                    <VerticalStackLayout
                        BindableLayout.ItemsSource="{Binding Profiles}"
                        Spacing="6">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="1" Padding="10" MinimumHeightRequest="50" IsVisible="{Binding IsVisible}">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsLieutenantBlocked}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#7F1D1D" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#9A3412" />
                                            <Setter Property="Stroke" Value="#FB923C" />
                                            <Setter Property="StrokeThickness" Value="2" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PerkTesterPageRoot}, Path=SelectProfileCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="2">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="60" />
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0" FormattedText="{Binding NameFormatted}" FontAttributes="Bold" />
                                            <HorizontalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="End" VerticalOptions="Center">
                                                <skia:SKCanvasView
                                                    WidthRequest="14"
                                                    HeightRequest="14"
                                                    VerticalOptions="Center"
                                                    IsVisible="{Binding ShowProfileTacticalAwarenessIcon}"
                                                    PaintSurface="OnProfileTacticalIconCanvasPaintSurface" />
                                                <Label Text="{Binding Cost, StringFormat='C {0}'}" FontSize="12" HorizontalTextAlignment="End" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Grid>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0" FormattedText="{Binding RangedWeaponsFormatted}" FontSize="12" TextColor="#EF4444" LineBreakMode="WordWrap" />
                                            <Label Grid.Column="1" FormattedText="{Binding MeleeWeaponsFormatted}" FontSize="12" TextColor="#22C55E" LineBreakMode="WordWrap" />
                                            <Label Grid.Column="2" FormattedText="{Binding UniqueEquipmentFormatted}" FontSize="12" TextColor="#06B6D4" LineBreakMode="WordWrap" />
                                            <Label Grid.Column="3" FormattedText="{Binding UniqueSkillsFormatted}" FontSize="12" TextColor="#F59E0B" LineBreakMode="WordWrap" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </ScrollView>
                <Grid Grid.Row="2" IsVisible="False" HeightRequest="0" WidthRequest="0">
                    <skia:SKCanvasView
                        x:Name="TopIconRowCanvas"
                        PaintSurface="OnTopIconRowCanvasPaintSurface" />
                    <skia:SKCanvasView
                        x:Name="BottomIconRowCanvas"
                        PaintSurface="OnBottomIconRowCanvasPaintSurface" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="2" StrokeThickness="1" Padding="12">
            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <Label Text="Qualified Perks" FontSize="20" FontAttributes="Bold" />
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout
                        BindableLayout.ItemsSource="{Binding Source={x:Reference PerkTesterPageRoot}, Path=QualifiedPerks}"
                        Spacing="6">
                        <BindableLayout.EmptyView>
                            <Label Text="Select a profile to view qualified perks." TextColor="#6B7280" />
                        </BindableLayout.EmptyView>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="1" Padding="8">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding PerkText}" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                        <Label Text="{Binding Meta}" FontSize="12" TextColor="#9CA3AF" LineBreakMode="WordWrap" />
                                        <Label Text="{Binding Granted}" FontSize="12" TextColor="#22C55E" LineBreakMode="WordWrap" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>

        <Grid
            x:Name="UnitFilterOverlay"
            Grid.ColumnSpan="3"
            IsVisible="False"
            BackgroundColor="#88000000"
            InputTransparent="False"
            ZIndex="100">
            <ContentView
                x:Name="UnitFilterPopupHost"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                MaximumWidthRequest="700" />
        </Grid>
    </Grid>

</ContentPage>
