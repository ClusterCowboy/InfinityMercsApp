<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="InfinityMercsApp.Views.CompanyViewerPage"
             x:Name="CompanyViewerRoot"
             Title="Company Viewer">

    <Grid Padding="16" RowDefinitions="Auto,*" RowSpacing="6">
        <Border Grid.Row="0" StrokeThickness="0" Padding="0">
            <Border.GestureRecognizers>
                <PointerGestureRecognizer
                    PointerPressed="OnCompanyStripPointerPressed"
                    PointerMoved="OnCompanyStripPointerMoved"
                    PointerReleased="OnCompanyStripPointerReleased" />
            </Border.GestureRecognizers>
            <Grid RowDefinitions="*" RowSpacing="0">
                <ScrollView x:Name="CompanyUnitsScrollView"
                            Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <ScrollView.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnCompanyUnitsStripPanUpdated" />
                    </ScrollView.GestureRecognizers>
                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Source={x:Reference CompanyViewerRoot}, Path=CompanyUnits}"
                                           Spacing="8"
                                           Padding="0,0,2,0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <controls:CompanyViewerUnitTileView
                                    ItemTappedCommand="{Binding Source={x:Reference CompanyViewerRoot}, Path=SelectCompanyUnitCommand}"
                                    ItemTappedCommandParameter="{Binding .}" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </Grid>
        </Border>

        <Border Grid.Row="1" StrokeThickness="0" Padding="12">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <VerticalStackLayout Grid.Row="0" Spacing="3" VerticalOptions="Center">
                        <!-- Readout eyebrow: class designation of the locked unit (LI / MI / HI / TAG / REM). -->
                        <HorizontalStackLayout Spacing="6"
                                               IsVisible="{Binding Source={x:Reference CompanyViewerRoot}, Path=HasSelectedUnitTypeHeading}">
                            <BoxView WidthRequest="8" HeightRequest="8" VerticalOptions="Center"
                                     BackgroundColor="{StaticResource Signal}" />
                            <Label Text="{Binding Source={x:Reference CompanyViewerRoot}, Path=SelectedUnitTypeHeading}"
                                   Style="{StaticResource LabelCaption}"
                                   TextColor="{StaticResource Signal}"
                                   CharacterSpacing="3"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Grid x:Name="SelectedNameDisplayRow" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label x:Name="SelectedNameLabel" Grid.Column="0" Text="{Binding Source={x:Reference CompanyViewerRoot}, Path=SelectedCaptainNameHeading}" FontSize="{DynamicResource FontSizeDisplay}" FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSelectedNameLabelTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                            <skia:SKCanvasView
                                x:Name="SelectedNameEditCanvas"
                                Grid.Column="1"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center"
                                PaintSurface="OnSelectedNameEditCanvasPaintSurface" />
                        </Grid>
                        <Grid x:Name="SelectedNameEditRow" IsVisible="False" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <Entry x:Name="SelectedNameEntry" Grid.Column="0" FontSize="{DynamicResource FontSizeDisplay}" />
                            <skia:SKCanvasView
                                x:Name="SelectedNameSaveCanvas"
                                Grid.Column="1"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center"
                                PaintSurface="OnSelectedNameSaveCanvasPaintSurface" />
                            <skia:SKCanvasView
                                x:Name="SelectedNameRejectCanvas"
                                Grid.Column="2"
                                WidthRequest="36"
                                HeightRequest="36"
                                VerticalOptions="Center"
                                PaintSurface="OnSelectedNameRejectCanvasPaintSurface" />
                        </Grid>
                        <Label Text="{Binding Source={x:Reference CompanyViewerRoot}, Path=SelectedProfileBaseNameHeading}"
                               FontSize="{DynamicResource FontSizeTitleSmall}"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Start"
                               IsVisible="{Binding Source={x:Reference CompanyViewerRoot}, Path=HasSelectedProfileBaseNameHeading}" />
                    </VerticalStackLayout>

                    <controls:UnitDisplayConfigurationsView
                        Grid.Row="1"
                        x:Name="UnitDisplayConfigurationsView"
                        UnitNameHeading="{Binding UnitNameHeading}"
                        ShowRegularOrderIcon="{Binding ShowRegularOrderIcon}"
                        ShowIrregularOrderIcon="{Binding ShowIrregularOrderIcon}"
                        ShowImpetuousIcon="{Binding ShowImpetuousIcon}"
                        ShowTacticalAwarenessIcon="{Binding ShowTacticalAwarenessIcon}"
                        ShowCubeIcon="{Binding ShowCubeIcon}"
                        ShowCube2Icon="{Binding ShowCube2Icon}"
                        ShowHackableIcon="{Binding ShowHackableIcon}"
                        UnitMov="{Binding UnitMov}"
                        UnitCc="{Binding UnitCc}"
                        UnitBs="{Binding UnitBs}"
                        UnitPh="{Binding UnitPh}"
                        UnitWip="{Binding UnitWip}"
                        UnitArm="{Binding UnitArm}"
                        UnitBts="{Binding UnitBts}"
                        UnitVitalityHeader="{Binding UnitVitalityHeader}"
                        UnitVitality="{Binding UnitVitality}"
                        UnitS="{Binding UnitS}"
                        UnitAva="{Binding UnitAva}"
                        ShowConfigurationsSection="False"
                        ShowSummaryRows="False"
                        EquipmentSummaryFormatted="{Binding EquipmentSummaryFormatted}"
                        SpecialSkillsSummaryFormatted="{Binding SpecialSkillsSummaryFormatted}" />

                    <ScrollView Grid.Row="2">
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" VerticalOptions="Center">
                                <Label Text="WEAPONS"
                                       Style="{StaticResource LabelCaption}"
                                       TextColor="{StaticResource TextMuted}"
                                       CharacterSpacing="3"
                                       VerticalOptions="Center" />
                                <BoxView Grid.Column="1" HeightRequest="1" VerticalOptions="Center"
                                         BackgroundColor="{StaticResource Hairline}" />
                            </Grid>
                            <Label FormattedText="{Binding Source={x:Reference CompanyViewerRoot}, Path=CurrentRangedWeaponsFormatted}" FontSize="{DynamicResource FontSizeBody}" LineBreakMode="WordWrap" />
                            <Label FormattedText="{Binding Source={x:Reference CompanyViewerRoot}, Path=CurrentMeleeWeaponsFormatted}" FontSize="{DynamicResource FontSizeBody}" LineBreakMode="WordWrap" />
                            <Label FormattedText="{Binding Source={x:Reference CompanyViewerRoot}, Path=CurrentPeripheralsFormatted}" FontSize="{DynamicResource FontSizeBody}" LineBreakMode="WordWrap" IsVisible="{Binding Source={x:Reference CompanyViewerRoot}, Path=HasCurrentPeripherals}" />
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
        </Border>
    </Grid>

</ContentPage>
