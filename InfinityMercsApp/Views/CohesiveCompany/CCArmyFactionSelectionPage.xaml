<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:shell="clr-namespace:Microsoft.Maui.Controls;assembly=Microsoft.Maui.Controls"
             x:Class="InfinityMercsApp.Views.CohesiveCompany.CCArmyFactionSelectionPage"
             x:Name="ArmyFactionSelectionRoot"
             Title="">

    <shell:Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
            <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                <Border StrokeThickness="2" Stroke="{Binding LeftSlotBorderColor}" Padding="8,4">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLeftSlotTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="34,*" ColumnSpacing="8">
                        <skia:SKCanvasView
                            x:Name="LeftSlotCanvas"
                            Grid.Column="0"
                            WidthRequest="28"
                            HeightRequest="28"
                            VerticalOptions="Center"
                            PaintSurface="OnLeftSlotCanvasPaintSurface" />
                        <Label
                            Grid.Column="1"
                            Text="{Binding LeftSlotText}"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>
                <Border StrokeThickness="2" Stroke="{Binding RightSlotBorderColor}" Padding="8,4" IsVisible="{Binding ShowRightSelectionBox}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRightSlotTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="34,*" ColumnSpacing="8">
                        <skia:SKCanvasView
                            x:Name="RightSlotCanvas"
                            Grid.Column="0"
                            WidthRequest="28"
                            HeightRequest="28"
                            VerticalOptions="Center"
                            PaintSurface="OnRightSlotCanvasPaintSurface" />
                        <Label
                            Grid.Column="1"
                            Text="{Binding RightSlotText}"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>
            </HorizontalStackLayout>
            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                <Label
                    WidthRequest="70"
                    Text="{Binding SeasonPointsCapText}"
                    VerticalOptions="Center" />
                <Label Text="/" VerticalOptions="Center" />
                <Picker
                    WidthRequest="80"
                    SelectedItem="{Binding SelectedStartSeasonPoints}">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>60</x:String>
                            <x:String>75</x:String>
                            <x:String>90</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
                <Label Text="Points to start season" VerticalOptions="Center" />
                <skia:SKCanvasView
                    x:Name="SeasonValidationCanvas"
                    WidthRequest="24"
                    HeightRequest="24"
                    VerticalOptions="Center"
                    PaintSurface="OnSeasonValidationCanvasPaintSurface" />
            </HorizontalStackLayout>
        </Grid>
    </shell:Shell.TitleView>

    <Grid Padding="16" ColumnDefinitions="0.82*,1.18*" ColumnSpacing="12" RowSpacing="10">

        <Grid Grid.Column="0">
                <Grid IsVisible="{Binding IsFactionSelectionActive}" RowDefinitions="*,Auto" RowSpacing="10">
                    <Border Grid.Row="0" StrokeThickness="1" Padding="10">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <Border Grid.Row="0" Padding="12,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFactionSelectionHeaderTapped" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsFactionSelectionActive}" Value="True">
                                        <Setter Property="BackgroundColor" Value="Black" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsFactionSelectionActive}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label
                                    Text="FACTION SELECTION"
                                    FontSize="24"
                                    FontAttributes="Bold"
                                    HorizontalTextAlignment="Start">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsFactionSelectionActive}" Value="True">
                                            <Setter Property="TextColor" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsFactionSelectionActive}" Value="False">
                                            <Setter Property="TextColor" Value="#A78BFA" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>

                            <ScrollView Grid.Row="1">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Factions}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <controls:FactionListItemView
                                                ItemTappedCommand="{Binding Source={x:Reference ArmyFactionSelectionRoot}, Path=BindingContext.SelectFactionCommand}"
                                                ItemTappedCommandParameter="{Binding .}" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </ScrollView>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" StrokeThickness="1" Padding="10">
                        <Grid ColumnDefinitions="*" ColumnSpacing="10" VerticalOptions="Center">
                            <Border Grid.Column="0" x:Name="UnitSelectionHeaderBorderInactive" Padding="12,8,0,8" SizeChanged="OnUnitSelectionHeaderBorderSizeChanged">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnUnitSelectionHeaderTapped" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsUnitSelectionActive}" Value="True">
                                        <Setter Property="BackgroundColor" Value="Black" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsUnitSelectionActive}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                    <Label
                                        Grid.Column="0"
                                        Text="UNIT SELECTION"
                                        FontSize="24"
                                        FontAttributes="Bold"
                                        HorizontalTextAlignment="Start"
                                        VerticalTextAlignment="Center"
                                        VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsUnitSelectionActive}" Value="True">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsUnitSelectionActive}" Value="False">
                                                <Setter Property="TextColor" Value="#A78BFA" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border
                                        Grid.Column="1"
                                        x:Name="UnitSelectionFilterButtonInactive"
                                        IsVisible="{Binding IsUnitSelectionActive}"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        Padding="2"
                                        Margin="0,0,12,0"
                                        VerticalOptions="Center"
                                        HorizontalOptions="End">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnUnitSelectionFilterButtonTapped" />
                                        </Border.GestureRecognizers>
                                        <skia:SKCanvasView
                                            x:Name="UnitSelectionFilterCanvasInactive"
                                            WidthRequest="20"
                                            HeightRequest="20"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Center"
                                            PaintSurface="OnUnitSelectionFilterCanvasPaintSurface" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Grid IsVisible="{Binding IsUnitSelectionActive}" RowDefinitions="Auto,*" RowSpacing="10">
                    <Border Grid.Row="0" StrokeThickness="1" Padding="10">
                        <Border Padding="12,8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFactionSelectionHeaderTapped" />
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsFactionSelectionActive}" Value="True">
                                    <Setter Property="BackgroundColor" Value="Black" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsFactionSelectionActive}" Value="False">
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label
                                Text="FACTION SELECTION"
                                FontSize="24"
                                FontAttributes="Bold"
                                HorizontalTextAlignment="Start">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsFactionSelectionActive}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsFactionSelectionActive}" Value="False">
                                        <Setter Property="TextColor" Value="#A78BFA" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </Border>

                    <Border Grid.Row="1" StrokeThickness="1" Padding="10">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <Grid Grid.Row="0" ColumnDefinitions="*" ColumnSpacing="10" VerticalOptions="Center">
                                <Border Grid.Column="0" x:Name="UnitSelectionHeaderBorderActive" Padding="12,8,0,8" SizeChanged="OnUnitSelectionHeaderBorderSizeChanged">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnUnitSelectionHeaderTapped" />
                                    </Border.GestureRecognizers>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsUnitSelectionActive}" Value="True">
                                            <Setter Property="BackgroundColor" Value="Black" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsUnitSelectionActive}" Value="False">
                                            <Setter Property="BackgroundColor" Value="Transparent" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                        <Label
                                            Grid.Column="0"
                                            Text="UNIT SELECTION"
                                            FontSize="24"
                                            FontAttributes="Bold"
                                            HorizontalTextAlignment="Start"
                                            VerticalTextAlignment="Center"
                                            VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsUnitSelectionActive}" Value="True">
                                                    <Setter Property="TextColor" Value="White" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsUnitSelectionActive}" Value="False">
                                                    <Setter Property="TextColor" Value="#A78BFA" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Border
                                            Grid.Column="1"
                                            x:Name="UnitSelectionFilterButtonActive"
                                            IsVisible="{Binding IsUnitSelectionActive}"
                                            StrokeThickness="0"
                                            BackgroundColor="Transparent"
                                            Padding="2"
                                            Margin="0,0,12,0"
                                            VerticalOptions="Center"
                                            HorizontalOptions="End">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnUnitSelectionFilterButtonTapped" />
                                            </Border.GestureRecognizers>
                                            <skia:SKCanvasView
                                                x:Name="UnitSelectionFilterCanvasActive"
                                                WidthRequest="20"
                                                HeightRequest="20"
                                                VerticalOptions="Center"
                                                HorizontalOptions="Center"
                                                PaintSurface="OnUnitSelectionFilterCanvasPaintSurface" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>

                            <ScrollView Grid.Row="1" IsVisible="{Binding ShowUnitsList}">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Units}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <controls:FactionListItemView
                                                ItemTapped="OnUnitItemTappedFromView"
                                                IsVisible="{Binding IsVisible}" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </ScrollView>

                            <ScrollView Grid.Row="1" IsVisible="{Binding ShowTeamsList}">
                                <VerticalStackLayout Spacing="0">
                                    <Label
                                        Text="One Core fireteam per company"
                                        FontAttributes="Bold"
                                        Margin="8,6,8,8" />
                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding TeamEntries}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border StrokeThickness="1" Padding="8,6" MinimumHeightRequest="50" IsVisible="{Binding IsVisible}">
                                                <VerticalStackLayout Spacing="4">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                        <Label
                                                            Grid.Column="0"
                                                            Text="{Binding Name}"
                                                            VerticalOptions="Center" />
                                                        <RadioButton
                                                            Grid.Column="1"
                                                            VerticalOptions="Center"
                                                            GroupName="CohesiveCoreFireteamSelection"
                                                            IsVisible="{Binding ShowTrackingRadioButton}"
                                                            IsChecked="{Binding IsTrackedTeam, Mode=TwoWay}"
                                                            CheckedChanged="OnTeamTrackingRadioButtonCheckedChanged" />
                                                    </Grid>
                                                    <VerticalStackLayout Spacing="3">
                                                        <Grid ColumnDefinitions="44,44,*" ColumnSpacing="8">
                                                            <Label Grid.Column="0" Text="MIN" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                                            <Label Grid.Column="1" Text="MAX" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                                            <Label Grid.Column="2" Text="UNIT" FontAttributes="Bold" />
                                                        </Grid>
                                                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding AllowedProfiles}" Spacing="2">
                                                            <BindableLayout.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid ColumnDefinitions="44,44,*" ColumnSpacing="8" IsVisible="{Binding IsVisible}" MinimumHeightRequest="50">
                                                                        <Label Grid.Column="0" Text="{Binding Min}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" VerticalOptions="Center" />
                                                                        <Label Grid.Column="1" Text="{Binding Max}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" VerticalOptions="Center" />
                                                                        <controls:FactionListItemView
                                                                            Grid.Column="2"
                                                                            ItemTapped="OnTeamAllowedProfileTappedFromView" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </BindableLayout.ItemTemplate>
                                                        </VerticalStackLayout>
                                                    </VerticalStackLayout>
                                                </VerticalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </ScrollView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        <Grid Grid.Column="1" RowDefinitions="*,*" RowSpacing="10">
        <!-- Reusable unit header + configurations panel shared with vanilla faction selection page. -->
        <controls:UnitDisplayConfigurationsView x:Name="UnitDisplayConfigurationsView" Grid.Row="0" />

        <Border Grid.Row="1" StrokeThickness="1" Padding="10">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                    <Label
                        Grid.Column="0"
                        Text="Mercs Company"
                        FontSize="20"
                        FontAttributes="Bold"
                        VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="-" VerticalOptions="Center" />
                    <Border Grid.Column="2" Stroke="{Binding CompanyNameBorderColor}" StrokeThickness="2" Padding="2,0">
                        <Entry
                            WidthRequest="220"
                            Text="{Binding CompanyName}"
                            Placeholder="Company Name"
                            ClearButtonVisibility="WhileEditing"
                            VerticalOptions="Center" />
                    </Border>
                    <Label
                        Grid.Column="3"
                        Text="Enter Company Name"
                        TextColor="#EF4444"
                        VerticalOptions="Center"
                        IsVisible="{Binding ShowCompanyNameValidationError}" />
                    <Label
                        Grid.Column="4"
                        Text="{Binding TrackedFireteamNameDisplay}"
                        VerticalOptions="Center"
                        HorizontalOptions="Fill"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="TailTruncation"
                        MaxLines="1" />
                    <Grid
                        Grid.Column="5"
                        WidthRequest="50"
                        HeightRequest="50"
                        Margin="0,0,4,0"
                        VerticalOptions="Center"
                        HorizontalOptions="End">
                        <skia:SKCanvasView
                            x:Name="TrackedFireteamLevelCanvas"
                            WidthRequest="50"
                            HeightRequest="50"
                            PaintSurface="OnTrackedFireteamLevelCanvasPaintSurface" />
                    </Grid>
                </Grid>
                <CollectionView
                    Grid.Row="1"
                    ItemsSource="{Binding MercsCompanyEntries}"
                    SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="1" Padding="8" Margin="0,0,0,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference ArmyFactionSelectionRoot}, Path=BindingContext.SelectMercsCompanyEntryCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsLieutenant}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#004219" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsLieutenant}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                                    <controls:FactionListItemView Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" TitleFormatted="{Binding NameFormatted}" />
                                    <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="8" VerticalOptions="Start" HorizontalOptions="End">
                                        <Label Text="{Binding CostDisplay}" VerticalOptions="Center" />
                                        <Button
                                            Text="X"
                                            WidthRequest="28"
                                            HeightRequest="28"
                                            Padding="0"
                                            FontAttributes="Bold"
                                            VerticalOptions="Start"
                                            HorizontalOptions="End"
                                            Command="{Binding Source={x:Reference ArmyFactionSelectionRoot}, Path=BindingContext.RemoveMercsCompanyEntryCommand}"
                                            CommandParameter="{Binding .}" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" FormattedText="{Binding EquipmentLineFormatted}" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" IsVisible="{Binding HasEquipmentLine}" />
                                    <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" FormattedText="{Binding SkillsLineFormatted}" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" IsVisible="{Binding HasSkillsLine}" />
                                    <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" FormattedText="{Binding RangedLineFormatted}" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" />
                                    <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" FormattedText="{Binding CcLineFormatted}" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" />
                                    <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" BackgroundColor="#111827" Stroke="#4B5563" StrokeThickness="1" Padding="6,4" IsVisible="{Binding HasPeripheralStatBlock}">
                                        <VerticalStackLayout Spacing="4">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                                <skia:SKCanvasView
                                                    Grid.Column="0"
                                                    WidthRequest="18"
                                                    HeightRequest="18"
                                                    VerticalOptions="Center"
                                                    PaintSurface="OnPeripheralIconCanvasPaintSurface" />
                                                <Label Grid.Column="1" Text="{Binding PeripheralNameHeading}" FontSize="12" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                                            </Grid>
                                            <Label Text="{Binding PeripheralSubtitle}" FontSize="12" TextColor="#9CA3AF" LineBreakMode="WordWrap" />
                                            <Label
                                                FormattedText="{Binding PeripheralEquipmentLineFormatted}"
                                                TextColor="White"
                                                FontSize="12"
                                                LineBreakMode="WordWrap"
                                                HorizontalOptions="FillAndExpand"
                                                IsVisible="{Binding HasPeripheralEquipmentLine}" />
                                            <Label
                                                FormattedText="{Binding PeripheralSkillsLineFormatted}"
                                                TextColor="White"
                                                FontSize="12"
                                                LineBreakMode="WordWrap"
                                                HorizontalOptions="FillAndExpand"
                                                IsVisible="{Binding HasPeripheralSkillsLine}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="No units added yet." TextColor="#6B7280" />
                    </CollectionView.EmptyView>
                </CollectionView>
                <Button
                    Grid.Row="2"
                    Text="START COMPANY"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Command="{Binding StartCompanyCommand}"
                    IsEnabled="{Binding IsCompanyValid}" />
            </Grid>
        </Border>
        </Grid>

        <Grid
            x:Name="UnitFilterOverlay"
            Grid.ColumnSpan="2"
            IsVisible="False"
            BackgroundColor="#88000000"
            InputTransparent="False"
            ZIndex="100">
            <ContentView
                x:Name="UnitFilterPopupHost"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                MaximumWidthRequest="700" />
        </Grid>
    </Grid>
</ContentPage>

