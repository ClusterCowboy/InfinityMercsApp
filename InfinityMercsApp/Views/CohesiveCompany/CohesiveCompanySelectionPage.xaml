<?xml version="1.0" encoding="utf-8" ?>
<templates:CompanySelectionPageBase xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:InfinityMercsApp.Views.Controls"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:shell="clr-namespace:Microsoft.Maui.Controls;assembly=Microsoft.Maui.Controls"
             xmlns:templates="clr-namespace:InfinityMercsApp.Views.Common"
             x:Class="InfinityMercsApp.Views.CohesiveCompany.CohesiveCompanySelectionPage"
             x:Name="ArmyFactionSelectionRoot"
             Title="">

    <shell:Shell.TitleView>
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" VerticalOptions="Center">
            <controls:AddFactionButtonView
                x:Name="AddFactionButton"
                Grid.Column="0"
                Tapped="OnToggleFactionStripTapped" />
            <controls:FactionSlotSelectorView
                x:Name="FactionSlotSelectorView"
                Grid.Column="1"
                VerticalOptions="Center"
                ShowRightSelectionBox="{Binding ShowRightSelectionBox}" />
            <controls:SeasonStartPointsView
                x:Name="SeasonStartPointsView"
                Grid.Column="2"
                VerticalOptions="Center"
                SeasonPointsCapText="{Binding SeasonPointsCapText}"
                SelectedStartSeasonPoints="{Binding SelectedStartSeasonPoints}"
                IsCompanyValid="{Binding IsCompanyValid}" />
        </Grid>
    </shell:Shell.TitleView>

    <Grid x:Name="MainContentGrid" Padding="2,2,2,0" ColumnDefinitions="0.82*,1.18*" RowDefinitions="Auto,Auto,*" ColumnSpacing="12" RowSpacing="10">

        <controls:FactionSelectionStripView
            Grid.Row="0"
            Grid.ColumnSpan="2"
            IsVisible="{Binding ShowFactionStrip}"
            ItemsSource="{Binding Factions}"
            SelectFactionCommand="{Binding SelectFactionCommand}" />

        <!-- Compact-only: top-of-content faction icon button that reopens the selector overlay. -->
        <controls:SelectedFactionButtonView
            x:Name="SelectedFactionButton"
            Grid.Row="0"
            Grid.ColumnSpan="2"
            IsVisible="False"
            ShowRightSlot="{Binding ShowRightSelectionBox}"
            Tapped="OnSelectedFactionButtonTapped" />

        <!-- Compact-only workspace switch: shows the units list, the selected-unit detail, or the company roster. -->
        <Grid x:Name="CompactTabBar"
              Grid.Row="1"
              Grid.ColumnSpan="2"
              ColumnDefinitions="*,*,*"
              ColumnSpacing="8"
              IsVisible="False">
            <Button x:Name="UnitsTabButton"
                    Grid.Column="0"
                    Text="UNITS"
                    Clicked="OnShowUnitsTabTapped" />
            <Button x:Name="ProfileTabButton"
                    Grid.Column="1"
                    Text="PROFILE"
                    Clicked="OnShowProfileTabTapped" />
            <Button x:Name="CompanyTabButton"
                    Grid.Column="2"
                    Text="COMPANY"
                    Clicked="OnShowCompanyTabTapped" />
        </Grid>

        <Grid x:Name="UnitsPane" Grid.Row="2" Grid.Column="0">
                <Grid VerticalOptions="FillAndExpand">
                    <Border StrokeThickness="0" Padding="0" VerticalOptions="FillAndExpand">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8" VerticalOptions="FillAndExpand">
                            <controls:CompanyUnitSelectionListPanelView
                                x:Name="UnitSelectionPanel"
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                VerticalOptions="FillAndExpand"
                                ShowUnitsList="{Binding ShowUnitsList}"
                                IsDense="{Binding IsCompact}"
                                ItemsSource="{Binding Units}"
                                ItemTappedCommand="{Binding SelectUnitCommand}"
                                HeaderBorderSizeChanged="OnUnitSelectionHeaderBorderSizeChanged"
                                FilterButtonTapped="OnUnitSelectionFilterButtonTapped"
                                FilterCanvasPaintSurface="OnUnitSelectionFilterCanvasPaintSurface">
                                <controls:CompanyUnitSelectionListPanelView.Triggers>
                                    <DataTrigger
                                        TargetType="controls:CompanyUnitSelectionListPanelView"
                                        Binding="{Binding ShowUnitsList}"
                                        Value="True">
                                        <Setter Property="Grid.RowSpan" Value="2" />
                                    </DataTrigger>
                                    <DataTrigger
                                        TargetType="controls:CompanyUnitSelectionListPanelView"
                                        Binding="{Binding ShowUnitsList}"
                                        Value="False">
                                        <Setter Property="Grid.RowSpan" Value="1" />
                                    </DataTrigger>
                                </controls:CompanyUnitSelectionListPanelView.Triggers>
                            </controls:CompanyUnitSelectionListPanelView>

                            <ScrollView Grid.Row="1" IsVisible="{Binding ShowTeamsList}">
                                <VerticalStackLayout Spacing="0">
                                    <Label
                                        Text="One Core fireteam per company"
                                        FontAttributes="Bold"
                                        Margin="8,6,8,8" />
                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding TeamEntries}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border StrokeThickness="1" Padding="8,6" MinimumHeightRequest="50" IsVisible="{Binding IsVisible}">
                                                <VerticalStackLayout Spacing="4">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                        <Label
                                                            Grid.Column="0"
                                                            Text="{Binding Name}"
                                                            VerticalOptions="Center" />
                                                        <RadioButton
                                                            Grid.Column="1"
                                                            VerticalOptions="Center"
                                                            GroupName="CohesiveCoreFireteamSelection"
                                                            IsVisible="{Binding ShowTrackingRadioButton}"
                                                            IsChecked="{Binding IsTrackedTeam, Mode=TwoWay}"
                                                            CheckedChanged="OnTeamTrackingRadioButtonCheckedChanged" />
                                                    </Grid>
                                                    <VerticalStackLayout Spacing="3">
                                                        <Grid ColumnDefinitions="44,44,*" ColumnSpacing="8">
                                                            <Label Grid.Column="0" Text="MIN" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                                            <Label Grid.Column="1" Text="MAX" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                                            <Label Grid.Column="2" Text="UNIT" FontAttributes="Bold" />
                                                        </Grid>
                                                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding AllowedProfiles}" Spacing="2">
                                                            <BindableLayout.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid ColumnDefinitions="44,44,*" ColumnSpacing="8" IsVisible="{Binding IsVisible}" MinimumHeightRequest="50">
                                                                        <Label Grid.Column="0" Text="{Binding Min}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" VerticalOptions="Center" />
                                                                        <Label Grid.Column="1" Text="{Binding Max}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" VerticalOptions="Center" />
                                                                        <controls:UnitSelectionListItemView
                                                                            Grid.Column="2"
                                                                            ItemTappedCommand="{Binding Source={x:Reference ArmyFactionSelectionRoot}, Path=BindingContext.SelectTeamAllowedProfileCommand}"
                                                                            ItemTappedCommandParameter="{Binding .}" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </BindableLayout.ItemTemplate>
                                                        </VerticalStackLayout>
                                                    </VerticalStackLayout>
                                                </VerticalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </ScrollView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        <!-- Right column: detail pane stacked above the company pane on medium+; one at a time on compact. -->
        <Grid x:Name="RightPane" Grid.Row="2" Grid.Column="1" RowDefinitions="*,3,*" RowSpacing="0">
        <!-- Reusable unit header + profiles panel shared with vanilla faction selection page. -->
            <controls:UnitDisplayConfigurationsView x:Name="UnitDisplayConfigurationsView" Grid.Row="0" VerticalOptions="FillAndExpand" ShowSummaryRows="False" />

            <Grid x:Name="CompanyPane" Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="0">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                        <HorizontalStackLayout Spacing="8">
                            <Label
                                Text="Mercs Company"
                                FontSize="{DynamicResource FontSizeTitleSmall}"
                                FontAttributes="Bold"
                                VerticalOptions="Center" />
                            <Label Text="-" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label
                            Text="Enter Company Name"
                            TextColor="{StaticResource Danger}"
                            IsVisible="{Binding ShowCompanyNameValidationError}" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1" Stroke="{Binding CompanyNameBorderColor}" StrokeThickness="2" Padding="2,0"
                            HorizontalOptions="Fill" MaximumWidthRequest="220" MinimumWidthRequest="110" VerticalOptions="Center">
                        <Entry
                            Text="{Binding CompanyName}"
                            Placeholder="Company Name"
                            ClearButtonVisibility="WhileEditing"
                            VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout
                        Grid.Column="2"
                        VerticalOptions="Center"
                        HorizontalOptions="Fill"
                        Spacing="2">
                        <Label
                            Text="{Binding TrackedFireteamNameDisplay}"
                            HorizontalOptions="Fill"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="TailTruncation"
                            MaxLines="1" />
                        <Label
                            Text="{Binding TrackedFireteamLevelBonusText}"
                            HorizontalOptions="Fill"
                            HorizontalTextAlignment="Center"
                            FontSize="{DynamicResource FontSizeCaption}"
                            IsVisible="{Binding HasTrackedFireteamLevelBonus}"
                            LineBreakMode="WordWrap"
                            MaxLines="2" />
                    </VerticalStackLayout>
                    <Grid
                        Grid.Column="3"
                        WidthRequest="50"
                        HeightRequest="50"
                        Margin="0,0,4,0"
                        VerticalOptions="Center"
                        HorizontalOptions="End">
                        <skia:SKCanvasView
                            x:Name="TrackedFireteamLevelCanvas"
                            WidthRequest="50"
                            HeightRequest="50"
                            PaintSurface="OnTrackedFireteamLevelCanvasPaintSurface" />
                    </Grid>
                </Grid>

                <controls:MercsCompanyEntriesListView
                    Grid.Row="1"
                    VerticalOptions="FillAndExpand"
                    ViewportHeightRatio="0.4"
                    ItemsSource="{Binding MercsCompanyEntries}"
                    SelectEntryCommand="{Binding SelectMercsCompanyEntryCommand}"
                    RemoveEntryCommand="{Binding RemoveMercsCompanyEntryCommand}"
                    ShowOrderModifierBadges="True"
                    PeripheralIconCanvasPaintSurface="OnPeripheralIconCanvasPaintSurface"
                    IrregularIconCanvasPaintSurface="OnIrregularIconCanvasPaintSurface"
                    RegularModifierIconCanvasPaintSurface="OnRegularModifierIconCanvasPaintSurface" />
                <Button
                    Grid.Row="1"
                    Text="START COMPANY"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0,0,10,10"
                    ZIndex="1"
                    Command="{Binding StartCompanyCommand}"
                    IsEnabled="{Binding IsCompanyValid}" />
            </Grid>
        </Grid>

        <Grid
            x:Name="UnitFilterOverlay"
            Grid.Row="0"
            Grid.RowSpan="3"
            Grid.ColumnSpan="2"
            IsVisible="False"
            BackgroundColor="#880E1116"
            InputTransparent="False"
            ZIndex="100">
            <ContentView
                x:Name="UnitFilterPopupHost"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                MaximumWidthRequest="700" />
        </Grid>

        <!-- Compact-only full-screen vertical faction selector. -->
        <controls:FactionSelectorOverlayView
            x:Name="FactionSelectorOverlay"
            Grid.Row="0"
            Grid.RowSpan="3"
            Grid.ColumnSpan="2"
            ZIndex="200"
            Title="{Binding Title}"
            ItemsSource="{Binding Factions}"
            SelectFactionCommand="{Binding SelectFactionCommand}" />
    </Grid>
</templates:CompanySelectionPageBase>

